CLASS /RB1M/CL_SD_PRT_INV_PDF2MAIL IMPLEMENTATION.


  METHOD /rb4r/sd_if_prt_inv_pdf2mail~change_output_parameters.
**<<< Handle for Data2mail
    DATA lo_sd_printout_static TYPE REF TO /rb1m/cl_sd_printout_static.
    DATA: ls_output TYPE /rb1m/sd_i_output.
    lo_sd_printout_static = /rb1m/cl_sd_printout_static=>get_instance( ).
    lo_sd_printout_static->get_key_data(
      RECEIVING
        es_key_data =    ls_output
    ).
    IF ls_output is NOT INITIAL.
      cs_outputparams-nopreview = abap_true.
      cs_outputparams-nodialog = abap_true.
      cs_outputparams-getpdf = 'X'.
    ENDIF.
*>>>>>> Handle for Data2mail
  ENDMETHOD.


  METHOD /rb4r/sd_if_prt_inv_pdf2mail~export_pdf.

   DATA lo_sd_printout_static TYPE REF TO /rb1m/cl_sd_printout_static.
   lo_sd_printout_static = /rb1m/cl_sd_printout_static=>get_instance( ).
**<<< Handle for Data2mail
    " export pdf to class attribute
    IF is_form_output IS NOT INITIAL.

      CALL METHOD lo_sd_printout_static->set_fpformoutput
        EXPORTING
          is_fpformoutput = is_form_output.              " Form Output (PDF, PDL)
    ENDIF.

*>>>>>> Handle for Data2mail
  ENDMETHOD.


  METHOD /rb4r/sd_if_prt_inv_pdf2mail~fill_message_details.
**<<< Handle for Data2mail
    DATA lo_sd_printout_static TYPE REF TO /rb1m/cl_sd_printout_static.
    DATA: ls_output TYPE /rb1m/sd_i_output.
    lo_sd_printout_static = /rb1m/cl_sd_printout_static=>get_instance( ).
    lo_sd_printout_static->get_key_data(
      RECEIVING
        es_key_data =    ls_output
    ).
    IF ls_output IS NOT INITIAL.
      cs_nast-objky     = ls_output-document.
      cs_nast-kappl     = ls_output-application.
      cs_nast-spras     = ls_output-language.
      cs_nast-kschl     = ls_output-outputtype.
      cs_nast-parnr     = ls_output-Parner.
      cs_nast-parvw     = ls_output-PartnerFunction.
      cs_tnapr-sform    = ls_output-PDFFormName.
      cs_tnapr-formtype = ls_output-formtype.
    ENDIF.
*>>>>>> Handle for Data2mail
  ENDMETHOD.
ENDCLASS.
