CLASS /RB1M/CL_SD_PRINTOUT_STATIC IMPLEMENTATION.


  METHOD clear_instance.
    IF mo_inst IS BOUND.
      CLEAR  mo_inst.
    ENDIF.
  ENDMETHOD.


  METHOD clear_key_data.
    IF ms_key_obj IS NOT INITIAL.
      CLEAR ms_key_obj.
    ENDIF.
    IF ms_fpformoutput-pdf IS NOT INITIAL.
      CLEAR ms_fpformoutput.
    ENDIF.
  ENDMETHOD.


  METHOD get_fpformoutput.
    es_fpformoutput = ms_fpformoutput.
  ENDMETHOD.


  METHOD get_instance.
* init
    CLEAR ro_inst.
* Create isntance
    IF mo_inst IS NOT BOUND.
      CREATE OBJECT mo_inst.
    ENDIF.
    ro_inst = mo_inst.

  ENDMETHOD.  "get_instance


  METHOD get_key_data.
    es_key_data = ms_key_obj.
  ENDMETHOD.


  METHOD set_fpformoutput.
    ms_fpformoutput = is_fpformoutput.
  ENDMETHOD.


  method SET_KEY_DATA.
    ms_key_obj = is_key.
  endmethod.
ENDCLASS.

