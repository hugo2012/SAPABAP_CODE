  METHOD set_pgi_and_clear_buffer.

    DATA: ls_excl_prd_dat TYPE /scwm/dlv_query_excl_str,
          ls_read_options TYPE /scwm/dlv_query_contr_str,
          lt_selection    TYPE /scwm/dlv_selection_tab,
          lt_hu_headers   TYPE /scwm/tt_huhdr_int,
          lt_hustat       TYPE /scwm/tt_hustatus,
          lv_msg          TYPE bapi_msg,
          lt_message      TYPE bapiret2_tab,
          ls_message      TYPE bapiret2.

    CLEAR: ev_error, et_bapiret.

    IF mv_lopt IS INITIAL.
*-Freight order & Door block status
      TRY.
          /scwm/cl_rf_asr=>get_instance( )->/scwm/if_rf_asr~get_lp_door_by_bol(
            EXPORTING
              iv_bol         = ms_hdline-freightorder
              iv_whse_no     = ms_hdline-lgnum
              iv_direction   = /scwm/if_af_sr_transport=>sc_direction-outbound
            IMPORTING
              et_t_lp_door   = DATA(lt_lp_door) ).

        CATCH /scwm/cx_rf_asr. " Exception Class for RF Advanced S&R
          ev_error = abap_true.
          MESSAGE e008(/rb4r/lo_rfid_load) WITH ms_hdline-freightorder INTO lv_msg.
          add_message( CHANGING ct_bapiret = et_bapiret ).
          ms_hdline-message = lv_msg.
          RETURN.
      ENDTRY.

      mv_lopt = lt_lp_door[ door = ms_hdline-gate ]-unl_point.
      IF mv_lopt IS INITIAL.
        ev_error = abap_true.
        MESSAGE e010(/rb4r/lo_rfid_load) INTO lv_msg WITH ms_hdline-freightorder ms_hdline-gate.
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ms_hdline-message = lv_msg.
      ENDIF.
    ENDIF.

*-Check HU status at EWM level
    lt_selection = VALUE #( option    = wmegc_option_eq
                          ( fieldname = /scwm/if_dl_logfname_c=>sc_whno_i
                            low       = ms_hdline-lgnum )
                          ( fieldname = /scdl/if_dl_logfname_c=>sc_refdocno_frd_h
                            low       = |{ ms_hdline-freightorder ALPHA = IN }| )
                          ( fieldname = /scwm/if_dl_logfname_c=>sc_locationno_lp_i
                            low       = mv_lopt )
                          ( fieldname = /scdl/if_dl_logfname_c=>sc_status_value_dbo_i
                            low       = /scdl/if_dl_status_c=>sc_v_false ) ).

    CLEAR ls_excl_prd_dat WITH abap_true.
    ls_excl_prd_dat-hu_data = ''.
    ls_excl_prd_dat-hu_prd_data = ''.
    ls_read_options-data_retrival_only = 'X'.
    ls_read_options-mix_in_object_instances = 'Y'. "DB Fetch

    TRY.
        /scwm/cl_dlv_management_prd=>get_instance( )->query(
                 EXPORTING
                        it_selection    = lt_selection
                        iv_doccat       = 'PDO'
                        is_read_options = ls_read_options
                        is_exclude_data = ls_excl_prd_dat
                      IMPORTING
                        et_hu_headers   = lt_hu_headers ).
      CATCH /scdl/cx_delivery. " Exception Class of Delivery
        ev_error = abap_true.
    ENDTRY.

*-Raise Error message if HU not found.
    IF lt_hu_headers IS INITIAL .
      MESSAGE e007(/rb4r/lo_rfid_load) WITH ms_hdline-freightorder INTO lv_msg.
      add_message( CHANGING ct_bapiret = et_bapiret ).
      ms_hdline-message = lv_msg.
      ev_error = abap_true.
      RETURN.
    ENDIF.

*-Load status
    DELETE lt_hu_headers WHERE top IS INITIAL.
    DATA(lt_huhdr) = CORRESPONDING /scwm/tt_huhdr_int( lt_hu_headers MAPPING guid_hu = guid_hu huident = huident ).

    CALL FUNCTION '/SCWM/HU_STATUS_SELECT'
      EXPORTING
        iv_stat   = wmegc_hustat_loaded
        it_huhdr  = lt_huhdr
      IMPORTING
        et_hustat = lt_hustat.

    DELETE lt_hustat WHERE inact = abap_true.  "Remove not loaded HUs

    ms_hdline-total_count   = lines( lt_hu_headers ).
    ms_hdline-current_count = lines( lt_hustat ).

    IF ms_hdline-current_count = ms_hdline-total_count.  "All HUs Loaded.

      "Check whether last scanned HU updated in TM.
      IF ms_output_data-direction = mc_dir_in.
        DO 10 TIMES.
          IF check_scanned_hu_loaded_tm( ) = abap_true.
            EXIT. "Exit from loop if load status updated.
          ENDIF.

          WAIT UP TO 1 SECONDS.
        ENDDO.
      ENDIF.

      "Set loading finished at stop level
      DATA(lr_load_fin) = NEW /scwm/cl_af_tmi_rf( ).

      lr_load_fin->set_load_finish(
        EXPORTING
          iv_lgnum   = ms_hdline-lgnum
          iv_frdno   = ms_hdline-freightorder
          iv_lopt    = mv_lopt
          iv_door    = CONV #( ms_output_data-gate )
        IMPORTING
          et_message = lt_message ).

      IF lt_message IS INITIAL.
        COMMIT WORK AND WAIT.
      ELSE.
        ROLLBACK WORK.
      ENDIF.

      "Return message for user
      CLEAR ls_message.
      READ TABLE lt_message INTO ls_message WITH KEY type = 'E'.
      IF sy-subrc IS NOT INITIAL.
        READ TABLE lt_message INTO ls_message INDEX 1.
      ENDIF.

      IF ls_message IS NOT INITIAL.
        MESSAGE ID ls_message-id TYPE 'E' NUMBER ls_message-number
        WITH ls_message-message_v1
             ls_message-message_v2
             ls_message-message_v3
             ls_message-message_v4 INTO lv_msg.
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ms_hdline-message = lv_msg.
        ev_error = abap_true.
        RETURN.
      ENDIF.

*-Display PGI posting message in Front end
      push_frond_end( iv_lgnum           = ms_output_data-warehouseno
                      iv_gate            = CONV #( ms_output_data-gate )
                      iv_load_completed  = abap_true ).
      WAIT UP TO 1 SECONDS.

*-Clear Buffer tables.
      DELETE FROM /rb4r/lo_hdline WHERE ( lgnum = ms_output_data-warehouseno AND
                                          gate  = ms_output_data-gate ).
      IF sy-subrc <> 0.
        MESSAGE e009(/rb4r/lo_rfid_load) INTO lv_msg.
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ms_hdline-message = lv_msg.
        ev_error = abap_true.
        RETURN.
      ENDIF.

      DELETE FROM /rb4r/lo_load_r WHERE ( freightorder = ms_hdline-freightorder ).
      IF sy-subrc <> 0.
        MESSAGE e009(/rb4r/lo_rfid_load) INTO lv_msg.
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ms_hdline-message = lv_msg.
        ev_error = abap_true.
        RETURN.
      ENDIF.

      DELETE FROM /rb4r/lo_rfiderr WHERE ( lgnum = ms_output_data-warehouseno AND
                                           gate  = ms_output_data-gate ). "#EC CI_SUBRC  "No Error handing required for error hus

      COMMIT WORK AND WAIT.
*-Update correct count details.
    ELSE.
      CLEAR: mt_load, ms_error_hu.
      update_monitor_buffer( ).
    ENDIF.

  ENDMETHOD.


  METHOD unload_hu.

    CLEAR: ev_error, et_bapiret, es_output, ev_load_completed.

    clear_buffer( ).

    DATA(ls_data) = is_data.
*-Determine internal HU number
    determine_hu_data( EXPORTING iv_hu_number = ls_data-handlingunit
                                 iv_lgnum     = ls_data-warehouseno
                       IMPORTING ev_hu_number = ls_data-handlingunit
                                 ev_error     = ev_error ).
    IF ev_error = abap_true.
      add_message( CHANGING ct_bapiret = et_bapiret ).
      RETURN.
    ENDIF.

    ms_output_data = CORRESPONDING #( ls_data EXCEPT gate freightorder ).

*-Validate Input data
    validatate_data( EXPORTING is_data    = ls_data
                     IMPORTING ev_error   = ev_error
                               et_bapiret = et_bapiret ).
    CHECK ms_output_data-gate IS NOT INITIAL.

*-Get buffer data to update Load monitor
    get_monitor_buffer( IMPORTING ev_read_error = DATA(lv_read_error)
                                  et_bapiret    = DATA(lt_bapiret) ).
    IF lv_read_error = abap_true.
      ev_error = abap_true.
      APPEND LINES OF lt_bapiret TO et_bapiret.
    ENDIF.

*-Set Unloading in EWM
    IF ev_error = abap_false AND ms_error_hu IS INITIAL.
      TEST-SEAM unload_hu.
        update_unloading_status( EXPORTING is_data    = ls_data
                                 IMPORTING ev_error   = ev_error
                                           et_bapiret = et_bapiret ).
      END-TEST-SEAM.
    ENDIF.

*-Update Load monitor buffer table
    IF ev_error = abap_true.
      CLEAR: mt_load.
    ENDIF.

    TEST-SEAM unload_buf_upd.
      update_monitor_buffer( ).
    END-TEST-SEAM.

*-Trigger PGI and clear buffer table.
    CHECK ev_error = abap_false.
    IF  ms_hdline-current_count >=  ms_hdline-total_count "All HUs Loaded.
    AND check_error_hu_exists( ) = abap_false.  "No Error HUs exists

      TEST-SEAM unload_pgi.
        set_pgi_and_clear_buffer( IMPORTING ev_error   = ev_error
                                            et_bapiret = et_bapiret ).
      END-TEST-SEAM.

      IF ms_hdline-current_count = ms_hdline-total_count.
*-display message in Load Monitor "All Hus are loaded, PGI in progress".
        ev_load_completed = abap_true.
      ENDIF.
    ENDIF.
    es_output = ms_output_data.

  ENDMETHOD.


  METHOD update_buffer_for_release_load.

    DATA: ls_hdline TYPE /rb4r/lo_hdline,
          lv_addr   TYPE ad_addrnum.

    CHECK NOT ( iv_lgnum IS INITIAL AND iv_gate IS INITIAL ).
    CHECK is_gate_valid_for_rfid_load( iv_lgnum = iv_lgnum
                                       iv_gate  = iv_gate ) .

    clear_monitor_db_buffer( iv_lgnum         = iv_lgnum
                             iv_gate          = iv_gate
                             iv_freight_order = iv_freight_order ).

    ls_hdline = VALUE #( lgnum         = iv_lgnum
                         gate          = iv_gate
                         freightorder  = iv_freight_order
                         carrier       = iv_carrier
                         license_plate = iv_license_plate
                         carrier_name  = read_carrier_name( iv_carrier ) ).

    TEST-SEAM upd_release_load.
      MODIFY /rb4r/lo_hdline FROM ls_hdline.
      IF sy-subrc IS NOT INITIAL.
        ROLLBACK WORK.
      ENDIF.
    END-TEST-SEAM.

*-Update Front end
    push_frond_end( iv_lgnum = iv_lgnum iv_gate  = iv_gate iv_load_info_disp = abap_true ).

  ENDMETHOD.


  METHOD update_buf_for_unrelease_load.

    DATA: lv_msg TYPE char100.

    CLEAR: ev_error.

    CHECK NOT ( iv_lgnum IS INITIAL AND iv_gate IS INITIAL AND iv_freight_order IS INITIAL ).
    CHECK is_gate_valid_for_rfid_load( iv_lgnum = iv_lgnum iv_gate  = iv_gate ) .

*-Check loaded HUs in Load table.
    SELECT SINGLE @abap_true FROM /rb4r/lo_i_rfidloadbasic
      WHERE freightorder = @iv_freight_order AND isscanned = '+'
      INTO @DATA(lv_loaded_hus).
    IF sy-subrc IS INITIAL.
      MESSAGE e018(/rb4r/lo_rfid_load) WITH iv_freight_order INTO lv_msg.
      ev_error = abap_true.
      RETURN.
    ENDIF.

*-Check Error HUs in Door
    SELECT SINGLE @abap_true FROM /rb4r/lo_i_rfiderrorbasic
      WHERE lgnum = @iv_lgnum AND gate = @iv_gate
      INTO @lv_loaded_hus.
    IF sy-subrc IS INITIAL.
      MESSAGE e019(/rb4r/lo_rfid_load) WITH iv_gate INTO lv_msg.
      ev_error = abap_true.
      RETURN.
    ENDIF.

*-Clear monitor buffer from DB
    clear_monitor_db_buffer( iv_lgnum         = iv_lgnum
                             iv_gate          = iv_gate
                             iv_freight_order = iv_freight_order ).

*-Update Front end
    push_frond_end( iv_lgnum = iv_lgnum iv_gate  = iv_gate ).

  ENDMETHOD.


  METHOD update_loading_status.

    DATA: lo_bd_local_upd TYPE REF TO /rb4r/lo_bd_rfid_local_upd.

    CLEAR: ev_error, et_bapiret.
    DATA(lo_log) = NEW /scwm/cl_log( ).
    TRY.
        /scwm/cl_sr_bom_dlv=>get_instance( )->set_dlv_hu_load(
          EXPORTING
            iv_lgnum          = is_data-warehouseno
            it_huident        = VALUE #( ( lgnum = is_data-warehouseno huident = is_data-handlingunit ) )
            iv_sr_dlv_act     = wmesr_act_load
            io_log            = lo_log
          IMPORTING
            ev_rejected       = ev_error
            et_return_codes   = DATA(lt_return_code) ).

      CATCH /scwm/cx_sr_error. " Superclass for Exceptions in Shipping/Receiving
        ev_error = abap_true.
    ENDTRY.

    DATA(lt_message) = lo_log->get_prot( ).
    IF ev_error = abap_true OR line_exists( lt_return_code[ failed = abap_true ] ).
      ev_error = abap_true.
      ROLLBACK WORK.
      /scwm/cl_tm=>cleanup( ).
      et_bapiret = lt_message.

    ELSE.
      LOOP AT lt_message INTO DATA(ls_message) WHERE type CA 'EA'.

        MESSAGE ID ls_message-id TYPE 'E' NUMBER ls_message-number
            WITH ls_message-message_v1 ls_message-message_v2
                 ls_message-message_v3 ls_message-message_v4 INTO DATA(lv_msg).
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ms_hdline-message = lv_msg.

        ROLLBACK WORK.
        /scwm/cl_tm=>cleanup( ).
        ev_error =  abap_true.
        EXIT.
      ENDLOOP.
    ENDIF.

    CHECK ev_error = abap_false.

    CALL FUNCTION '/SCWM/LOADING_INFO_SAVE'
      EXPORTING
        iv_commit = ' '.

*-Call BAdI
    TRY.
        GET BADI lo_bd_local_upd.
      CATCH cx_badi_not_implemented.
        CLEAR lo_bd_local_upd.
      CATCH cx_badi_multiply_implemented.
        CLEAR lo_bd_local_upd.
    ENDTRY.
*-Update Local line tables
    IF lo_bd_local_upd IS BOUND.
      TRY.
          CALL BADI lo_bd_local_upd->load_hu_upd_local_line
            EXPORTING
              is_rfid_input = ms_output_data.
        CATCH cx_badi_not_implemented  ##NO_HANDLER.

      ENDTRY.
    ENDIF.

    COMMIT WORK AND WAIT.
    /scwm/cl_tm=>cleanup( ).

*-Update Buffer table entries.
    ms_hdline-current_count += 1.
    ASSIGN mt_load[ freightorder = ms_output_data-freightorder handlingunit = ms_output_data-handlingunit ] TO FIELD-SYMBOL(<ls_hu>).
    IF sy-subrc IS INITIAL.
      <ls_hu>-is_scanned = '+'.
      <ls_hu>-scan_date = sy-datum.
      <ls_hu>-scan_time = sy-uzeit.
    ENDIF.

  ENDMETHOD.


  METHOD update_monitor_buffer.

*-Update Header table
    IF NOT ms_hdline IS INITIAL.
      MODIFY /rb4r/lo_hdline FROM ms_hdline.
      IF sy-subrc <> 0.
        ROLLBACK WORK.
      ENDIF.
    ENDIF.

*-Update Load status table
    IF NOT mt_load IS INITIAL.
      MODIFY /rb4r/lo_load_r FROM TABLE mt_load.
      IF sy-subrc <> 0.
        ROLLBACK WORK.
      ENDIF.
    ENDIF.

*-Update Error HU
    IF NOT ms_error_hu IS INITIAL.

      IF ms_output_data-direction = mc_dir_out. "Unloading
        DELETE /rb4r/lo_rfiderr FROM ms_error_hu.
        IF sy-subrc <> 0.
          CLEAR: ms_error_hu. "No handling required.
        ENDIF.

      ELSE. "Loading
        MODIFY /rb4r/lo_rfiderr FROM ms_error_hu.
        IF sy-subrc <> 0.
          CLEAR: ms_error_hu. "No handling required.
        ENDIF.
      ENDIF.

    ENDIF.

    COMMIT WORK AND WAIT.
    IF sy-subrc <> 0.
      ROLLBACK WORK.
    ENDIF.

  ENDMETHOD.


