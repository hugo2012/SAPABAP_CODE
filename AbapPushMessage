        /scwm/cl_tm=>cleanup( ).
        ev_error =  abap_true.
        EXIT.
      ENDLOOP.
    ENDIF.

    CHECK ev_error = abap_false.

    CALL FUNCTION '/SCWM/LOADING_INFO_SAVE'
      EXPORTING
        iv_commit = ' '.

*-Call BAdI
    TRY.
        GET BADI lo_bd_local_upd.
      CATCH cx_badi_not_implemented.
        CLEAR lo_bd_local_upd.
      CATCH cx_badi_multiply_implemented.
        CLEAR lo_bd_local_upd.
    ENDTRY.
*-Update Local line tables
    IF lo_bd_local_upd IS BOUND.
      DATA(ls_rfid_input) = ms_output_data.
      IF ls_rfid_input-freightorder IS INITIAL.
        ls_rfid_input-freightorder = ms_hdline-freightorder.
      ENDIF.

      TRY.
          CALL BADI lo_bd_local_upd->load_hu_upd_local_line
            EXPORTING
              is_rfid_input = ls_rfid_input.
        CATCH cx_badi_not_implemented  ##NO_HANDLER.

      ENDTRY.
    ENDIF.

    COMMIT WORK AND WAIT.
    /scwm/cl_tm=>cleanup( ).

*-Update Buffer table entries.
    read_hu_ext_number( EXPORTING it_hunumbers = VALUE #( ( hu_exid = ms_output_data-handlingunit ) )
                        IMPORTING et_huheader  = DATA(lt_hu_erp) ).
    IF lt_hu_erp IS NOT INITIAL.
      DATA(lv_erp_hu) = lt_hu_erp[ 1 ]-ext_id_hu_2.
    ENDIF.

    ms_hdline-current_count -= 1.
    APPEND INITIAL LINE TO mt_load ASSIGNING FIELD-SYMBOL(<ls_hu>).
    IF sy-subrc IS INITIAL.
      <ls_hu>-freightorder     = ms_hdline-freightorder.
      <ls_hu>-handlingunit     = ms_output_data-handlingunit.
      <ls_hu>-handlingunit_ext = COND #( WHEN lv_erp_hu IS NOT INITIAL THEN lv_erp_hu
                                         ELSE ms_output_data-handlingunit ).
      <ls_hu>-is_scanned       = ' '.
      <ls_hu>-scan_date        = sy-datum.
      <ls_hu>-scan_time        = sy-uzeit.
    ENDIF.

  ENDMETHOD.


  METHOD validatate_data.

    CLEAR: ev_error, et_bapiret, ev_fo_not_released.
    DATA: lv_msg TYPE bapi_msg.

*-Validate RFID Gate
    SELECT gate, rfidgate
      FROM /rb4r/lo_i_rfidgatebasic
      WHERE lgnum = @is_data-warehouseno
      AND rfidgate = @is_data-gate
      INTO TABLE @DATA(lt_gate).
    IF sy-subrc <> 0.
      MESSAGE e000(/rb4r/lo_rfid_load) WITH is_data-gate INTO lv_msg.
      ev_error =  abap_true.
      add_message( CHANGING ct_bapiret = et_bapiret ).
    ELSEIF lines( lt_gate ) > 1.
      MESSAGE e001(/rb4r/lo_rfid_load) WITH is_data-gate INTO lv_msg.
      ev_error =  abap_true.
      add_message( CHANGING ct_bapiret = et_bapiret ).
    ENDIF.

    CHECK ev_error = abap_false.
    ms_output_data-gate = lt_gate[ 1 ]-gate.

*-Unloading should be possible for blocked case also;
*-So FO & Warehouse Gate validation not required;
    IF ms_output_data-direction = mc_dir_out.
      RETURN.
    ENDIF.

*-Read Freight order
    SELECT
      transportationorderuuid,
      transportationorder,
      transportationorderexecsts,
      carrier,
*      \_transportationorderitem[ (*) INNER ]-transportationorderitemuuid,
*      CAST( \_transportationorderitem[ (*) INNER ]-/rb4c/packageidentifier AS CHAR( 20 ) ) AS hu,
      \_transportationorderstop[ (*) INNER ]-transpordstopwrhsnmbr  AS warehousenumber,
      \_transportationorderstop[ (*) INNER ]-transpordstopwrhsdoorid AS gate,
      \_transportationorderstop[ (*) INNER ]-transpordstopwrhsdoorstatus AS gatestatus
      FROM i_transportationorder
      WHERE transportationordercategory = @/scmtms/if_tor_const=>sc_tor_cat_for
      AND   transpordlifecyclestatus    <> '10' "Canceled
      AND   transpordlifecyclestatus    <> '05' "Completed
*      AND \_transportationorderitem[ (*) INNER ]-transporditemcategory   = @/scmtms/if_tor_const=>sc_tor_item_category-packaging
*      AND \_transportationorderitem[ (*) INNER ]-/rb4c/packageidentifier = @is_data-handlingunit
*      AND \_transportationorderitem[ (*) INNER ]-ismaincargoitem         = @abap_true
      AND \_transportationorderstop[ (*) INNER ]-transpordstopwrhsnmbr   = @is_data-warehouseno
      AND \_transportationorderstop[ (*) INNER ]-transpordstopwrhsdoorid = @ms_output_data-gate
      AND \_transportationorderstop[ (*) INNER ]-transpordstopcategory   = @/scmtms/if_tor_const=>sc_tor_stop_cat-outbound
      AND \_transportationorderstop[ (*) INNER ]-transpordstoprole       = @/scmtms/if_tor_const=>sc_tor_stop_role-load_substop
      INTO TABLE @DATA(lt_tor_fo).
    IF sy-subrc <> 0.
      ev_error = abap_true.
      MESSAGE e002(/rb4r/lo_rfid_load) WITH is_data-handlingunit INTO lv_msg.
      add_message( CHANGING ct_bapiret = et_bapiret ).
      ms_hdline-message = lv_msg.
      RETURN.
    ENDIF.

*Freight order status
    DELETE lt_tor_fo WHERE NOT ( transportationorderexecsts = /scmtms/if_tor_status_c=>sc_root-execution-v_in_execution
                                 AND gatestatus = 'A' ). "Arrived at door
    IF lt_tor_fo IS INITIAL.
      ev_error           = abap_true.
      ev_fo_not_released = abap_true.
      MESSAGE e004(/rb4r/lo_rfid_load) INTO lv_msg.
      add_message( CHANGING ct_bapiret = et_bapiret ).
      ms_hdline-message = lv_msg.
      RETURN.
    ENDIF.

*Warehouse Gate
    DATA(ls_tor_fo) = VALUE #( lt_tor_fo[ gate = ms_output_data-gate ] OPTIONAL ).
    ms_output_data-freightorder = |{ ls_tor_fo-transportationorder ALPHA = OUT }|.
    IF ms_output_data-freightorder IS INITIAL.
      ev_error = abap_true.
      MESSAGE e003(/rb4r/lo_rfid_load) INTO lv_msg.
      add_message( CHANGING ct_bapiret = et_bapiret ).
      ms_hdline-message = lv_msg.
      RETURN.
    ENDIF.

*-Carrier
    mv_carrier = ls_tor_fo-carrier.
*-Set Last scanned HU UUID
*    mv_last_scan_hu = ls_Tor_FO-transportationorderitemuuid.

*-Freight order & Door block status
    TEST-SEAM lp_door.
      TRY.
          /scwm/cl_rf_asr=>get_instance( )->/scwm/if_rf_asr~get_lp_door_by_bol(
            EXPORTING
              iv_bol         = ms_output_data-freightorder
              iv_whse_no     = ms_output_data-warehouseno
              iv_direction   = /scwm/if_af_sr_transport=>sc_direction-outbound
            IMPORTING
              et_t_lp_door   = DATA(lt_lp_door)
              et_lp_fo       = DATA(lt_lp) ).

        CATCH /scwm/cx_rf_asr. " Exception Class for RF Advanced S&R
          ev_error = abap_true.
          MESSAGE e008(/rb4r/lo_rfid_load) WITH ms_output_data-freightorder INTO lv_msg.
          add_message( CHANGING ct_bapiret = et_bapiret ).
          ms_hdline-message = lv_msg.
          RETURN.
      ENDTRY.
    END-TEST-SEAM.

    IF lt_lp_door IS INITIAL AND lt_lp IS NOT INITIAL.
      ev_error = abap_true.
      MESSAGE e166(/scwm/rf_de) INTO lv_msg.
      add_message( CHANGING ct_bapiret = et_bapiret ).
      ms_hdline-message = lv_msg.

    ELSEIF NOT line_exists( lt_lp_door[ door = ms_output_data-gate ] ).
      ev_error = abap_true.
      MESSAGE e003(/rb4r/lo_rfid_load) INTO lv_msg.
      add_message( CHANGING ct_bapiret = et_bapiret ).
      ms_hdline-message = lv_msg.

    ELSE.
      mv_lopt = lt_lp_door[ door = ms_output_data-gate ]-unl_point.
      IF mv_lopt IS INITIAL.
        ev_error = abap_true.
        MESSAGE e010(/rb4r/lo_rfid_load) INTO lv_msg WITH ms_output_data-freightorder ms_output_data-gate.
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ms_hdline-message = lv_msg.
      ENDIF.
    ENDIF.

*-Check HU
    SELECT transportationorderitemuuid, transportationorderuuid, transporditempackageid
      FROM i_transportationorderitem
     WHERE transportationorderuuid = @ls_tor_fo-transportationorderuuid
       AND transporditemcategory   = @/scmtms/if_tor_const=>sc_tor_item_category-packaging
       AND transporditempackageid  = @is_data-handlingunit
       AND ismaincargoitem         = @abap_true
       INTO TABLE @DATA(lt_tor_hu).
    IF sy-subrc IS NOT INITIAL.
      mv_wrong_hu = abap_true.
    ELSE.
      mv_last_scan_hu = VALUE #( lt_tor_hu[ 1 ]-transportationorderitemuuid OPTIONAL ).
    ENDIF.
  ENDMETHOD.
ENDCLASS.
