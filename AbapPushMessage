CLASS /RB4R/CL_LO_AUTO_ID_LOAD_CTRL IMPLEMENTATION.


  METHOD add_message.

*-Add system message in table.
    APPEND VALUE #( type       = sy-msgty
                    id         = sy-msgid
                    number     = sy-msgno
                    message_v1 = sy-msgv1
                    message_v2 = sy-msgv2
                    message_v3 = sy-msgv3
                    message_v4 = sy-msgv4 ) TO ct_bapiret.

  ENDMETHOD.


  METHOD check_error_hu_exists.

*-Check error HUs against warehouse Gate

    SELECT SINGLE @abap_true
           FROM /rb4r/lo_i_rfiderrorbasic
           INTO @DATA(lv_exists)
           WHERE  lgnum = @ms_output_data-warehouseno
           AND     gate = @ms_output_data-gate.
    IF sy-subrc IS INITIAL.
      rv_error_hu_exists = abap_true.
    ENDIF.

  ENDMETHOD.


  METHOD check_scanned_hu_loaded_tm.

    CHECK mv_last_scan_hu IS NOT INITIAL.

*-Get loading status
    SELECT SINGLE transporditemhndlgexecstatus       "#EC CI_SEL_NESTED
          FROM i_transportationorderitem
         WHERE transportationorderitemuuid = @mv_last_scan_hu
           INTO @DATA(lv_load_status).
    IF sy-subrc IS INITIAL.
      rv_loaded = COND #( WHEN lv_load_status = /scmtms/if_tor_status_c=>sc_item_tr-handling_exec-v_loaded
                          THEN abap_true ELSE abap_false ).
    ENDIF.
  ENDMETHOD.


  METHOD clear_buffer.

    CLEAR: ms_output_data,
           ms_hdline,
           mt_load,
           mv_carrier,
           mv_lopt,
           mv_last_scan_hu,
           ms_error_hu,
           mv_wrong_hu.

  ENDMETHOD.


  METHOD clear_monitor_db_buffer.

    TEST-SEAM clear_db.
      IF NOT ( iv_lgnum IS INITIAL AND iv_gate IS INITIAL ).

        DELETE FROM /rb4r/lo_hdline WHERE lgnum = iv_lgnum AND gate = iv_gate. "#EC CI_SUBRC

        DELETE FROM /rb4r/lo_rfiderr WHERE lgnum = iv_lgnum AND gate = iv_gate. "#EC CI_SUBRC

      ENDIF.

      IF iv_freight_order IS NOT INITIAL.

        DELETE FROM /rb4r/lo_load_r WHERE freightorder = iv_freight_order. "#EC CI_SUBRC

      ENDIF.
    END-TEST-SEAM.
  ENDMETHOD.


  METHOD determine_hu_data.

    DATA: lt_mapstloc TYPE /scwm/tt_tmapstloc,
          lv_msg      TYPE text100.

    DATA(lo_det_hu) = NEW /rb4r/cl_sd_det_hu_data( ).

    TRY.
        lo_det_hu->determine_hu_data(
            EXPORTING
              i_hu_number = iv_hu_number
            IMPORTING
              e_hu_number = ev_hu_number ).

      CATCH /rb4r/cx_sd_det_hu_data INTO DATA(lo_ex). " Exception class for HU DATA determin.

*-In case of multiple HUs found, Read HU with Plant
        IF lo_ex->if_t100_message~t100key-msgid = '/RB4R/SD_DET_HU_MSG'
        AND lo_ex->if_t100_message~t100key-msgno = 006.

          CALL FUNCTION '/SCWM/TMAPSTLOC_READ_MULTI'   "Plant --> Warehouse number mapping
            EXPORTING
              iv_lgnum     = iv_lgnum
            IMPORTING
              et_tmapstloc = lt_mapstloc
            EXCEPTIONS
              not_found    = 1
              OTHERS       = 2.
          IF sy-subrc IS INITIAL.
            /scmtms/cl_logint_cmn_reuse=>get_bsg_and_logsys( IMPORTING ev_logsys = DATA(lv_logsys) ).
            SORT lt_mapstloc BY logsys.
            DELETE lt_mapstloc WHERE logsys NE lv_logsys. "Filter with Logical system

            SORT  lt_mapstloc BY plant.
            DELETE ADJACENT DUPLICATES FROM lt_mapstloc COMPARING plant.  "Remome Duplicate entries of plant
            IF lines( lt_mapstloc ) = 1.   "Single plant --> Read HU with plant number
              TRY.
                  lo_det_hu->determine_hu_data(
                    EXPORTING
                      i_hu_number     = iv_hu_number
                      i_plant         = VALUE #( lt_mapstloc[ 1 ]-plant )
                    IMPORTING
                      e_hu_number     = ev_hu_number ).
                CATCH /rb4r/cx_sd_det_hu_data INTO DATA(lo_ex1). " Exception class for HU DATA determin.
                  IF lo_ex1->if_t100_message~t100key-msgid = '/RB4R/SD_DET_HU_MSG'
                  AND lo_ex1->if_t100_message~t100key-msgno = 006.
                    DATA(lv_multi_hu_err) =  abap_true.  "IF Multiple HU found, Raise error to Partial unload not possible
                  ELSE.
                    ev_error = abap_true.
                    MESSAGE ID lo_ex1->if_t100_message~t100key-msgid
                    TYPE 'E'
                    NUMBER  lo_ex1->if_t100_message~t100key-msgno
                    WITH    lo_ex1->if_t100_message~t100key-attr1
                            lo_ex1->if_t100_message~t100key-attr2
                            lo_ex1->if_t100_message~t100key-attr3
                            lo_ex1->if_t100_message~t100key-attr4
                    INTO lv_msg.
                  ENDIF.
              ENDTRY.
            ELSE. "Multiple plant for warehouse --> Raise error
              lv_multi_hu_err = abap_true.
            ENDIF.
          ELSE.
            lv_multi_hu_err = abap_true.
          ENDIF.
        ELSE.
          ev_error = abap_true.
          MESSAGE ID lo_ex->if_t100_message~t100key-msgid
          TYPE 'E'
          NUMBER  lo_ex->if_t100_message~t100key-msgno
          WITH    lo_ex->if_t100_message~t100key-attr1
                  lo_ex->if_t100_message~t100key-attr2
                  lo_ex->if_t100_message~t100key-attr3
                  lo_ex->if_t100_message~t100key-attr4
         INTO lv_msg.
        ENDIF.
    ENDTRY.
    IF lv_multi_hu_err = abap_true.
      ev_error = abap_true.
      MESSAGE e020(/rb4r/lo_rfid_load) INTO lv_msg.
    ENDIF.

  ENDMETHOD.


  METHOD get_monitor_buffer.

    DATA: ls_excl_prd_dat TYPE /scwm/dlv_query_excl_str,
          ls_read_options TYPE /scwm/dlv_query_contr_str,
          lt_selection    TYPE /scwm/dlv_selection_tab,
          lt_hu_headers   TYPE /scwm/tt_huhdr_int,
          lt_hustat       TYPE /scwm/tt_hustatus,
          lv_loaded       TYPE int4,
          ls_load         TYPE /rb4r/lo_load_r.

*-Store Error message for update.
    IF ms_hdline-message IS NOT INITIAL.
      DATA(lv_msg) = ms_hdline-message.
    ENDIF.

*-Header line table
    SELECT SINGLE
      lgnum,
      gate,
      freightorder,
      currentcount AS current_count,
      totalcount   AS total_count,
      loadtruck,
      message,
      carrier,
      carriername AS carrier_name,
      licenseplate
      FROM /rb4r/lo_i_rfidheaderlinebasic
      INTO @DATA(ls_hdline)
      WHERE lgnum = @ms_output_data-warehouseno
      AND gate = @ms_output_data-gate.
    IF sy-subrc IS NOT INITIAL OR ls_hdline-freightorder IS INITIAL.

*-If loading not started in RFID, Unloading of HU not possible.
      IF ms_output_data-direction = mc_dir_out.
        MESSAGE e016(/rb4r/lo_rfid_load) INTO lv_msg.
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ev_read_error = abap_true.
        RETURN.
      ENDIF.

      ms_hdline =  VALUE #( lgnum         = ms_output_data-warehouseno
                            gate          = ms_output_data-gate
                            freightorder  = ms_output_data-freightorder
                            carrier       = mv_carrier
                            carrier_name  = read_carrier_name( )
                            license_plate = read_license_plate( ) ).
      DATA(lv_first_read) = abap_true.
    ELSE.
      ms_hdline = CORRESPONDING #( ls_hdline EXCEPT message ).
      IF ms_hdline-total_count IS INITIAL
      AND ms_output_data-direction = mc_dir_in. "Loading.
        lv_first_read = abap_true.
      ENDIF.

      IF  mv_wrong_hu = abap_true
      AND ms_output_data-direction = mc_dir_in. "Loading.
*-Wrong HU & FO
        read_hu_ext_number( EXPORTING it_hunumbers = VALUE #( ( hu_exid = ms_output_data-handlingunit ) )
                            IMPORTING et_huheader  = DATA(lt_huheader_erp) ).
        IF lt_huheader_erp IS NOT INITIAL.
          DATA(lv_erp_hu) = lt_huheader_erp[ 1 ]-ext_id_hu_2.
        ENDIF.

        MESSAGE e012(/rb4r/lo_rfid_load) WITH ls_hdline-freightorder INTO lv_msg.
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ev_read_error = abap_true.
        ms_error_hu = VALUE #( lgnum        = ms_output_data-warehouseno
                               gate         = ms_output_data-gate
                               hunumber     = ms_output_data-handlingunit
                               hunumber_ext = COND #( WHEN lv_erp_hu IS NOT INITIAL THEN lv_erp_hu
                                                      ELSE ms_output_data-handlingunit )
                               status       = 'R' "Remove HU
                               ecomment     = lv_msg ).
      ENDIF.
    ENDIF.

*-Update Load direction
    ms_hdline-loadtruck = COND #( WHEN ms_output_data-direction = mc_dir_in THEN abap_true
                                  ELSE abap_false ).

*-Update error message.
    IF lv_msg IS NOT INITIAL.
      ms_hdline-message = lv_msg.
      RETURN.
    ENDIF.

*-Read HU list from DB
    IF lv_first_read = abap_true.

      lt_selection = VALUE #( option    = wmegc_option_eq
                            ( fieldname = /scwm/if_dl_logfname_c=>sc_whno_i
                              low       = ms_output_data-warehouseno )
                            ( fieldname = /scdl/if_dl_logfname_c=>sc_refdocno_frd_h
                              low       = |{ ms_output_data-freightorder ALPHA = IN }| )
                            ( fieldname = /scwm/if_dl_logfname_c=>sc_locationno_lp_i
                              low       = mv_lopt )
                            ( fieldname = /scdl/if_dl_logfname_c=>sc_status_value_dbo_i
                              low       = /scdl/if_dl_status_c=>sc_v_false ) ).

      CLEAR ls_excl_prd_dat WITH abap_true.
      ls_excl_prd_dat-hu_data     = ''.
      ls_excl_prd_dat-hu_prd_data = ''.
      ls_read_options-data_retrival_only      = 'X'.
      ls_read_options-mix_in_object_instances = 'Y'. "DB Fetch

      TEST-SEAM hu_query.
        TRY.
            /scwm/cl_dlv_management_prd=>get_instance( )->query(
                          EXPORTING
                            it_selection    = lt_selection
                            iv_doccat       = wmegc_doccat_pdo "'PDO'
                            is_read_options = ls_read_options
                            is_exclude_data = ls_excl_prd_dat
                          IMPORTING
                            et_hu_headers   = lt_hu_headers ).
          CATCH /scdl/cx_delivery. " Exception Class of Delivery
            ev_read_error = abap_true.
        ENDTRY.
      END-TEST-SEAM.

*-Raise Error message if HU not found.
      IF lt_hu_headers IS INITIAL .
        MESSAGE e007(/rb4r/lo_rfid_load) WITH ms_output_data-freightorder INTO lv_msg.
        add_message( CHANGING ct_bapiret = et_bapiret ).
        ms_hdline-message = lv_msg.
        ev_read_error = abap_true.
        RETURN.
      ENDIF.

*-Load status
      DELETE lt_hu_headers WHERE top IS INITIAL.
      DATA(lt_huhdr) = CORRESPONDING /scwm/tt_huhdr_int( lt_hu_headers MAPPING guid_hu = guid_hu huident = huident ).

      CALL FUNCTION '/SCWM/HU_STATUS_SELECT'
        EXPORTING
          iv_stat   = wmegc_hustat_loaded
          it_huhdr  = lt_huhdr
        IMPORTING
          et_hustat = lt_hustat.

      read_hu_ext_number( EXPORTING it_hunumbers = CORRESPONDING #( lt_hu_headers MAPPING hu_exid = huident )
                          IMPORTING et_huheader  = lt_huheader_erp ).

      LOOP AT lt_hu_headers INTO DATA(ls_huhdr).
        CLEAR: ls_load, lv_erp_hu.
        lv_erp_hu                = VALUE #( lt_huheader_erp[ hu_exid = ls_huhdr-huident ]-ext_id_hu_2 OPTIONAL ).
        ls_load-freightorder     = ms_output_data-freightorder.
        ls_load-handlingunit     = ls_huhdr-huident.
        ls_load-handlingunit_ext = COND #( WHEN lv_erp_hu IS NOT INITIAL THEN lv_erp_hu ELSE ls_huhdr-huident ).
        IF line_exists( lt_hustat[ objnr = ls_huhdr-guid_hu inact = abap_false ] ).
          lv_loaded += 1.
          ls_load-is_scanned = '+'.  "Already Loaded HUs
        ENDIF.
        APPEND ls_load TO mt_load.
      ENDLOOP.

      ms_hdline-current_count = lv_loaded.
      ms_hdline-total_count   = lines( mt_load ).

    ELSEIF ms_output_data-direction = mc_dir_in. "Loading; Not first time scan
      read_hu_ext_number( EXPORTING it_hunumbers = VALUE #( ( hu_exid = ms_output_data-handlingunit ) )
                          IMPORTING et_huheader  = lt_huheader_erp ).

      CLEAR:lv_erp_hu.
      IF lt_huheader_erp IS NOT INITIAL.
        lv_erp_hu = lt_huheader_erp[ 1 ]-ext_id_hu_2.
      ENDIF.

      mt_load = VALUE #( ( freightorder     = ms_output_data-freightorder
                           handlingunit     = ms_output_data-handlingunit
                           handlingunit_ext = COND #( WHEN lv_erp_hu IS NOT INITIAL THEN lv_erp_hu
                                                      ELSE ms_output_data-handlingunit ) ) ).
    ENDIF.

*-Check whether Unloading for Error HU
    IF ms_output_data-direction = mc_dir_out.

      SELECT SINGLE
             lgnum,
             gate,
             hunumber
        FROM /rb4r/lo_i_rfiderrorbasic
        INTO CORRESPONDING FIELDS OF @ms_error_hu
        WHERE  lgnum = @ms_output_data-warehouseno
        AND     gate = @ms_output_data-gate
        AND hunumber = @ms_output_data-handlingunit.

      IF sy-subrc <> 0.
        CLEAR ms_error_hu.
      ENDIF.
    ENDIF.

  ENDMETHOD.


  METHOD is_gate_valid_for_rfid_load.

    CHECK NOT ( iv_lgnum IS INITIAL OR iv_gate IS INITIAL ).

    SELECT SINGLE * FROM /rb4r/lo_i_rfidgatebasic
      WHERE lgnum =  @iv_lgnum AND gate = @iv_gate
      INTO @DATA(ls_gate).

    IF sy-subrc IS INITIAL AND ls_gate-rfidgate IS NOT INITIAL.
      rv_valid_gate = abap_true.
    ENDIF.

  ENDMETHOD.


  METHOD load_hu.

    CLEAR: ev_error, et_bapiret, es_output, ev_load_completed, ev_wrong_hu_exists, ev_fo_not_released.

    clear_buffer( ).

    DATA(ls_data) = is_data.
*-Determine internal HU number
    determine_hu_data( EXPORTING iv_hu_number = ls_data-handlingunit
                                 iv_lgnum     = ls_data-warehouseno
                       IMPORTING ev_hu_number = ls_data-handlingunit
                                 ev_error     = ev_error ).
    IF ev_error = abap_true.
      add_message( CHANGING ct_bapiret = et_bapiret ).
      RETURN.
    ENDIF.

    ms_output_data = CORRESPONDING #( ls_data EXCEPT gate freightorder ).

*-Validate Input data
    validatate_data( EXPORTING is_data            = ls_data
                     IMPORTING ev_error           = ev_error
                               et_bapiret         = et_bapiret
                               ev_fo_not_released = ev_fo_not_released ).
    CHECK ms_output_data-gate IS NOT INITIAL.

*-Get buffer data to update Load monitor
    get_monitor_buffer( IMPORTING ev_read_error = DATA(lv_read_error)
                                  et_bapiret    = DATA(lt_bapiret) ).
    IF lv_read_error = abap_true.
      ev_error = abap_true.
      APPEND LINES OF lt_bapiret TO et_bapiret.
    ENDIF.

*-Set Loading in EWM
    IF ev_error = abap_false.
      TEST-SEAM load_hu.
        update_loading_status( EXPORTING is_data    = ls_data
                               IMPORTING ev_error   = ev_error
                                         et_bapiret = et_bapiret ).
      END-TEST-SEAM.
    ENDIF.

*-Update Load monitor buffer table
    IF ev_error = abap_true.
      CLEAR: mt_load.
    ENDIF.
    TEST-SEAM load_buf_upd.
      update_monitor_buffer( ).
    END-TEST-SEAM.

*-Trigger PGI and clear buffer table.
    CHECK ev_error = abap_false.
    IF ms_hdline-current_count >=  ms_hdline-total_count.

*-Check No Error HUs exists in Truck / Gate
      IF check_error_hu_exists( ) = abap_false.
        TEST-SEAM load_pgi.
          set_pgi_and_clear_buffer( IMPORTING ev_error   = ev_error
                                              et_bapiret = et_bapiret ).
        END-TEST-SEAM.
        IF ms_hdline-current_count = ms_hdline-total_count AND ev_error IS INITIAL.
*-display message in Load Monitor "All Hus are loaded, PGI in progress".
          ev_load_completed = abap_true.
        ENDIF.
      ELSE.
*-display message in load monitor "All Hus are loaded, but wrong Hus in trach, please unload"
*        ev_wrong_hu_exists = abap_true.  "Commended for future reference

      ENDIF.
    ENDIF.
    es_output = ms_output_data.

  ENDMETHOD.


  METHOD push_frond_end.

    DATA: lv_message TYPE string.

*-Get Gate & Warehouse number
    IF iv_lgnum IS NOT INITIAL OR iv_gate IS NOT INITIAL.
      DATA(lv_lgnum) = iv_lgnum.
      DATA(lv_gate) =  iv_gate.

    ELSEIF ms_hdline IS NOT INITIAL. "From API Buffer
      lv_lgnum = ms_hdline-lgnum.
      lv_gate = ms_hdline-gate.

    ELSE.
      RETURN.
    ENDIF.

*-Set Message time
    DATA(lv_msg_time) = COND #( WHEN iv_msg_time IS NOT INITIAL THEN iv_msg_time
                                ELSE 120 ). "Set defualt timing to disappear message = 120 secs (BBMDIF-43043)
    DATA(lv_specific_time) = lv_msg_time * 1000. "Convert Seconds to Milliseconds for UI5

*-Prepare Message
    lv_message = '{ "GATE": "' && lv_gate &&
                   '", "WarehouseNo": "'  && lv_lgnum &&
                   '", "NEWDATAAVAILABLE": "X", "HULOADEDSUCCESS": "' && iv_load_completed &&
                   '", "HULOADEDWRONGHU": "' && iv_wrong_hu_exists &&
                   '", "FONOTRELEASED": "' && iv_fo_not_released &&
                   '", "SPECIFICTIMEMSG": "' && lv_specific_time &&
                   '", "DELAYLOADINNGNEWDATA": "' && iv_delay_refresh &&
                   '", "RELEASELOADINGFO": "' && iv_load_info_disp && '" }'.

*-Push message to Front-end
    DATA(lo_rfid_apc) = NEW /rb4r/cl_lo_apc_wsp_ext_rfid_l( ).

    lo_rfid_apc->send_message(
      EXPORTING
        iv_amc_application_id = mc_amc_application
        iv_amc_channel_id     = mc_amc_channel_id
        iv_message            = lv_message
      IMPORTING
        es_message            = DATA(ls_msg) ).

  ENDMETHOD.


  METHOD read_carrier_name.

    DATA: lv_addr   TYPE ad_addrnum.

    DATA(lv_carrier) = COND #( WHEN iv_carrier IS NOT INITIAL THEN iv_carrier
                               ELSE mv_carrier ).

    CHECK lv_carrier IS NOT INITIAL.
*-Get Carrier address number
    TEST-SEAM bp_fetch.
      CALL FUNCTION 'BUPA_ADDRESS_GET_NUMBERS'
        EXPORTING
          iv_partner                = lv_carrier
          iv_valdt_of_standard_addr = sy-datlo
        IMPORTING
          ev_addrnumber             = lv_addr.
    END-TEST-SEAM.

*-Read Carrier
    SELECT SINGLE businesspartnername1
      FROM i_address
      WITH PRIVILEGED ACCESS
      WHERE addressid = @lv_addr
      INTO @rv_carrier_name.
    IF sy-subrc <> 0.
      CLEAR rv_carrier_name.
    ENDIF.

  ENDMETHOD.


