  " ---------------------------------------------------------------------
  METHOD cancel_delivery.
    " --Local Data Declaration
    DATA ls_header_data    TYPE bapiobdlvhdrchg.
    DATA ls_header_control TYPE bapiobdlvhdrctrlchg.
    DATA lt_item_data      TYPE STANDARD TABLE OF bapiobdlvitemchg.
    DATA lt_item_control   TYPE STANDARD TABLE OF bapiobdlvitemctrlchg.
    DATA lt_return         TYPE STANDARD TABLE OF bapiret2.

    DATA(lo_data_extractor) = NEW /rb1m/cl_sd_chadela_data_pro( ).
    DATA(lo_process)        = NEW /rb1m/cl_sd_chadela_process( ).

    DATA(ls_key) = VALUE #( keys[ 1 ] OPTIONAL ).

    " --Read data for action result
    READ ENTITIES OF /rb1m/sd_c_delivery_change_ewm IN LOCAL MODE
         ENTITY /rb1m/sd_c_delivery_change_ewm
         ALL FIELDS WITH
         CORRESPONDING #( keys )
         RESULT DATA(lt_data).

    result = VALUE #( FOR ls_data IN lt_data ( %tky   = ls_data-%tky
                                               %param = ls_data ) ).

    "-- Get All the items
    lo_data_extractor->read_delivery_details(
      EXPORTING it_range_delivery = VALUE #( ( sign   = /rb1m/if_sd_chadela_constant=>gc_sign_i
                                               option = /rb1m/if_sd_chadela_constant=>gc_option_eq
                                               low    = ls_key-delivery ) )
      IMPORTING et_delivery_data  = DATA(lt_delivery_data) ).

    lo_data_extractor->read_delivery_header(
                            EXPORTING iv_delivery        = ls_key-delivery
                            IMPORTING es_delivery_header = DATA(ls_del_header) ).

    lo_data_extractor->read_delivery_item(
                            EXPORTING iv_delivery      = ls_key-delivery
                                      iv_delivery_item = ls_key-deliveryitem
                            IMPORTING es_delivery_item = DATA(ls_del_item) ).

    "-- EWM Query Method
    lo_data_extractor->query(
      EXPORTING iv_delivery     = ls_key-delivery
      IMPORTING ev_warehouse_no = DATA(lv_warehouse_no)
                et_header       = DATA(lt_header)
                et_items        = DATA(lt_items) ).

**********************************************************************
*              QM Concession / Delivery Block Validations            *
**********************************************************************
    "-- Reading Quantity from EWM
    LOOP AT lt_items ASSIGNING FIELD-SYMBOL(<ls_item>).
      IF line_exists( <ls_item>-refdoc[ refdoccat = /rb1m/if_sd_chadela_constant=>gc_ref_doc_erp
                                        refdocno  = ls_key-delivery
                                        refitemno = ls_key-deliveryitem ] ).

        DATA(ls_item) = <ls_item>.
        EXIT.
      ENDIF.
    ENDLOOP.
    UNASSIGN <ls_item>.

    DATA(ls_delivery) = VALUE #( lt_data[ 1 ] OPTIONAL ).

    DATA(lv_difference_qty) =  CONV lfimg( 0 - ls_item-qty-qty ).
**********************************************************************
    "-- QM Concession Validation
**********************************************************************
    DATA(lo_operation) = NEW /rb4r/cl_qm_conces_operations( ).
    lo_operation->check_for_block(
      EXPORTING
        iv_matnr     = ls_delivery-material
        iv_plant     = ls_delivery-plant
        iv_kunnr     = ls_del_header-shiptoparty
        iv_lifnr     = ls_del_header-supplier
        iv_quan      = lv_difference_qty
        iv_uom       = ls_item-qty-uom
        iv_mon_type  = /rb1m/if_sd_chadela_constant=>gc_con_mon_type_ycsd
        iv_doc_type  = ls_delivery-deliverytype
        iv_call_from = /rb1m/if_sd_chadela_constant=>gc_chadela
        iv_date      = sy-datum
        iv_lock      = abap_true
      IMPORTING
        et_return    = lt_return
        et_qm_conc   = DATA(lt_qm_conc) ).
    IF line_exists( lt_return[ type = /rb1m/if_sd_chadela_constant=>gc_error ] ).
      APPEND VALUE #( %cid         = ls_key-%cid_ref
                      delivery     = ls_key-delivery
                      deliveryitem = ls_key-deliveryitem
                      %update      = if_abap_behv=>auth-unauthorized
                    ) TO failed-/rb1m/sd_c_delivery_change_ewm.

      DATA(ls_return) = VALUE #( lt_return[ 1 ] OPTIONAL ).

      APPEND VALUE #( %cid         = ls_key-%cid_ref
                      delivery     = ls_key-delivery
                      deliveryitem = ls_key-deliveryitem
                      %msg         = new_message( id       = ls_return-id
                                                  number   = ls_return-number
                                                  severity = if_abap_behv_message=>severity-error
                                                  v1       = ls_return-message_v1
                                                  v2       = ls_return-message_v2
                                                  v3       = ls_return-message_v3
                                                  v4       = ls_return-message_v4 )
                      %update      = if_abap_behv=>auth-unauthorized
                   ) TO reported-/rb1m/sd_c_delivery_change_ewm.
      RETURN.

    ENDIF.
**********************************************************************
    "-- Delivery Block Validation
**********************************************************************
    DATA(lo_db_monitor)  = NEW /rb4r/cl_qm_db_monitor( ).

    lo_db_monitor->db_check_for_block(
        EXPORTING
            iv_matnr     = ls_delivery-material
            iv_plant     = ls_delivery-plant
            iv_kunnr     = ls_delivery-shiptoparty
            iv_partner   = COND parvw( WHEN ls_delivery-shiptoparty EQ ''
                                          THEN ''
                                        ELSE /rb1m/if_sd_chadela_constant=>gc_sh )
            iv_kunag     = ls_del_header-soldtoparty
            iv_partner_g = COND parvw( WHEN ls_del_header-soldtoparty EQ ''
                                          THEN ''
                                        ELSE /rb1m/if_sd_chadela_constant=>gc_sp )
            iv_batch     = ls_del_item-batch
            iv_quan      = lv_difference_qty
            iv_uom       = ls_item-qty-uom
            iv_doc_type  = ls_delivery-deliverytype
            iv_call_from = /rb1m/if_sd_chadela_constant=>gc_chadela
            iv_date      = sy-datum
          IMPORTING
            et_return    = lt_return
            ev_block     = DATA(lv_block) ).
    IF line_exists( lt_return[ type = /rb1m/if_sd_chadela_constant=>gc_error ] ).
      APPEND VALUE #( %cid         = ls_key-%cid_ref
                      delivery     = ls_key-delivery
                      deliveryitem = ls_key-deliveryitem
                      %update      = if_abap_behv=>auth-unauthorized
                    ) TO failed-/rb1m/sd_c_delivery_change_ewm.

      ls_return = VALUE #( lt_return[ 1 ] OPTIONAL ).

      APPEND VALUE #( %cid         = ls_key-%cid_ref
                      delivery     = ls_key-delivery
                      deliveryitem = ls_key-deliveryitem
                      %msg         = new_message( id       = ls_return-id
                                                  number   = ls_return-number
                                                  severity = if_abap_behv_message=>severity-error
                                                  v1       = ls_return-message_v1
                                                  v2       = ls_return-message_v2
                                                  v3       = ls_return-message_v3
                                                  v4       = ls_return-message_v4 )
                      %update      = if_abap_behv=>auth-unauthorized
                   ) TO reported-/rb1m/sd_c_delivery_change_ewm.
      RETURN.

    ENDIF.
**********************************************************************

    "-- Check the Picking Status of all the items.
    LOOP AT lt_delivery_data ASSIGNING FIELD-SYMBOL(<ls_del>).
      DATA(lv_picking_status) = lo_process->get_picking_status( iv_delivery      = <ls_del>-delivery
                                                                iv_delivery_item = <ls_del>-deliveryitem
                                                                it_items         = lt_items ).
      IF lv_picking_status <> 1.
        EXIT.
      ELSE.
        " --Fill Delivery Item Quantity to 0.
        APPEND VALUE #( deliv_numb = <ls_del>-delivery
                        deliv_item = <ls_del>-deliveryitem
                        dlv_qty    = 0 )
               TO lt_item_data[].

        APPEND VALUE #( deliv_numb = <ls_del>-delivery
                        deliv_item = <ls_del>-deliveryitem
                        chg_delqty = abap_true )
               TO lt_item_control[].
      ENDIF.
    ENDLOOP.

    IF lv_picking_status = 1.
      "-- Check the Open WH Task of all the items.
      LOOP AT lt_items ASSIGNING <ls_item>.
        "--Reading Warehouse Task
        lo_data_extractor->read_warehouse_task(
                EXPORTING iv_warehouse_number = lv_warehouse_no
                          iv_docid            = <ls_item>-docid
                          iv_itemid           = <ls_item>-itemid
                IMPORTING et_wt_open          = DATA(lt_wt_open) ).
        IF lt_wt_open IS NOT INITIAL.
          DATA(lv_wh_task_exists) = abap_true.
          EXIT.
        ENDIF.
        CLEAR: lt_wt_open.
      ENDLOOP.

      IF lv_wh_task_exists IS INITIAL.

        ls_header_data-deliv_numb    = ls_key-delivery.
        ls_header_control-deliv_numb = ls_key-delivery.
        CLEAR lt_return.
        " ---------------------------------------------------------------------
        " C A L L   B A P I                           -
        " ---------------------------------------------------------------------
        CALL FUNCTION 'RFC_CALLBACK_REJECTED'.
        CALL FUNCTION '/RB1M/SD_CALL_BAPI_DEL_CHANGE' DESTINATION 'NONE'
          EXPORTING
            is_header_data    = ls_header_data
            is_header_control = ls_header_control
            iv_delivery       = ls_key-delivery
          TABLES
            it_item_data      = lt_item_data
            it_item_control   = lt_item_control
            et_return         = lt_return.
        IF line_exists( lt_return[ type = /rb1m/if_sd_chadela_constant=>gc_error ] ).
          LOOP AT lt_return ASSIGNING FIELD-SYMBOL(<ls_return>).
            APPEND VALUE #( %cid         = ls_key-%cid_ref
                            delivery     = ls_key-delivery
                            deliveryitem = ls_key-deliveryitem
                            %update      = if_abap_behv=>auth-unauthorized )
                   TO failed-/rb1m/sd_c_delivery_change_ewm.

            APPEND VALUE #( %cid         = ls_key-%cid_ref
                            delivery     = ls_key-delivery
                            deliveryitem = ls_key-deliveryitem
                            %msg         = new_message( id       = <ls_return>-id
                                                        number   = <ls_return>-number
                                                        v1       = <ls_return>-message_v1
                                                        v2       = <ls_return>-message_v2
                                                        v3       = <ls_return>-message_v3
                                                        v4       = <ls_return>-message_v4
                                                        severity = if_abap_behv_message=>severity-error )
                            %update      = if_abap_behv=>auth-unauthorized )
                   TO reported-/rb1m/sd_c_delivery_change_ewm.
          ENDLOOP.
        ELSE. " --Success
          APPEND VALUE #( %cid         = ls_key-%cid_ref
                          delivery     = ls_key-delivery
                          deliveryitem = ls_key-deliveryitem
                          %msg         = new_message( id       = /rb1m/if_sd_chadela_constant=>gc_message_id
                                                      number   = 006
                                                      severity = if_abap_behv_message=>severity-success )
                          %update      = if_abap_behv=>auth-allowed )
                 TO reported-/rb1m/sd_c_delivery_change_ewm.
        ENDIF.
      ELSE. "-- Open WH Task Exist check
        APPEND VALUE #( %cid         = ls_key-%cid_ref
                        delivery     = ls_key-delivery
                        deliveryitem = ls_key-deliveryitem
                        %update      = if_abap_behv=>auth-unauthorized )
               TO failed-/rb1m/sd_c_delivery_change_ewm.

        APPEND VALUE #( %cid         = ls_key-%cid_ref
                        delivery     = ls_key-delivery
                        deliveryitem = ls_key-deliveryitem
                        %msg         = new_message( id       = /rb1m/if_sd_chadela_constant=>gc_message_id
                                                    number   = 005
                                                    severity = if_abap_behv_message=>severity-error )
                        %update      = if_abap_behv=>auth-unauthorized )
               TO reported-/rb1m/sd_c_delivery_change_ewm.

      ENDIF.
    ELSE. "-- Picking Status Check
      APPEND VALUE #( %cid         = ls_key-%cid_ref
                      delivery     = ls_key-delivery
                      deliveryitem = ls_key-deliveryitem
                      %update      = if_abap_behv=>auth-unauthorized )
             TO failed-/rb1m/sd_c_delivery_change_ewm.

      APPEND VALUE #( %cid         = ls_key-%cid_ref
                      delivery     = ls_key-delivery
                      deliveryitem = ls_key-deliveryitem
                      %msg         = new_message( id       = /rb1m/if_sd_chadela_constant=>gc_message_id
                                                  number   = 005
                                                  severity = if_abap_behv_message=>severity-error )
                      %update      = if_abap_behv=>auth-unauthorized )
             TO reported-/rb1m/sd_c_delivery_change_ewm.

    ENDIF.
  ENDMETHOD.
