    get_selection_screen_data( EXPORTING it_filter_condition    = it_filter_condition
                               IMPORTING et_range_delivery      = DATA(lt_range_delivery)
                                         et_range_deliveryitem  = DATA(lt_range_deliveryitem)
                                         et_range_textname      = DATA(lt_range_textname)
                                         et_range_textappobject = DATA(lt_range_textappobject)
                                         et_range_textid        = DATA(lt_range_textid)
                                         et_range_language      = DATA(lt_range_language) ).

    " --When user click on navigation from List Page->Report Page:
    IF lines( it_filter_condition ) = 2.
      APPEND VALUE #( sign   = /rb1m/if_sd_chadela_constant=>gc_sign_i
                      option = /rb1m/if_sd_chadela_constant=>gc_option_eq
                      low    = VALUE #( lt_range_delivery[ 1 ]-low OPTIONAL ) )
             TO lt_range_textname[].
    ENDIF.

    get_delivery_text( EXPORTING iv_delivery            = VALUE #( lt_range_delivery[ 1 ]-low OPTIONAL )
                                 iv_delivery_item       = VALUE #( lt_range_deliveryitem[ 1 ]-low OPTIONAL )
                                 it_range_textname      = lt_range_textname
                                 it_range_textappobject = lt_range_textappobject
                                 it_range_textid        = lt_range_textid
                                 it_range_language      = lt_range_language
                       IMPORTING et_delivery_text       = et_final_output ).
  ENDMETHOD.


  METHOD update_ewm_tm_status.

*-Read Inco1 text
    SELECT incotermsclassification, incotermsclassificationname
      FROM i_incotermsclassificationtext
      WHERE language = @sy-langu
      INTO TABLE @DATA(lt_inco).
    IF sy-subrc IS NOT INITIAL.
      CLEAR: lt_inco.
    ENDIF.

    LOOP AT ct_output ASSIGNING FIELD-SYMBOL(<ls_output>).
      mo_data_process->get_ewm_tm_status(
        EXPORTING
          iv_delivery             =  <ls_output>-delivery            " Delivery
          iv_delivery_item        =  <ls_output>-deliveryitem        " Delivery Item
        IMPORTING
          ev_warehousetask_exists =  DATA(lv_warehousetask_exists)   " General Flag
          ev_pickingstatus        =  DATA(lv_pickingstatus)          " Status Value
          es_root_node            =  DATA(ls_root_node)              " Root Node
          es_item                 =  DATA(ls_item) ).                " Delivery Item (PRD) for Read Operations

      "--Inco1 text
      <ls_output>-incotermsclassificationname = VALUE #( lt_inco[ incotermsclassification = <ls_output>-inco1
                                                                   ]-incotermsclassificationname OPTIONAL ).

      "--Updating EWM Quantity & UOM
      IF <ls_output>-distributionstatus NE ' '.
        <ls_output>-quantity  = ls_item-qty-qty.
        <ls_output>-salesunit = ls_item-qty-uom.
      ENDIF.

      "--Only EWM deliveries will be changed in the Application.
      "--for ERP Delivery, Restrict the user with the message.
      IF <ls_output>-distributionstatus IS INITIAL.
        <ls_output>-delcriticality = 1.
        <ls_output>-message        = TEXT-005.
        CONTINUE.
      ENDIF.

      IF <ls_output>-delcriticality <> 1.
        "--Check if Warehouse Task is exist
        IF lv_warehousetask_exists IS NOT INITIAL.
          <ls_output>-delcriticality = 2.
          <ls_output>-message        = TEXT-001.
        ENDIF.

        "--Check Picking Status
        IF lv_pickingstatus IS NOT INITIAL AND lv_pickingstatus NE 1.
          IF lv_pickingstatus EQ 2.
            <ls_output>-delcriticality = 3.
            MESSAGE ID '/RB1M/SD_DEL_CHANGE' TYPE 'I' NUMBER 008 INTO <ls_output>-message.
          ELSE.
            <ls_output>-delcriticality = 2.
            MESSAGE ID '/RB1M/SD_DEL_CHANGE' TYPE 'I' NUMBER 001 INTO <ls_output>-message.
          ENDIF.
        ENDIF.

        "--Check if Freight Unit is assigned to consignment Order
        IF ls_root_node-plan_status_root = 02 OR ls_root_node-plan_status_root = 03.
          <ls_output>-delcriticality = 2.
          <ls_output>-message        = TEXT-002.
        ENDIF.

        "--Check if Goods Issue posted (EWM/TM)
        IF ls_root_node-dlv_goods_mvmnt =  /rb1m/if_sd_chadela_constant=>gc_dlv_goods_mvmnt_c.
          <ls_output>-delcriticality = 2.
          <ls_output>-message        = TEXT-003.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.


  METHOD get_delivery_text.
    CLEAR et_delivery_text.
    SELECT a~textobjectkey,
           a~textobjecttype,
           a~textobjectcategory,
           a~language,
           b~textobjecttypename
      FROM i_textobject AS a
      LEFT OUTER JOIN i_textobjecttypetext AS b
      ON  a~textobjectcategory = b~textobjectcategory
      AND a~textobjecttype     = b~textobjecttype
      AND b~language           = @sy-langu
      WHERE a~textobjectkey      IN @it_range_textname
        AND a~textobjecttype     IN @it_range_textid
        AND a~textobjectcategory = @/rb1m/if_sd_chadela_constant=>gc_textobjectcategory_vbbk
        AND a~language           IN @it_range_language
      ORDER BY a~textobjecttype
      INTO TABLE @DATA(lt_textobject).
    IF sy-subrc IS NOT INITIAL.
      CLEAR lt_textobject.
    ENDIF.

    LOOP AT lt_textobject ASSIGNING FIELD-SYMBOL(<ls_textobject>).
      APPEND INITIAL LINE TO et_delivery_text ASSIGNING FIELD-SYMBOL(<ls_text>).
      <ls_text>-delivery      = iv_delivery.
      <ls_text>-deliveryitem  = iv_delivery_item.
      <ls_text>-textname      = <ls_textobject>-textobjectkey.
      <ls_text>-textappobject = <ls_textobject>-textobjectcategory.
      <ls_text>-textid        = <ls_textobject>-textobjecttype.
      <ls_text>-tdtext        = <ls_textobject>-textobjecttypename.
      <ls_text>-language      = <ls_textobject>-language.
      <ls_text>-text          = read_text( iv_id       = <ls_textobject>-textobjecttype
                                           iv_language = <ls_textobject>-language
                                           iv_name     = <ls_textobject>-textobjectkey
                                           iv_object   = <ls_textobject>-textobjectcategory ).
    ENDLOOP.
  ENDMETHOD.


  METHOD get_selection_screen_data.
    " --Initializing exporting parameters.
    CLEAR: et_range_delivery,
           et_range_deliveryitem,
           et_range_textappobject,
           et_range_textid,
           et_range_textname,
           et_range_language.

    LOOP AT it_filter_condition ASSIGNING FIELD-SYMBOL(<fs_filter>).
      CASE <fs_filter>-name.
        WHEN 'DELIVERY'.
          et_range_delivery = VALUE #( FOR ls_range IN <fs_filter>-range
                                       ( sign   = ls_range-sign
                                         option = ls_range-option
                                         low    = ls_range-low
                                         high   = ls_range-high ) ).
        WHEN 'DELIVERYITEM'.
          et_range_deliveryitem = VALUE #( FOR ls_range IN <fs_filter>-range
                                           ( sign   = ls_range-sign
                                             option = ls_range-option
                                             low    = ls_range-low
                                             high   = ls_range-high ) ).

        WHEN 'TEXTNAME'.
          et_range_textname = VALUE #( FOR ls_range IN <fs_filter>-range
                                       ( sign   = ls_range-sign
                                         option = ls_range-option
                                         low    = ls_range-low
                                         high   = ls_range-high ) ).
        WHEN 'TEXTAPPOBJECT'.
          et_range_textappobject = VALUE #( FOR ls_range IN <fs_filter>-range
                                            ( sign   = ls_range-sign
                                              option = ls_range-option
                                              low    = ls_range-low
                                              high   = ls_range-high ) ).
        WHEN 'TEXTID'.
          et_range_textid = VALUE #( FOR ls_range IN <fs_filter>-range
                                     ( sign   = ls_range-sign
                                       option = ls_range-option
                                       low    = ls_range-low
                                       high   = ls_range-high ) ).
        WHEN 'LANGUAGE'.
          et_range_language = VALUE #( FOR ls_range IN <fs_filter>-range
                                       ( sign   = ls_range-sign
                                         option = ls_range-option
                                         low    = ls_range-low
                                         high   = ls_range-high ) ).
      ENDCASE.
    ENDLOOP.
  ENDMETHOD.


  METHOD get_incoterm_data.

    DATA: lv_shippingpoit TYPE vstel,
          lv_shipto       TYPE kunnr.

    CLEAR : et_incoterm.

    LOOP AT it_filter_condition INTO DATA(ls_filter).
      CASE ls_filter-name.
        WHEN 'SHIPPINGPOINT'.
          lv_shippingpoit = VALUE #( ls_filter-range[ 1 ]-low OPTIONAL ).
        WHEN 'SHIPTOPARTY'.
          lv_shipto = VALUE #( ls_filter-range[ 1 ]-low OPTIONAL ).
        WHEN 'INCO2'.
          DATA(lv_inco2) = VALUE #( ls_filter-range[ 1 ]-low OPTIONAL ).
        WHEN OTHERS.
      ENDCASE.
    ENDLOOP.

*-Fetch inco1 details
    SELECT inco~incotermsclassification,
           inco~locationismandatory,
           inco_t~incotermsclassificationname
           FROM i_incotermsclassification AS inco LEFT OUTER JOIN i_incotermsclassificationtext AS inco_t
           ON inco~incotermsclassification = inco_t~incotermsclassification
          AND inco_t~language = @sy-langu
          INTO TABLE @DATA(lt_inco).
    IF sy-subrc IS NOT INITIAL.
      CLEAR:lt_inco.
    ENDIF.

*-Determine INCO2 from utility class and fill output table
    DATA(lo_inco_utility) = NEW /rb1m/cl_sd_inco_utilities( ).

    et_incoterm = VALUE #( FOR ls_inco IN lt_inco
                           LET lv_inco2_d = lo_inco_utility->get_inco2_value(
                                              iv_inco1  = ls_inco-incotermsclassification
                                              iv_vstel  = lv_shippingpoit
                                              iv_kunnr  = lv_shipto )
                           IN shippingpoint = lv_shippingpoit
                              shiptoparty   = lv_shipto
                            ( inco1         = ls_inco-incotermsclassification
                              locationismandatory = ls_inco-locationismandatory
                              inconame      = ls_inco-incotermsclassificationname
                              inco2         =  COND #( WHEN lv_inco2_d IS NOT INITIAL THEN lv_inco2_d
                                                       ELSE lv_inco2 ) ) ).


  ENDMETHOD.
ENDCLASS.


