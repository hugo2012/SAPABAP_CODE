CLASS /rb1m/cl_sd_del_mass_fld_chngs IMPLEMENTATION.


  METHOD if_rap_query_provider~select.
    " _Local data declearation.
    DATA lt_current_text_output TYPE tt_delivery_text.
    DATA lt_current_del_output  TYPE tt_output.
    DATA lt_inco_output         TYPE tt_incoterm.

    DATA(lv_page_size)        = io_request->get_paging( )->get_page_size( ).
    DATA(lv_offset)           = io_request->get_paging( )->get_offset( ).
    DATA(lt_requested_fields) = io_request->get_requested_elements( ) ##NEEDED.
    DATA(lt_sort_order)       = io_request->get_sort_elements( ).

    TRY.
        DATA(lt_filter_condition) = io_request->get_filter( )->get_as_ranges( ).
        " Essential: Capture the manual input search string
        DATA(lv_search_expression) = io_request->get_search_expression( ).

        IF io_request->is_data_requested( ).
          CASE io_request->get_entity_id( ).
            WHEN '/RB1M/SD_C_DELIVERY_CHANGE_EWM'.
              me->prepare_delivery_data( EXPORTING it_filter_condition = lt_filter_condition
                                         IMPORTING et_final_output     = DATA(lt_delivery) ).

              " --Sorting Implementation: /RB1M/SD_C_DELIVERY_CHANGE_EWM
              IF lt_sort_order IS NOT INITIAL.
                DATA(lt_sort) = VALUE abap_sortorder_tab( FOR ls_sort_order IN lt_sort_order
                                                          ( name       = ls_sort_order-element_name
                                                            descending = ls_sort_order-descending ) ).
                SORT lt_delivery BY (lt_sort).
              ENDIF.

              " --Paging implementation: /RB1M/SD_C_DELIVERY_CHANGE_EWM
              IF lines( lt_delivery ) > 20.
                DATA(lv_start) = lv_offset + 1.
                DATA(lv_end)   = lv_page_size + lv_offset.
                APPEND LINES OF lt_delivery FROM lv_start TO lv_end TO lt_current_del_output.
              ELSE.
                lt_current_del_output = lt_delivery.
              ENDIF.

              io_response->set_total_number_of_records( lines( lt_delivery ) ).
              io_response->set_data( lt_current_del_output ).

            WHEN '/RB1M/SD_C_DELIVERY_TEXT'.
              prepare_delivery_text_data( EXPORTING it_filter_condition = lt_filter_condition
                                          IMPORTING et_final_output     = DATA(lt_delivery_text) ).

              " --Sorting Implementation: /RB1M/SD_C_DELIVERY_CHANGE_EWM
              IF lt_sort_order IS NOT INITIAL.
                lt_sort = VALUE abap_sortorder_tab( FOR ls_sort_order IN lt_sort_order
                                                    ( name       = ls_sort_order-element_name
                                                      descending = ls_sort_order-descending ) ).
                SORT lt_delivery_text BY (lt_sort).
              ENDIF.

              " --Paging implementation: /RB1M/SD_C_DELIVERY_TEXT
              IF lines( lt_delivery_text ) > 20.
                lv_start = lv_offset + 1.
                lv_end   = lv_page_size + lv_offset.
                APPEND LINES OF lt_delivery_text FROM lv_start TO lv_end TO lt_current_text_output.
              ELSE.
                lt_current_text_output = lt_delivery_text.
              ENDIF.

              io_response->set_total_number_of_records( lines( lt_delivery_text ) ).
              io_response->set_data( lt_current_text_output ).

            WHEN '/RB1M/SD_C_INCOTERMVH'.
              get_incoterm_data( EXPORTING it_filter_condition = lt_filter_condition
                                 IMPORTING et_incoterm         = DATA(lt_incoterm) ).
              IF lv_search_expression IS NOT INITIAL.
                " Essential: Capture the manual input search string
                IF strlen( lv_search_expression ) >= 3.
                  LOOP AT lt_filter_condition INTO DATA(ls_filter).
                    CASE ls_filter-name.
                      WHEN 'SHIPPINGPOINT'.
                        DATA(lv_shippingpoit) = VALUE #( ls_filter-range[ 1 ]-low OPTIONAL ).
                      WHEN 'SHIPTOPARTY'.
                        DATA(lv_shipto) = VALUE #( ls_filter-range[ 1 ]-low OPTIONAL ).
                      WHEN OTHERS.
                    ENDCASE.
                  ENDLOOP.
                  SELECT a~*
                   FROM @lt_incoterm AS a
                   WHERE shippingpoint = @lv_shippingpoit
                     AND shiptoparty = @lv_shipto
                     AND inco1 = @lv_search_expression
                     INTO TABLE @DATA(lt_incoterm_1).
                  IF sy-subrc IS INITIAL.
                      lt_incoterm = lt_incoterm_1.
                     " --Paging implementation: /RB1M/SD_C_INCOTERMVH
                      IF lines( lt_incoterm ) > lv_page_size.
                        lv_start = lv_offset + 1.
                        lv_end   = lv_page_size + lv_offset.
                        APPEND LINES OF lt_incoterm FROM lv_start TO lv_end TO lt_inco_output.
                      ELSE.
                        lt_inco_output = lt_incoterm.
                      ENDIF.
                  ENDIF.
                ENDIF.
              ELSE.
                  " --Paging implementation: /RB1M/SD_C_INCOTERMVH
                  IF lines( lt_incoterm ) > lv_page_size.
                    lv_start = lv_offset + 1.
                    lv_end   = lv_page_size + lv_offset.
                    APPEND LINES OF lt_incoterm FROM lv_start TO lv_end TO lt_inco_output.
                  ELSE.
                    lt_inco_output = lt_incoterm.
                  ENDIF.
              ENDIF.

              io_response->set_total_number_of_records( lines( lt_inco_output ) ).
              io_response->set_data( lt_inco_output ).
          ENDCASE.
        ENDIF.
      CATCH cx_root INTO DATA(lv_exception).
        " TODO: variable is assigned but never used (ABAP cleaner)
        DATA(lv_exception_message) = cl_message_helper=>get_latest_t100_exception( lv_exception )->if_message~get_longtext( ).
    ENDTRY.
  ENDMETHOD.


  METHOD read_text.
    " --Local Data Declearation
    DATA lt_lines TYPE tlinet.

    CALL FUNCTION 'READ_TEXT'
      EXPORTING
        id                      = iv_id
        language                = iv_language
        name                    = iv_name
        object                  = iv_object
      TABLES
        lines                   = lt_lines
      EXCEPTIONS
        id                      = 1
        language                = 2
        name                    = 3
        not_found               = 4
        object                  = 5
        reference_check         = 6
        wrong_access_to_archive = 7
        OTHERS                  = 8.
    IF sy-subrc IS INITIAL.
      LOOP AT lt_lines ASSIGNING FIELD-SYMBOL(<ls_line>).
        rv_text = |{ rv_text }| && |{ <ls_line>-tdline }|.
      ENDLOOP.
    ENDIF.
  ENDMETHOD.


  METHOD prepare_delivery_data.
    " --Initializing exporting parameters.
    CLEAR et_final_output.

    get_selection_screen_data( EXPORTING it_filter_condition   = it_filter_condition
                               IMPORTING et_range_delivery     = DATA(lt_range_delivery)
                                         et_range_deliveryitem = DATA(lt_range_deliveryitem) ).

    " --Fetching Delivery details
    mo_data_extractor->read_delivery_details( EXPORTING it_range_delivery     = lt_range_delivery
                                                        it_range_deliveryitem = lt_range_deliveryitem
                                              IMPORTING et_delivery_data      = et_final_output ).

    " --Updating EWM/TM Status
    update_ewm_tm_status( CHANGING ct_output = et_final_output ).
  ENDMETHOD.


