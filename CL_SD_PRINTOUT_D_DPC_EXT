  METHOD consignmentorder_get_entityset.
    TRY.

        CALL METHOD /rb1m/cl_sd_printout_dataprovd=>/rb1m/if_sd_printout_dataprovd~get_shipping_data
          EXPORTING
            iv_co             = 'X'
            it_select_options = it_filter_select_options
          IMPORTING
            et_freightorder   = DATA(lt_freightorder).

        CHECK lt_freightorder IS NOT INITIAL.
        SORT lt_freightorder ASCENDING BY freightorderdocument codocument carrier .
        DELETE ADJACENT DUPLICATES FROM lt_freightorder COMPARING freightorderdocument codocument carrier.

** $inlinecount query option for all count entries.
        IF io_tech_request_context->has_inlinecount( ) = abap_true.
            DESCRIBE TABLE lt_freightorder LINES es_response_context-inlinecount.
             es_response_context-inlinecount =  es_response_context-inlinecount .
            ELSE.
            CLEAR es_response_context-inlinecount.
        ENDIF.
*- For paging i.e. $top and $skip
        /iwbep/cl_mgw_data_util=>paging(
                                    EXPORTING   is_paging = is_paging
                                    CHANGING    ct_data   = lt_freightorder
                                       ).

        et_entityset = VALUE #( BASE et_entityset FOR ls_fo IN lt_freightorder
                                 ( codocument = ls_fo-codocument
                                   freightorderdocument = ls_fo-freightorderdocument
                                   freightorderunit = ls_fo-freightorderunit
                                   deliverydocument = ls_fo-deliverydocument
                                   shiptoparty      = ls_fo-shiptoparty
                                   date             = ls_fo-date
                                   carrier          = ls_fo-carrier
                                   createdby        = ls_fo-createdby
                                  ) ).


      CATCH /iwbep/cx_mgw_busi_exception.
      CATCH /iwbep/cx_mgw_tech_exception.
    ENDTRY.
  ENDMETHOD.


  METHOD languageset_get_entityset.
    DATA: lv_langu_out TYPE char2.
    DATA : lv_text TYPE tdobname.
    DATA : lt_lagu_so10 TYPE /rb1m/cl_sd_printout_d_mpc=>tt_language.

    TRY.

*       Get Text for body of email.
*        lv_text = '/RB1M/SD_PRINTOUT_EMAIL'.
        LOOP AT it_filter_select_options INTO DATA(ls_filter) .
          IF ls_filter-property = 'TextID'.
            lv_text = VALUE #( ls_filter-select_options[ 1 ]-low OPTIONAL ).
          ENDIF.
        ENDLOOP.

        IF lv_text is INITIAL.
           lv_text = '/RB1M/SD_PRINTOUT_EMAIL'.
        ENDIF.

        SELECT *
          FROM /rb1m/sd_i_language
         WHERE sptxt IS NOT INITIAL
         AND  spras EQ @sy-langu
        INTO TABLE @DATA(lt_language).
        IF sy-subrc IS INITIAL.

          et_entityset = CORRESPONDING #( lt_language ).

          CALL FUNCTION 'CONVERSION_EXIT_ISOLA_OUTPUT'
            EXPORTING
              input  = sy-langu
            IMPORTING
              output = lv_langu_out.

          et_entityset[ spras = sy-langu ]-loaddefault = lv_langu_out.

        ENDIF.
        CLEAR lt_language.
        IF lv_text IS NOT INITIAL.
          SELECT a~*
          FROM /rb1m/sd_i_language AS a
           LEFT OUTER JOIN /rb1m/sd_i_text_header AS b
           ON a~spras = b~tdspras
           WHERE sptxt IS NOT INITIAL
            AND  tdname = @lv_text
            AND a~spras NE @sy-langu
          INTO TABLE @lt_language.
          IF sy-subrc IS INITIAL.
            lt_lagu_so10 = CORRESPONDING #( lt_language ).
            APPEND LINES OF  lt_lagu_so10 TO et_entityset.
          ENDIF.
        ENDIF.

      CATCH /iwbep/cx_mgw_busi_exception.
      CATCH /iwbep/cx_mgw_tech_exception.
    ENDTRY.
  ENDMETHOD.


  METHOD /iwbep/if_mgw_appl_srv_runtime~create_deep_entity.

    DATA : lt_deep_entityset TYPE TABLE OF /rb1m/cl_sd_printout_dataprovd=>/rb1m/if_sd_printout_dataprovd~ts_return_data2mail,
           ls_deep           LIKE LINE OF lt_deep_entityset.
    DATA : ls_return TYPE /rb1m/cl_sd_printout_dataprovd=>/rb1m/if_sd_printout_dataprovd~ts_return_data2mail.
    DATA : lo_message_container TYPE REF TO /iwbep/if_message_container.
    DATA : ls_temp TYPE /rb1m/cl_sd_printout_d_mpc_ext=>ts_output.
    DATA : ls_output TYPE /rb1m/sd_i_output.
    DATA : lv_va_jobname  TYPE tbtco-jobname,
           lv_vn_jobcount TYPE tbtco-jobcount.
    DATA : lv_spras TYPE spras.
    TYPES: lty_r_codoc      TYPE RANGE OF /rb1m/cl_sd_printout_d_mpc=>ts_consignmentorder-codocument,
           lty_r_output     TYPE RANGE OF /rb1m/cl_sd_printout_d_mpc=>ts_output-messagetype,
           lty_r_mail       TYPE RANGE OF /rb1m/cl_sd_printout_d_mpc=>ts_email-emailid,
           lty_r_actiontype TYPE RANGE OF /rb1m/cl_sd_printout_d_mpc=>ts_output-actiontype.
    DATA : lr_codoc      TYPE lty_r_codoc,
           lr_fodoc      TYPE lty_r_codoc,
           lr_output     TYPE lty_r_output,
           lr_mailid     TYPE lty_r_mail,
           lr_actiontype TYPE lty_r_actiontype.

    CASE iv_entity_set_name.
      WHEN 'Data2MailRootSet'.

        TRY.
            " Return structure as a deep structure
            io_data_provider->read_entry_data(
              IMPORTING
                es_data = ls_return
            ).

*<<<     Write logic here to process for submit program


            CHECK ls_return IS NOT INITIAL.
            IF ls_return-root2fonav IS NOT INITIAL.
              " The FO Documents
              lr_fodoc =  VALUE #(   FOR ls_fo2fonav IN ls_return-root2fonav
                                     ( sign = 'I'
                                       option = 'EQ'
                                       low = ls_fo2fonav-freightorderdocument
                                      )
                                   ).
              SORT lr_fodoc BY low.
              DELETE ADJACENT DUPLICATES FROM lr_fodoc COMPARING low.
            ENDIF.

*          Language for Email Title Translation...
            IF ls_return-language IS NOT INITIAL.
              CLEAR lv_spras.
              CALL FUNCTION 'CONVERSION_EXIT_ISOLA_INPUT'
                EXPORTING
                  input            = ls_return-language
                IMPORTING
                  output           = lv_spras
                EXCEPTIONS
                  unknown_language = 1
                  OTHERS           = 2.
              IF sy-subrc <> 0.
* Implement suitable error handling here
              ENDIF.

            ENDIF.
            IF ls_return-root2conav IS NOT INITIAL.
              " CO Documents
              lr_codoc =  VALUE #( FOR ls_fo2conav IN ls_return-root2conav
                                   ( sign = 'I'
                                     option = 'EQ'
                                     low = ls_fo2conav-codocument
                                    )
                                 ).
              SORT lr_codoc BY low.
              DELETE ADJACENT DUPLICATES FROM lr_codoc COMPARING low.

            ENDIF.

            IF ls_return-root2outputnav IS NOT INITIAL.
              " Message Type
              lr_output =   VALUE #( FOR ls_fo2output IN ls_return-root2outputnav
                                    WHERE ( application NE 'CO' )
                                    ( sign = 'I'
                                     option = 'EQ'
                                     low = ls_fo2output-messagetype
                                    )
                                 ).


              " Action Type
              lr_actiontype  = VALUE #( FOR ls_fo2output IN ls_return-root2outputnav
                                        WHERE ( application EQ 'CO' )
                                          ( sign = 'I'
                                            option = 'EQ'
                                            low = ls_fo2output-actiontype
                                           )
                                ).

            ENDIF.
            " Special case to add output Type from R3 applied for Direct Invoice
            IF ls_return-directinvoice = abap_true.
              APPEND VALUE #( sign = 'I' option = 'EQ' low = 'YO36' high = '')
                      TO lr_output .
            ENDIF.
            " Text of Email Body
            DATA(lv_mailtext) = VALUE #(  ls_return-root2textnav[ 1 ]-textvalue OPTIONAL ).

            lr_mailid  = VALUE #( FOR ls_fo2mail IN ls_return-root2emailnav
                                ( sign = 'I'
                                  option = 'EQ'
                                  low = ls_fo2mail-emailid
                                 )
                              ).
            SPLIT ls_return-processstatus AT '|' INTO DATA(lv_sta_green) DATA(lv_sta_yellow).
            IF lv_sta_green IS NOT INITIAL.
              DATA(lv_processstatus_green) = 'X'.
            ENDIF.
            IF lv_sta_yellow IS NOT INITIAL.
              DATA(lv_processstatus_yellow) = 'X'.
            ENDIF.

            DATA(lv_mode_run) = 1.   "for testing purpose
            "BREAK-POINT.
            IF lv_mode_run = 0. "run forceground
              SUBMIT /rb1m/sd_sh_printout_data2mail
                WITH s_fo     IN lr_fodoc
                WITH s_co     IN lr_codoc
                WITH s_out_p  IN lr_output
                WITH s_act_p  IN lr_actiontype
                WITH p_excel  EQ ls_return-excelexport
                WITH p_inv    EQ ls_return-directinvoice
                WITH p_mlbinv EQ ls_return-mlbinvoice
                WITH p_proinv EQ ls_return-proformadirectinvoice
                WITH p_pminv  EQ ls_return-proformamlbinvoice
                WITH p_prcsg  EQ lv_processstatus_green
                WITH p_prcsy  EQ lv_processstatus_yellow
                WITH p_langu  EQ lv_spras
                WITH p_merge  EQ ls_return-mergeoption
                WITH p_text   EQ lv_mailtext
                WITH s_mail   IN lr_mailid
                AND RETURN.
            ELSE.
              " call submit report program to perform send mail through batchground job
              "* Open job
              lv_va_jobname = 'YF2M_DATA2MAIL' && sy-datum && sy-uzeit.
              CALL FUNCTION 'JOB_OPEN'
                EXPORTING
                  jobname          = lv_va_jobname
                IMPORTING
                  jobcount         = lv_vn_jobcount
                EXCEPTIONS
                  cant_create_job  = 1
                  invalid_job_data = 2
                  jobname_missing  = 3
                  OTHERS           = 4.

              CHECK sy-subrc IS INITIAL.

              SUBMIT /rb1m/sd_sh_printout_data2mail USER sy-uname
                  VIA JOB lv_va_jobname NUMBER lv_vn_jobcount
                  WITH s_fo     IN lr_fodoc
                  WITH s_co     IN lr_codoc
                  WITH s_out_p  IN lr_output
                  WITH s_act_p  IN lr_actiontype
                  WITH p_excel  EQ ls_return-excelexport
                  WITH p_inv    EQ ls_return-directinvoice
                  WITH p_mlbinv EQ ls_return-mlbinvoice
                  WITH p_proinv EQ ls_return-proformadirectinvoice
                  WITH p_pminv  EQ ls_return-proformamlbinvoice
                  WITH p_prcsg  EQ lv_processstatus_green
                  WITH p_prcsy  EQ lv_processstatus_yellow
                  WITH p_merge  EQ ls_return-mergeoption
                  WITH p_text   EQ lv_mailtext
                  WITH s_mail   IN lr_mailid
                  AND RETURN.
              IF sy-subrc IS INITIAL.
                "* Close job
                CALL FUNCTION 'JOB_CLOSE'
                  EXPORTING
                    jobcount             = lv_vn_jobcount
                    jobname              = lv_va_jobname
                    strtimmed            = 'X'  " start immediatly
                  EXCEPTIONS
                    cant_start_immediate = 1
                    invalid_startdate    = 2
                    jobname_missing      = 3
                    job_close_failed     = 4
                    job_nosteps          = 5
                    job_notex            = 6
                    lock_failed          = 7
                    OTHERS               = 8.
              ENDIF.
            ENDIF.
*>>>
            IF sy-subrc IS INITIAL.
              " Run submit and get respone.
              " if OK response Result = "Success"
              "Sending a success/information message - to the response header
              lo_message_container = me->mo_context->get_message_container( ).
              " Fill the message container
              lo_message_container->add_message_text_only(
                EXPORTING
                  iv_msg_type               = 'S'
                  iv_msg_text               = 'Created successfully batch job with name' && | : | && lv_va_jobname
                  iv_add_to_response_header = abap_true
              ).
              " else  Result = "Error"
            ELSE.
              lo_message_container = me->mo_context->get_message_container( ).
              lo_message_container->add_message_text_only(
                 EXPORTING
                   iv_msg_type               = 'E'
                   iv_msg_text               = '400 - Error - '
                   iv_add_to_response_header = abap_true
               ).
            ENDIF.

            CALL METHOD copy_data_to_ref
              EXPORTING
                is_data = ls_return
              CHANGING
                cr_data = er_deep_entity.

          CATCH /iwbep/cx_mgw_busi_exception.
          CATCH /iwbep/cx_mgw_tech_exception.
        ENDTRY.
    ENDCASE.
  ENDMETHOD.


