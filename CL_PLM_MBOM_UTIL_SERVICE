                        ( kfid = '10' field_name = /rb4r/if_plm_mbom_constant=>mc_field_mandt field_length = 3 field_type = 'C' )
                        ( kfid = '20' field_name = /rb4r/if_plm_mbom_constant=>mc_field_stlty field_length = 1 field_type = 'C' )
                        ( kfid = '30' field_name = /rb4r/if_plm_mbom_constant=>mc_field_stlnr field_length = 8 field_type = 'C' ) ).
        ENDIF.
      WHEN /rb4r/if_plm_mbom_constant=>mc_tab_stas.
        lt_key_field  = get_psomr( /rb4r/if_plm_mbom_constant=>mc_tab_stas ).
        IF lt_key_field IS INITIAL.
          lt_key_field = VALUE tt_key_field(
                        ( kfid = '10' field_name = /rb4r/if_plm_mbom_constant=>mc_field_mandt field_length = 3 field_type = 'C' )
                        ( kfid = '20' field_name = /rb4r/if_plm_mbom_constant=>mc_field_stlty field_length = 1 field_type = 'C' )
                        ( kfid = '30' field_name = /rb4r/if_plm_mbom_constant=>mc_field_stlnr field_length = 8 field_type = 'C' )
                        ( kfid = '40' field_name = /rb4r/if_plm_mbom_constant=>mc_field_stlal field_length = 2 field_type = 'C' )
                        ( kfid = '50' field_name = /rb4r/if_plm_mbom_constant=>mc_field_stlkn field_length = 8 field_type = 'N' ) ).
        ENDIF.
      WHEN /rb4r/if_plm_mbom_constant=>mc_tab_mara.
        lt_key_field  = get_psomr( /rb4r/if_plm_mbom_constant=>mc_tab_mara ).
        IF lt_key_field IS INITIAL.
          lt_key_field = VALUE tt_key_field(
                        ( kfid = '10' field_name = /rb4r/if_plm_mbom_constant=>mc_field_mandt field_length = 3 field_type = 'C' )
                        ( kfid = '20' field_name = /rb4r/if_plm_mbom_constant=>mc_field_matnr field_length = 40 field_type = 'C' ) ).
        ENDIF.
      WHEN OTHERS.
    ENDCASE.

    "Split table key into an internal table
    CLEAR rt_keys.
    SORT lt_key_field BY kfid ASCENDING.
    LOOP AT lt_key_field ASSIGNING FIELD-SYMBOL(<ls_ckfs>).
      APPEND INITIAL LINE TO rt_keys ASSIGNING FIELD-SYMBOL(<ls_key>).
      <ls_key>-field_name = <ls_ckfs>-field_name.
      <ls_key>-field_value = iv_tabkey+lv_pos(<ls_ckfs>-field_length).
      lv_pos = lv_pos + <ls_ckfs>-field_length.
    ENDLOOP.

  ENDMETHOD.


