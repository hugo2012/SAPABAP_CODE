  METHOD read_check_table_field.

    DATA: lt_dd05q               TYPE tt_dd05q,
          ls_dd05q               TYPE dd05q,
          ls_condition           TYPE hrcond,
          lr_chktab              TYPE REF TO data,
          lt_condition           TYPE STANDARD TABLE OF hrcond,
          lv_texttab_name        TYPE char30,
          lv_check_table         TYPE char30,
          lv_textfld_name        TYPE char30,
          lv_where               TYPE string,
          lv_text_field          TYPE char30,
          lt_empty_package_table TYPE string_hashed_table.

    FIELD-SYMBOLS:
      <ls_chk_table>    TYPE any,
      <ls_source_table> TYPE any,
      <lv_field>        TYPE any.

    CLEAR: ev_text, ev_check_table.

    ev_message = /rb4r/if_plm_mbom_constant=>mc_msg_text_table_read_error.
    REPLACE /rb4r/if_plm_sevm_dp_constant=>mc_string_and1 IN ev_message WITH iv_table_name.
    REPLACE /rb4r/if_plm_sevm_dp_constant=>mc_string_and2 IN ev_message WITH iv_table_field.

    " Get foreign keys of the input table&field
    IF line_exists( mt_dd05q[ tabname = iv_table_name fieldname = iv_table_field ] ).
      LOOP AT mt_dd05q INTO ls_dd05q WHERE tabname = iv_table_name AND fieldname = iv_table_field.
        ls_dd05q-tabname = ls_dd05q-tabname. "ATC
        APPEND ls_dd05q TO lt_dd05q.
      ENDLOOP.
    ELSE.
      SELECT *
        FROM dd05q
        INTO TABLE lt_dd05q
        WHERE tabname = iv_table_name
        AND fieldname = iv_table_field.       "#EC CI_SUBRC
      IF lt_dd05q IS NOT INITIAL.
        APPEND LINES OF lt_dd05q TO mt_dd05q.
      ENDIF.
    ENDIF.
    SORT lt_dd05q BY primpos ASCENDING.

    " compose query of check table
    ASSIGN is_data TO <ls_source_table>.
    CLEAR: lt_condition.
    LOOP AT lt_dd05q INTO ls_dd05q WHERE forkey NE 'MANDT' OR checkfield NE 'MANDT'.
      ls_condition-field = ls_dd05q-checkfield.
      ls_condition-field = cl_abap_dyn_prg=>escape_quotes( ls_condition-field ).
      ls_condition-field = cl_abap_dyn_prg=>escape_quotes_str( ls_condition-field ).
      ls_condition-opera = 'EQ'.

      IF ls_dd05q-forkey IS INITIAL.
        CASE ls_dd05q-checkfield.
          WHEN 'MATNR'.
            ls_condition-low = iv_matnr.  "#EC CI_FLDEXT_OK[2215424]
          WHEN 'STLAN'.
            ls_condition-low = iv_stlan.  "#EC CI_FLDEXT_OK[2215424]
          WHEN 'WERKS'.
            ls_condition-low = iv_werks.  "#EC CI_FLDEXT_OK[2215424]
          WHEN 'STLAL'.
            ls_condition-low = iv_stlal.  "#EC CI_FLDEXT_OK[2215424]
          WHEN OTHERS.
            CLEAR ls_condition.
            CONTINUE.
        ENDCASE.
      ELSE.
        ASSIGN COMPONENT ls_dd05q-forkey OF STRUCTURE <ls_source_table> TO <lv_field>.
        ls_condition-low = <lv_field>.
      ENDIF.

      ls_condition-low = cl_abap_dyn_prg=>escape_quotes( ls_condition-low ).
      ls_condition-low = cl_abap_dyn_prg=>escape_quotes_str( ls_condition-low ).

      APPEND ls_condition TO lt_condition.
    ENDLOOP.
    lv_check_table = ls_dd05q-checktable.
    lv_text_field = iv_text_field.

    LOOP AT lt_condition INTO ls_condition.
      IF sy-tabix = 1.
        lv_where = ls_condition-field && ` ` && ls_condition-opera && ` ` && cl_abap_dyn_prg=>quote( val = ls_condition-low ) .
      ELSE.
        lv_where = lv_where && ` ` && 'AND' && ` ` && ls_condition-field && ` ` && ls_condition-opera && ` ` && cl_abap_dyn_prg=>quote( val = ls_condition-low ) .
      ENDIF.
    ENDLOOP.

    INSERT condense( lv_check_table ) INTO TABLE mt_dyn_prg_whitlist_tab.
    TRY." ATC....
        lv_check_table = cl_abap_dyn_prg=>check_table_name_tab( val      = lv_check_table
                                                                packages = lt_empty_package_table ).
        lv_check_table = cl_abap_dyn_prg=>check_whitelist_tab( val        = lv_check_table
                                                               whitelist  = mt_dyn_prg_whitlist_tab ).
      CATCH cx_abap_not_in_package INTO DATA(lx_not_in_package).
        ev_message = lx_not_in_package->get_text( ).
        RETURN.
      CATCH cx_abap_not_a_table INTO DATA(lx_not_a_table).
        ev_message = lx_not_a_table->get_text( ).
        RETURN.
      CATCH cx_abap_not_in_whitelist INTO DATA(lx_not_in_whitelist).
        ev_message = lx_not_in_whitelist->get_text( ).
        RETURN.
    ENDTRY.

    ev_check_table = lv_check_table.
    CREATE DATA lr_chktab TYPE (lv_check_table).
    ASSIGN lr_chktab->* TO <ls_chk_table>.

    TRY.
        SELECT SINGLE *                                  "#EC CI_DYNTAB
         INTO <ls_chk_table>                             "#EC CI_DYNTAB
         FROM (lv_check_table)                           "#EC CI_DYNTAB
          WHERE (lv_where).                              "#EC CI_DYNTAB "#EC CI_SUBRC "#EC CI_DYNWHERE
      CATCH cx_sy_dynamic_osql_error INTO DATA(lx_dynamic_osql_error).
        ev_message = lx_dynamic_osql_error->get_text( ).
        RETURN.
    ENDTRY.
    " text table exists?
    IF iv_is_text_table = abap_true.

      CLEAR: lt_dd05q, ls_dd05q.
      CALL FUNCTION 'DDUT_TEXTTABLE_GET'
        EXPORTING
          tabname    = lv_check_table
        IMPORTING
          texttable  = lv_texttab_name
          checkfield = lv_textfld_name.
      IF iv_table_field = 'MEINS' OR iv_table_field = 'ROMEI' OR iv_table_field = 'BMEIN'.
        ev_legend_field = lv_textfld_name.
      ELSE.
        ev_legend_field = iv_table_field.
      ENDIF.

      IF line_exists( mt_dd05q[ fortable = lv_texttab_name forkey = lv_textfld_name ] ).
        LOOP AT mt_dd05q INTO ls_dd05q WHERE fortable = lv_texttab_name AND forkey = lv_textfld_name.
          ls_dd05q-fortable = ls_dd05q-fortable. "ATC
          APPEND ls_dd05q TO lt_dd05q.
        ENDLOOP.
      ELSE.
        SELECT fortable
               forkey
          FROM dd05q
          INTO CORRESPONDING FIELDS OF TABLE lt_dd05q
          WHERE tabname = lv_texttab_name
           AND fieldname = lv_textfld_name.                   "#EC CI_SUBRC
        IF lt_dd05q IS NOT INITIAL.
          APPEND LINES OF lt_dd05q TO mt_dd05q.
        ENDIF.
      ENDIF.

      CLEAR: lt_condition, lv_where.
      LOOP AT lt_dd05q INTO ls_dd05q WHERE forkey NE 'MANDT' OR checkfield NE 'MANDT'.

        ls_condition-field = ls_dd05q-forkey.
        ls_condition-field = cl_abap_dyn_prg=>escape_quotes( ls_condition-field ).
        ls_condition-field = cl_abap_dyn_prg=>escape_quotes_str( ls_condition-field ).
        ls_condition-opera = 'EQ'.
        IF ls_dd05q-forkey = 'MANDT'.
          ls_condition-low = sy-mandt.
        ELSE.
          ASSIGN COMPONENT ls_dd05q-forkey OF STRUCTURE <ls_chk_table> TO <lv_field>.
          ls_condition-low = <lv_field>.
          ls_condition-low = cl_abap_dyn_prg=>escape_quotes( ls_condition-low ).
          ls_condition-low = cl_abap_dyn_prg=>escape_quotes_str( ls_condition-low ).
        ENDIF.
        APPEND ls_condition TO lt_condition.

      ENDLOOP.
      " Add language key
      IF iv_table_field = 'SANKA'.
        ls_condition-field = 'LANGU'.
      ELSE.
        ls_condition-field = 'SPRAS'.
      ENDIF.
      ls_condition-opera = 'EQ'.
      ls_condition-low = sy-langu.
      ls_condition-low = cl_abap_dyn_prg=>escape_quotes( ls_condition-low ).
      ls_condition-low = cl_abap_dyn_prg=>escape_quotes_str( ls_condition-low ).
      APPEND ls_condition TO lt_condition.

*      CALL FUNCTION 'RH_DYNAMIC_WHERE_BUILD'
*        EXPORTING
*          dbtable         = space " can be empty
*        TABLES
*          condtab         = lt_condition
*          where_clause    = gt_where_clauses
*        EXCEPTIONS
*          empty_condtab   = 01
*          no_db_field     = 02
*          unknown_db      = 03
*          wrong_condition = 04.
*      IF sy-subrc = 0.
*        RETURN.
*      ENDIF.
      LOOP AT lt_condition INTO ls_condition.
        IF sy-tabix = 1.
          lv_where = ls_condition-field && ` ` && ls_condition-opera && ` ` && cl_abap_dyn_prg=>quote( val = ls_condition-low ) .
        ELSE.
          lv_where = lv_where && ` ` && 'AND' && ` ` && ls_condition-field && ` ` && ls_condition-opera && ` ` && cl_abap_dyn_prg=>quote( val = ls_condition-low ) .
        ENDIF.
      ENDLOOP.
      lv_where = cl_abap_dyn_prg=>escape_quotes_str( lv_where ).
      INSERT condense( lv_texttab_name ) INTO TABLE mt_dyn_prg_whitlist_tab.
      INSERT condense( lv_text_field ) INTO TABLE mt_dyn_prg_whitlist_field.
      TRY. "ATC...
          lv_texttab_name = cl_abap_dyn_prg=>check_whitelist_tab( val       = lv_texttab_name
                                                                  whitelist = mt_dyn_prg_whitlist_tab ).
          lv_text_field = cl_abap_dyn_prg=>check_column_name( val = lv_text_field ).
          lv_text_field = cl_abap_dyn_prg=>check_whitelist_tab( val       = lv_text_field
                                                                whitelist = mt_dyn_prg_whitlist_field ).
        CATCH cx_abap_invalid_name INTO DATA(lx_invalid_name).
          ev_message = lx_invalid_name->get_text( ).
          RETURN.
        CATCH cx_abap_not_in_whitelist INTO lx_not_in_whitelist.
          ev_message = lx_not_in_whitelist->get_text( ).
          RETURN.
        CATCH cx_abap_not_a_table INTO lx_not_a_table.
          ev_message = lx_not_a_table->get_text( ).
          RETURN.
      ENDTRY.

      TRY.
          SELECT SINGLE (lv_text_field)                  "#EC CI_DYNTAB
            INTO ev_text                                 "#EC CI_DYNTAB
            FROM (lv_texttab_name)                       "#EC CI_DYNTAB
            WHERE (lv_where).                            "#EC CI_DYNTAB "#EC CI_SUBRC "#EC CI_DYNWHERE
        CATCH cx_sy_dynamic_osql_error INTO lx_dynamic_osql_error.
          ev_message = lx_dynamic_osql_error->get_text( ).
          RETURN.
      ENDTRY.
      ev_text_table = lv_texttab_name.
    ELSE.
      " text field is in the check table
      ASSIGN COMPONENT iv_text_field OF STRUCTURE <ls_chk_table> TO <lv_field>.
      IF sy-subrc EQ 0.
        ev_text = <lv_field>.
      ENDIF.
      ev_text_table = ev_check_table.
      ev_legend_field = iv_table_field.
    ENDIF.

    CLEAR ev_message.

  ENDMETHOD.


METHOD read_mast.

  DATA: lv_material    TYPE matnr,
        lt_mast        TYPE wes_t_mast,
        lv_log         TYPE string,
        lv_keys        TYPE string,
        lt_material    TYPE STANDARD TABLE OF rsdsselopt_255,
        lt_plant       TYPE STANDARD TABLE OF rsdsselopt_255,
        lt_bom_usage   TYPE STANDARD TABLE OF rsdsselopt_255,
        lt_bom_nr      TYPE STANDARD TABLE OF rsdsselopt_255,
        lt_alternative TYPE STANDARD TABLE OF rsdsselopt_255.

  CLEAR: et_mast.

  CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
    EXPORTING
      input        = iv_material
    IMPORTING
      output       = lv_material
    EXCEPTIONS
      length_error = 1
      OTHERS       = 2.
  IF sy-subrc <> 0.
    lv_log = /rb4r/if_plm_mbom_constant=>mc_msg_matnr_error.
    REPLACE /rb4r/if_plm_sevm_dp_constant=>mc_string_and1 IN lv_log WITH lv_material. "#EC CI_FLDEXT_OK[2215424]
    RAISE EXCEPTION TYPE /rb4r/cx_lo_pdpp_sevm_2msg_err
      EXPORTING
        iv_msg_text = lv_log
        iv_part     = /rb4r/if_plm_sevm_dp_constant=>mc_string_body.
  ENDIF.

  IF iv_material IS SUPPLIED AND lv_material IS NOT INITIAL AND iv_material NE '*'.
    lt_material = VALUE #( ( sign = 'I' option = 'EQ' low = lv_material ) ).
  ENDIF.
  IF iv_plant IS SUPPLIED AND iv_plant NE '*'.
    lt_plant = VALUE #( ( sign = 'I' option = 'EQ' low = iv_plant ) ).
  ENDIF.
  IF iv_bom_usage IS SUPPLIED AND iv_bom_usage IS NOT INITIAL AND iv_bom_usage NE '*'.
    lt_bom_usage = VALUE #( ( sign = 'I' option = 'EQ' low = iv_bom_usage ) ).
  ENDIF.
  IF iv_alternative IS SUPPLIED AND iv_alternative IS NOT INITIAL AND iv_alternative NE '*'.
    lt_alternative = VALUE #( ( sign = 'I' option = 'EQ' low = iv_alternative ) ).
  ENDIF.
  IF iv_bom_nr IS SUPPLIED AND iv_bom_nr IS NOT INITIAL AND iv_bom_nr NE '*'.
    lt_bom_nr = VALUE #( ( sign = 'I' option = 'EQ' low = iv_bom_nr ) ).
  ENDIF.

  IF lt_bom_nr IS NOT INITIAL OR lt_alternative IS NOT INITIAL OR lt_bom_usage IS NOT INITIAL OR
    lt_plant IS NOT INITIAL OR lt_material IS NOT INITIAL.
    SELECT *
     FROM mast
     INTO TABLE lt_mast
     WHERE matnr IN lt_material
       AND werks IN lt_plant
       AND stlnr IN lt_bom_nr
       AND stlan IN lt_bom_usage                          "#EC CI_SUBRC
       AND stlal IN lt_alternative.                  "#EC CI_SEL_NESTED
  ENDIF.

  IF lt_mast IS INITIAL.
    lv_log = /rb4r/if_plm_mbom_constant=>mc_msg_no_mast_found_error.
    REPLACE /rb4r/if_plm_sevm_dp_constant=>mc_string_and1 IN lv_log WITH lv_keys.
    RAISE EXCEPTION TYPE /rb4r/cx_lo_pdpp_sevm_2msg_err
      EXPORTING
        iv_msg_text = lv_log
        iv_part     = /rb4r/if_plm_sevm_dp_constant=>mc_string_body.
  ENDIF.
  et_mast = lt_mast.

ENDMETHOD.


  METHOD read_table_filter.

    DATA: lt_tabflt TYPE STANDARD TABLE OF /rb4r/plm_tabflt,
          ls_tabflt TYPE /rb4r/plm_tabflt.
    IF iv_tablename IS SUPPLIED AND iv_msgconfid IS SUPPLIED.
      SELECT *
        FROM /rb4r/plm_tabflt
        INTO TABLE et_tabflt
        WHERE msgconfid = iv_msgconfid
          AND tablename = iv_tablename
          AND active = abap_true.             "#EC CI_SUBRC
    ELSEIF iv_msgconfid IS SUPPLIED.
      SELECT *
        FROM /rb4r/plm_tabflt
        INTO TABLE et_tabflt
        WHERE msgconfid = iv_msgconfid
          AND active = abap_true.             "#EC CI_SUBRC
    ELSEIF iv_tablename IS SUPPLIED.
      SELECT *
        FROM /rb4r/plm_tabflt
        INTO TABLE et_tabflt
        WHERE tablename = iv_tablename
          AND active = abap_true.             "#EC CI_SUBRC
    ELSE.
      SELECT *
        FROM /rb4r/plm_tabflt
        INTO TABLE et_tabflt
        WHERE active = abap_true.             "#EC CI_SUBRC
    ENDIF.

    " option can be refered to dimain DDOPTION, only support EQ,LE,GE,NE,GT,LT
    " Not support BT,CP,NB,NP
    LOOP AT et_tabflt INTO ls_tabflt WHERE opt = 'EQ' OR opt = 'LE' OR opt = 'GE'
                                        OR opt = 'NE' OR opt = 'GT' OR opt = 'LT'.
      ls_tabflt-opt = ls_tabflt-opt.
      APPEND ls_tabflt TO lt_tabflt.
    ENDLOOP.
    SORT lt_tabflt BY msgconfid tablename filter_group fieldname.
    et_tabflt = lt_tabflt.

  ENDMETHOD.
ENDCLASS.
