CLASS /RB4R/CL_PLM_MBOM_UTIL_SERVICE IMPLEMENTATION.


  METHOD expand_structure_components.
    DATA: lt_comp_to_del TYPE abap_component_tab,
          lt_comp        TYPE abap_component_tab,
          lo_line_type   TYPE REF TO cl_abap_structdescr,
          lt_sub_comp    TYPE abap_component_tab.

    " components may have included strucutre. Such strucutre need to be expanded
    IF line_exists( ct_comp[ as_include = abap_true ] ).
      LOOP AT ct_comp ASSIGNING FIELD-SYMBOL(<ls_comp>).
        CLEAR: lt_sub_comp.
        IF <ls_comp>-type->kind EQ 'S' AND <ls_comp>-as_include = abap_true.
          lo_line_type ?= <ls_comp>-type.
          lt_sub_comp = lo_line_type->get_components( ).
          expand_structure_components(
            CHANGING
              ct_comp = lt_sub_comp ).
          APPEND LINES OF lt_sub_comp TO lt_comp.
        ELSE.
          APPEND <ls_comp> TO lt_comp.
        ENDIF.
      ENDLOOP.
      ct_comp = lt_comp.
    ENDIF.
  ENDMETHOD.


  METHOD export_payload_to_file.

    DATA: lv_path      TYPE string,
          xlm_xstring  TYPE xstring,
          temptable    TYPE w3mimetabtype,
          bin_filesize TYPE i.

    IF iv_json IS NOT INITIAL AND iv_file_name IS NOT INITIAL.

      CALL FUNCTION 'SCMS_STRING_TO_XSTRING'
        EXPORTING
          text   = iv_json
        IMPORTING
          buffer = xlm_xstring.

      CALL FUNCTION 'SCMS_XSTRING_TO_BINARY'
        EXPORTING
          buffer        = xlm_xstring
        IMPORTING
          output_length = bin_filesize
        TABLES
          binary_tab    = temptable.
      lv_path = iv_file_name.
      cl_gui_frontend_services=>gui_download(
         EXPORTING
           bin_filesize = bin_filesize
           filename     = lv_path
           filetype     = 'BIN'
         CHANGING
           data_tab     = temptable
         EXCEPTIONS
           file_write_error          = 1
           no_batch                  = 2
           gui_refuse_filetransfer   = 3
           invalid_type              = 4
           no_authority              = 5
           unknown_error             = 6
           header_not_allowed        = 7
           separator_not_allowed     = 8
           filesize_not_allowed      = 9
           header_too_long           = 10
           dp_error_create           = 11
           dp_error_send             = 12
           dp_error_write            = 13
           unknown_dp_error          = 14
           access_denied             = 15
           dp_out_of_memory          = 16
           disk_full                 = 17
           dp_timeout                = 18
           file_not_found            = 19
           dataprovider_exception    = 20
           control_flush_error       = 21
           not_supported_by_gui      = 22
           error_no_gui              = 23
           OTHERS                    = 24
      ).
      IF sy-subrc EQ 0.
        ev_message = /rb4r/if_plm_mbom_constant=>mc_file_write_error && |{ iv_file_name }|.
      ENDIF.
    ENDIF.

  ENDMETHOD.


  METHOD filter_table_by_setting.

********************************************************************************
* How to use:
* 1) Type of CT_TABLE must be a DDIC object
********************************************************************************
    DATA: lt_tabflt               TYPE STANDARD TABLE OF /rb4r/plm_tabflt,
          ls_tabflt_group         TYPE /rb4r/plm_tabflt,
          ls_tabflt               TYPE /rb4r/plm_tabflt,
          lt_tabflt_5_fields      TYPE STANDARD TABLE OF /rb4r/plm_tabflt,
          lt_tabflt_group         TYPE STANDARD TABLE OF /rb4r/plm_tabflt,
          lv_where_clause         TYPE string,
          lt_range1               TYPE RANGE OF char255,
          lt_range2               TYPE RANGE OF char255,
          lt_range3               TYPE RANGE OF char255,
          lt_range4               TYPE RANGE OF char255,
          lt_range5               TYPE RANGE OF char255,
          lt_dyn_prg_whitlist_tab TYPE string_hashed_table,
          lo_table                TYPE REF TO cl_abap_tabledescr,
          lr_table                TYPE REF TO data,
          lr_table_middle         TYPE REF TO data,
          lr_table_final          TYPE REF TO data,
          lt_dd03p                TYPE STANDARD TABLE OF dd03p.
    FIELD-SYMBOLS: <lt_table>        TYPE STANDARD TABLE,
                   <lt_table_middle> TYPE STANDARD TABLE,
                   <lt_table_final>  TYPE STANDARD TABLE.

    lo_table ?= cl_abap_datadescr=>describe_by_data( ct_table ).
    CREATE DATA lr_table TYPE HANDLE lo_table.
    CREATE DATA lr_table_middle TYPE HANDLE lo_table.
    CREATE DATA lr_table_final TYPE HANDLE lo_table.
    ASSIGN lr_table->* TO <lt_table>.
    ASSIGN lr_table_middle->* TO <lt_table_middle>.
    ASSIGN lr_table_final->* TO <lt_table_final>.

    /rb4r/cl_plm_mbom_util_service=>read_table_filter(
      EXPORTING
        iv_msgconfid  = iv_msgconfid
        iv_tablename  = iv_tablename
      IMPORTING
        et_tabflt     = lt_tabflt ).

    IF lt_tabflt IS INITIAL.
      " No configuration than do not process the filters
      RETURN.
    ENDIF.

    TRY.
        LOOP AT lt_tabflt INTO ls_tabflt.
          cl_abap_dyn_prg=>check_table_name_str( val = ls_tabflt-tablename packages = '' ).
          " check field name existence
          CALL FUNCTION 'DD_TBFD_GET'
            EXPORTING
              tabl_name     = iv_tablename
            TABLES
              dd03p_tab_a   = lt_dd03p
            EXCEPTIONS
              illegal_value = 1
              op_failure    = 2
              OTHERS        = 3.
          IF sy-subrc <> 0 OR NOT line_exists( lt_dd03p[ fieldname = ls_tabflt-fieldname ] ).
            CLEAR ct_table.
            RAISE EXCEPTION TYPE /rb4r/cx_lo_pdpp_sevm_2msg_err
              EXPORTING
                iv_msg_text = /rb4r/if_plm_mbom_constant=>mc_sql_injection
                iv_part     = /rb4r/if_plm_sevm_dp_constant=>mc_string_body.
            RETURN.
          ENDIF.
        ENDLOOP.
      CATCH cx_abap_not_a_table cx_abap_invalid_name cx_abap_not_in_package.
        CLEAR ct_table.
        RAISE EXCEPTION TYPE /rb4r/cx_lo_pdpp_sevm_2msg_err
          EXPORTING
            iv_msg_text = /rb4r/if_plm_mbom_constant=>mc_sql_injection
            iv_part     = /rb4r/if_plm_sevm_dp_constant=>mc_string_body.
        RETURN.
    ENDTRY.

    " Each group will be considered as a seprated iteration of input table, the final result combines each group
    LOOP AT lt_tabflt INTO ls_tabflt_group GROUP BY ( filter_group = ls_tabflt_group-filter_group )
      ASSIGNING FIELD-SYMBOL(<lr_group>).

      <lt_table_middle> = ct_table.

*      LOOP AT GROUP <lr_group> ASSIGNING FIELD-SYMBOL(<ls_filter>).
*        APPEND <ls_filter> TO lt_tabflt_group.
*      ENDLOOP.

      " Execution of each group
      LOOP AT GROUP <lr_group> ASSIGNING FIELD-SYMBOL(<ls_filter>).
        APPEND <ls_filter> TO lt_tabflt_5_fields.

        IF ( sy-tabix MOD 5 ) = 0.
          " for each 5 fields, filter together
          /rb4r/cl_plm_mbom_util_service=>generate_where_clause_by_flt(
            EXPORTING
              it_filter        = lt_tabflt_5_fields
              iv_rangetab_name = 'LT_RANGE'
            IMPORTING
              et_range1        = lt_range1
              et_range2        = lt_range2
              et_range3        = lt_range3
              et_range4        = lt_range4
              et_range5        = lt_range5
            CHANGING
              cv_where_clause  = lv_where_clause ).
          INSERT condense( lv_where_clause ) INTO TABLE lt_dyn_prg_whitlist_tab.
          TRY." ATC....
              lv_where_clause = cl_abap_dyn_prg=>check_whitelist_tab( val        = lv_where_clause
                                                                      whitelist  = lt_dyn_prg_whitlist_tab ).
            CATCH cx_abap_not_in_whitelist.
              CLEAR ct_table.
              RAISE EXCEPTION TYPE /rb4r/cx_lo_pdpp_sevm_2msg_err
                EXPORTING
                  iv_msg_text = /rb4r/if_plm_mbom_constant=>mc_sql_injection
                  iv_part     = /rb4r/if_plm_sevm_dp_constant=>mc_string_body.
              RETURN.
          ENDTRY.
          LOOP AT <lt_table_middle> ASSIGNING FIELD-SYMBOL(<ls_table_line>) WHERE (lv_where_clause). " CT_TABLE->replace with middle table
            <ls_table_line> = <ls_table_line>. "ATC
            APPEND <ls_table_line> TO <lt_table>.
          ENDLOOP.
          <lt_table_middle> = <lt_table>. " CT_TABLE->replace with middle table

          " clear
          CLEAR: <lt_table>, lt_range1, lt_range2, lt_range3, lt_range4, lt_range5, lt_tabflt_5_fields, lv_where_clause.
        ENDIF.

      ENDLOOP.

      " the remaining filter settings
      IF lt_tabflt_5_fields IS NOT INITIAL.
        /rb4r/cl_plm_mbom_util_service=>generate_where_clause_by_flt(
          EXPORTING
            it_filter        = lt_tabflt_5_fields
            iv_rangetab_name = 'LT_RANGE'
          IMPORTING
            et_range1        = lt_range1
            et_range2        = lt_range2
            et_range3        = lt_range3
            et_range4        = lt_range4
            et_range5        = lt_range5
          CHANGING
            cv_where_clause  = lv_where_clause ).
        INSERT condense( lv_where_clause ) INTO TABLE lt_dyn_prg_whitlist_tab.
        TRY." ATC....
            lv_where_clause = cl_abap_dyn_prg=>check_whitelist_tab( val        = lv_where_clause
                                                                    whitelist  = lt_dyn_prg_whitlist_tab ).
          CATCH cx_abap_not_in_whitelist.
            CLEAR ct_table.
            RAISE EXCEPTION TYPE /rb4r/cx_lo_pdpp_sevm_2msg_err
              EXPORTING
                iv_msg_text = /rb4r/if_plm_mbom_constant=>mc_sql_injection
                iv_part     = /rb4r/if_plm_sevm_dp_constant=>mc_string_body.
            RETURN.
        ENDTRY.
        LOOP AT <lt_table_middle> ASSIGNING <ls_table_line> WHERE (lv_where_clause). " use the middle table
          <ls_table_line> = <ls_table_line>. "ATC
          APPEND <ls_table_line> TO <lt_table>.
        ENDLOOP.
      ELSE.
        <lt_table> = <lt_table_middle>.
      ENDIF.

      APPEND LINES OF <lt_table> TO <lt_table_final>.
      CLEAR: lt_tabflt_group, <lt_table_middle>, <lt_table>, lt_tabflt_5_fields, lv_where_clause.

    ENDLOOP.

    ct_table = <lt_table_final>.
    SORT ct_table.
    DELETE ADJACENT DUPLICATES FROM ct_table.

  ENDMETHOD.


  METHOD generate_where_clause_by_flt.
********************************************************************************
* How to use:
* 1) Make sure the name of range tables retruned by the method should be the same
* in the where clause.
* 2) The maxium number of each run should not exceed 5 fields. Parameter
* IV_RANGETAB_FROM indicates the first range table number of retrun, like,
* lt_range1, while IV_RANGETAB_FROM = 1.
* 3) Run the method twice when there are more than 5 fields configed
********************************************************************************
    DATA: ls_filter                TYPE /rb4r/plm_tabflt,
          lt_filter                TYPE tt_tabflt,
          ls_range                 LIKE LINE OF et_range1,
          lt_range                 TYPE tt_range_255,
          lv_range_name            TYPE string,
          lv_range_name_calculated TYPE string,
          lv_field_cnt             TYPE i,
          lv_field_cnt_c           TYPE char2,
          lv_start                 TYPE i.

    CONSTANTS: lc_range_tab TYPE string VALUE 'LT_RANGE'.

    CLEAR: et_range1, et_range2, et_range3, et_range4, et_range5, cv_where_clause.

    " check the only config id, one table
    lt_filter = it_filter.
    SORT lt_filter BY msgconfid tablename.
    DELETE ADJACENT DUPLICATES FROM lt_filter COMPARING msgconfid tablename.
    IF lines( lt_filter ) > 1.
      CLEAR cv_where_clause.
      RETURN.
    ENDIF.

    " range table number from
    IF iv_rangetab_from = 0.
      lv_start = 1.
    ELSE.
      lv_start = iv_rangetab_from.
    ENDIF.

    " range table name
    IF iv_rangetab_name IS INITIAL.
      lv_range_name = lc_range_tab.
    ELSE.
      lv_range_name = iv_rangetab_name.
    ENDIF.

    LOOP AT it_filter INTO ls_filter GROUP BY ( msgconfid = ls_filter-msgconfid tablename = ls_filter-tablename fieldname = ls_filter-fieldname )
      ASSIGNING FIELD-SYMBOL(<lr_group>).

      " 5 fields utmost
      IF lv_field_cnt = 0.
        lv_field_cnt = lv_start.
      ELSE.
        lv_field_cnt = lv_field_cnt + 1.
      ENDIF.

      IF  ( lv_field_cnt - lv_start + 1 ) > 5.
        CLEAR cv_where_clause.
        EXIT.
      ENDIF.

      " compose range table
      CLEAR lt_range.
      LOOP AT GROUP <lr_group> ASSIGNING FIELD-SYMBOL(<ls_filter>).
        CASE <ls_filter>-opt.
          WHEN 'NE'.
            " NE is special
            ls_range-sign = 'E'.
            ls_range-option = 'EQ'.
          WHEN OTHERS.
            ls_range-sign = 'I'.
            ls_range-option = <ls_filter>-opt.
        ENDCASE.

        ls_range-low = <ls_filter>-value.
        APPEND ls_range TO lt_range.
      ENDLOOP.

      " fill retrun tables
      CASE lv_field_cnt - lv_start + 1.
        WHEN 1.
          et_range1 = lt_range.
        WHEN 2.
          et_range2 = lt_range.
        WHEN 3.
          et_range3 = lt_range.
        WHEN 4.
          et_range4 = lt_range.
        WHEN 5.
        WHEN OTHERS.
          CLEAR cv_where_clause.
          EXIT.
      ENDCASE.
      lv_field_cnt_c = lv_field_cnt.
      CONCATENATE lv_range_name lv_field_cnt_c INTO lv_range_name_calculated.

      " compose where clause
      IF cv_where_clause IS NOT INITIAL.
        cv_where_clause = | { cv_where_clause } | && 'AND' && | { <ls_filter>-fieldname } | && 'IN' && | { lv_range_name_calculated } |.
      ELSE.
        cv_where_clause =  | { <ls_filter>-fieldname } | && 'IN' && | { lv_range_name_calculated } |.
      ENDIF.

    ENDLOOP.

  ENDMETHOD.


  METHOD get_keys_by_tabkey.
