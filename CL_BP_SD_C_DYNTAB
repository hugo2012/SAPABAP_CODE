CLASS lsc_sd_c_dyntab DEFINITION INHERITING FROM cl_abap_behavior_saver.
  PROTECTED SECTION.

    METHODS finalize REDEFINITION.

    METHODS check_before_save REDEFINITION.

    METHODS save REDEFINITION.

    METHODS cleanup REDEFINITION.

    METHODS cleanup_finalize REDEFINITION.

ENDCLASS.

CLASS lsc_sd_c_dyntab IMPLEMENTATION.

  METHOD finalize.
  ENDMETHOD.

  METHOD check_before_save.
  ENDMETHOD.

  METHOD save.

    DATA:
      lt_r_matnr   TYPE RANGE OF matnr,
      ls_vbsk      TYPE vbsk,
      lt_vbfs      TYPE TABLE OF vbfs,
      lt_vbls      TYPE TABLE OF vbls,
      lt_lips      TYPE TABLE OF lips,
      lv_shipto    TYPE kunwe,
      lv_numc10    TYPE numc10,
      lt_komdlgn   TYPE TABLE OF komdlgn,
      lv_matnr     TYPE matnr,
      lv_lifnr     TYPE elifn,
      lv_parenid   TYPE char10,
      lv_index     TYPE i,
      lv_vgpos     TYPE vgpos,
      lv_ebeln     TYPE ebeln,
      lv_ebeln_tmp TYPE ebeln.
    DATA : lr_ebeln TYPE RANGE OF ebeln.
    DATA(ls_dyntab) = lcl_buffer=>gs_dyntab.

    CASE ls_dyntab-runmode.
      WHEN 'C'.

        SELECT SINGLE
               plant,
               salesorganization,
               distributionchannel,
               division
          FROM i_plant
          INTO @DATA(ls_plant)
         WHERE plant = @ls_dyntab-plant.
        IF sy-subrc <> 0.
          CLEAR ls_plant.
        ENDIF.
*      Subcon item level
        DATA(lt_itmtemp) = lcl_buffer=>gt_items.
*      Collect all the Purchase Order...
        LOOP AT lt_itmtemp INTO DATA(ls_tmp) WHERE col6 IS NOT INITIAL.
          lv_ebeln = ls_tmp-col6.
          APPEND VALUE #( sign = 'I'
                          option = 'EQ'
                          low = |{ lv_ebeln ALPHA = IN }| ) TO lr_ebeln.
          CLEAR : lv_ebeln.
        ENDLOOP.

        IF lt_itmtemp IS NOT INITIAL.
          SORT lt_itmtemp BY col9.
          DELETE ADJACENT DUPLICATES FROM lt_itmtemp COMPARING col9.
        ENDIF.


        LOOP AT lt_itmtemp INTO DATA(ls_itmtemp).
          CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
            EXPORTING
              input        = ls_itmtemp-col9
            IMPORTING
              output       = lv_matnr
            EXCEPTIONS
              length_error = 1
              OTHERS       = 2.

          APPEND VALUE #( sign = 'I'
                          option = 'EQ'
                          low = lv_matnr ) TO lt_r_matnr.


          CLEAR: lv_matnr.
        ENDLOOP.

        SELECT matnr,
               vtweg
          FROM mvke
          INTO TABLE @DATA(lt_mvke)
         WHERE matnr IN @lt_r_matnr
           AND vkorg =  @ls_plant-salesorganization.
        IF sy-subrc = 0.
          SORT lt_mvke BY matnr
                          vtweg.
        ENDIF.
*       To get the Purchase Order Agreement
        IF lr_ebeln IS NOT INITIAL.
          SORT lr_ebeln BY low.
          DELETE ADJACENT DUPLICATES FROM lr_ebeln.
          SELECT ebeln, ebelp FROM ekpo
                              WHERE ebeln IN @lr_ebeln
                                AND loekz EQ ''
                              INTO TABLE @DATA(lt_ekpo).

          IF sy-subrc = 0.
            SORT lt_ekpo BY ebeln ebelp.
          ENDIF.
        ENDIF.
*       To populate VBSK table
        ls_vbsk = VALUE #( mandt = sy-mandt
                           ernam = sy-uname
                           erdat = sy-datum
                           uzeit = sy-uzeit
                           smart = 'L' ).

        LOOP AT lcl_buffer=>gt_items INTO DATA(ls_item) WHERE parentid NE space.
          READ TABLE lcl_buffer=>gt_items INTO DATA(ls_head)
            WITH KEY rootid = ls_item-parentid.
          IF sy-subrc = 0.
            lv_shipto = ls_head-col17.
*           Purchase order Agreement
            lv_ebeln_tmp = ls_head-col6.
            DATA(lv_purchaseorder) = |{ lv_ebeln_tmp ALPHA = IN }|.
          ENDIF.

          CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
            EXPORTING
              input        = ls_item-col9
            IMPORTING
              output       = lv_matnr
            EXCEPTIONS
              length_error = 1
              OTHERS       = 2.

          CALL FUNCTION 'CONVERSION_EXIT_CUNIT_INPUT'
            EXPORTING
              input  = ls_item-col12
            IMPORTING
              output = ls_item-col12.

          READ TABLE lt_mvke INTO DATA(ls_mvke) BINARY SEARCH
            WITH KEY matnr = lv_matnr.
          IF sy-subrc <> 0.
            CLEAR ls_mvke.
          ENDIF.

          lv_lifnr = |{ ls_head-col2 ALPHA = IN }|.
          lv_shipto = |{ lv_shipto ALPHA = IN }|.
          DATA(ls_ekpo) = VALUE #( lt_ekpo[ ebeln = lv_purchaseorder ] OPTIONAL ).
          lv_vgpos = ls_ekpo-ebelp.
          APPEND VALUE #( lifnr = lv_lifnr
                          matnr = lv_matnr
                          lgnum = ls_dyntab-warehouno
                          werks = ls_dyntab-plant
                          vstel = ls_dyntab-shippoint
                          kunwe = lv_shipto
                          charg = ls_item-col14
                          lfimg = ls_item-col17
                          vrkme = ls_item-col12
                          lgort = '2000'
                          lgtyp = ls_item-col7
                          lgpla = ls_item-col8
                          vkorg = ls_plant-salesorganization
                          vtweg = ls_mvke-vtweg
                          spart = ls_plant-division
                          lfart = 'YOLB'
*                          bwart = '541'
                          kzazu = 'X'
                          vgbel = ls_ekpo-ebeln
                          vgpos = lv_vgpos
                          vgtyp = 'V'
                          wadat = sy-datlo
*                          wauhr = sy-timlo
                          lfdat = sy-datlo
*                          lfuhr = sy-timlo
                          ) TO lt_komdlgn.

          CLEAR:
                      ls_head,
                      ls_mvke,
                      lv_lifnr,
                      lv_matnr,
                      lv_shipto,
                      lv_vgpos,
                      lv_purchaseorder.

        ENDLOOP.

*       Create delivery will happen for one vendor and different materials
        CALL FUNCTION 'GN_DELIVERY_CREATE' "#EC CI_USAGE_OK[2438131]
          EXPORTING
            vbsk_i         = ls_vbsk
            vbls_pos_rueck = abap_true
            no_commit      = abap_true
            if_no_deque    = abap_true
          TABLES
            xkomdlgn       = lt_komdlgn
            xvbfs          = lt_vbfs        " Error tab
            xvbls          = lt_vbls
            xxlips         = lt_lips        " Success tab
          EXCEPTIONS
            error_message  = 1
            OTHERS         = 99.
        IF sy-subrc = 0.
*         Success cases
          LOOP AT lt_lips INTO DATA(ls_lips).
            lv_index = sy-tabix.

            CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
              EXPORTING
                input  = ls_lips-matnr
              IMPORTING
                output = lv_matnr.

            READ TABLE lcl_buffer=>gt_items ASSIGNING FIELD-SYMBOL(<lfs_item>)
              WITH KEY col9 = lv_matnr
                       col7+0(3) = ls_lips-lgtyp
                       col8+0(10) = ls_lips-lgpla.
            IF <lfs_item> IS ASSIGNED.
              <lfs_item>-col1 = 'Success'.
              <lfs_item>-col6 = ls_lips-vbeln.
              lv_parenid = <lfs_item>-parentid.
            ENDIF.
            UNASSIGN <lfs_item>.

            READ TABLE lcl_buffer=>gt_items ASSIGNING <lfs_item>
              WITH KEY col9 = lv_matnr
                       rootid = lv_parenid.
            IF <lfs_item> IS ASSIGNED.
              <lfs_item>-col1 = 'Success'.
            ENDIF.
            UNASSIGN <lfs_item>.

            APPEND VALUE #( mainindex = 1
                            msgindex = sy-tabix
                            msgtype = 'S'
                            msgno = '000'
                            msgcontent = |Delivery { ls_lips-vbeln } created successfull! |
                            msgv1 = ls_lips-vbeln ) TO lcl_buffer=>gt_msgres.
            CLEAR:
              lv_matnr,
              lv_parenid.
          ENDLOOP.

          DESCRIBE TABLE lt_lips LINES DATA(lv_tabix).

          DATA lv_meins TYPE meins.

*         Error cases
          LOOP AT lt_vbfs INTO DATA(ls_vbfs).
*            CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
*              EXPORTING
*                input        = ls_vbfs-matnr
*              IMPORTING
*                output       = lv_matnr.
*
*            READ TABLE lcl_buffer=>gt_items ASSIGNING <lfs_item>
*              WITH KEY Col9 = lv_matnr.
**                       Col7 = ls_vbfs-lgtyp
**                       Col8 = ls_vbfs-lgpla.
*            IF <lfs_item> IS ASSIGNED.
*              <lfs_item>-Col1 = 'Error'.
*              lv_parenid = <lfs_item>-ParentId.
*            ENDIF.
*            UNASSIGN <lfs_item>.
*
*            READ TABLE lcl_buffer=>gt_items ASSIGNING <lfs_item>
*              WITH KEY Col9 = lv_matnr
*                       RootId = lv_parenid.
*            IF <lfs_item> IS ASSIGNED.
*              <lfs_item>-Col1 = 'Error'.
*            ENDIF.
*            UNASSIGN <lfs_item>.

*           Check if UoM exist
            lv_meins = ls_vbfs-msgv2.

            CALL FUNCTION 'CONVERSION_EXIT_CUNIT_OUTPUT'
              EXPORTING
                input  = lv_meins
              IMPORTING
                output = lv_meins
                         EXCEPTIONS
                         unit_not_found.
            IF sy-subrc = 0.
              ls_vbfs-msgv2 = lv_meins.
            ENDIF.

            MESSAGE ID ls_vbfs-msgid
               TYPE ls_vbfs-msgty
             NUMBER ls_vbfs-msgno
               INTO DATA(lv_message)
               WITH ls_vbfs-msgv1
                    ls_vbfs-msgv2
                    ls_vbfs-msgv3
                    ls_vbfs-msgv4.

            APPEND VALUE #( mainindex = 1
                            msgindex = ls_vbfs-zaehl + lv_tabix
                            msgtype = ls_vbfs-msgty
                            msgno = ls_vbfs-msgno
                            msgcontent = lv_message
                            msgv1 = ls_vbfs-msgv1
                            msgv2 = ls_vbfs-msgv2
                            msgv3 = ls_vbfs-msgv3
                            msgv4 = ls_vbfs-msgv4 ) TO lcl_buffer=>gt_msgres.
            CLEAR:
              lv_matnr,
              lv_parenid.
          ENDLOOP.

        ELSE.

          APPEND VALUE #( mainindex = 1
                          msgindex = 1
                          msgtype = 'E'
                          msgno = '000'
                          msgcontent = 'Have error when running FM GN_DELIVERY_CREATE.'
                          msgv1 = ls_lips-vbeln ) TO lcl_buffer=>gt_msgres.

        ENDIF.

      WHEN OTHERS.

    ENDCASE.

  ENDMETHOD.

  METHOD cleanup.
  ENDMETHOD.

  METHOD cleanup_finalize.
  ENDMETHOD.

ENDCLASS.

