CLASS lhc_sd_c_dyntab IMPLEMENTATION.

  METHOD get_instance_authorizations.
  ENDMETHOD.

  METHOD get_deep.

**********************************************************************
    READ TABLE dyntab INDEX 1 INTO DATA(ls_dyntab).
    lcl_buffer=>gs_dyntab = CORRESPONDING #( ls_dyntab ).

    DATA ls_header LIKE LINE OF lcl_buffer=>gt_header.

**********************************************************************
    LOOP AT headernav INTO DATA(ls_headernav).
      LOOP AT ls_headernav-%target INTO DATA(ls_heatarget).
        ls_header = CORRESPONDING #( ls_heatarget ).

        APPEND ls_header TO lcl_buffer=>gt_header.
        CLEAR ls_header.
      ENDLOOP.
    ENDLOOP.

**********************************************************************
    DATA ls_items LIKE LINE OF lcl_buffer=>gt_items.

    LOOP AT itemsnav INTO DATA(ls_itemsnav).
      LOOP AT ls_itemsnav-%target INTO DATA(ls_itmtarget).
        ls_items = CORRESPONDING #( ls_itmtarget ).

        APPEND ls_items TO lcl_buffer=>gt_items.
        CLEAR ls_items.
      ENDLOOP.
    ENDLOOP.

**********************************************************************
    DATA ls_r_vendor LIKE LINE OF lcl_buffer=>gt_r_vendor.

    LOOP AT vendornav INTO DATA(ls_vendornav).
      LOOP AT ls_vendornav-%target INTO DATA(ls_ventarget).
        ls_r_vendor-sign   = ls_ventarget-sign.
        ls_r_vendor-option = ls_ventarget-optio.
        ls_r_vendor-low    = ls_ventarget-low.
        ls_r_vendor-high   = ls_ventarget-high.

        APPEND ls_r_vendor TO lcl_buffer=>gt_r_vendor.
        CLEAR ls_r_vendor.
      ENDLOOP.
    ENDLOOP.

**********************************************************************
    DATA ls_r_purord LIKE LINE OF lcl_buffer=>gt_r_purord.

    LOOP AT purordnav INTO DATA(ls_purordnav).
      LOOP AT ls_purordnav-%target INTO DATA(ls_potarget).
        ls_r_purord-sign   = ls_potarget-sign.
        ls_r_purord-option = ls_potarget-optio.
        ls_r_purord-low    = ls_potarget-low.
        ls_r_purord-high   = ls_potarget-high.

        APPEND ls_r_purord TO lcl_buffer=>gt_r_purord.
        CLEAR ls_r_purord.
      ENDLOOP.
    ENDLOOP.

**********************************************************************
    DATA ls_r_reqdat LIKE LINE OF lcl_buffer=>gt_r_reqdat.

    LOOP AT reqdatnav INTO DATA(ls_reqdatnav).
      LOOP AT ls_reqdatnav-%target INTO DATA(ls_dattarget).
        ls_r_reqdat-sign   = ls_dattarget-sign.
        ls_r_reqdat-option = ls_dattarget-optio.

        IF ls_dattarget-low IS NOT INITIAL.
          DATA(lv_date_low) = replace( val = ls_dattarget-low regex = '(\d{4})-(\d{2})-(\d{2}).*' with = '$1$2$3' occ = 0 ).
          ls_r_reqdat-low   = lv_date_low+1(8).
        ENDIF.

        IF ls_dattarget-high IS NOT INITIAL.
          DATA(lv_date_hig) = replace( val = ls_dattarget-high regex = '(\d{4})-(\d{2})-(\d{2}).*' with = '$1$2$3' occ = 0 ).
          ls_r_reqdat-high  = lv_date_hig+1(8).
        ENDIF.

        APPEND ls_r_reqdat TO lcl_buffer=>gt_r_reqdat.
        CLEAR ls_r_reqdat.
      ENDLOOP.
    ENDLOOP.

**********************************************************************
    DATA ls_r_storty LIKE LINE OF lcl_buffer=>gt_r_storty.

    LOOP AT stortynav INTO DATA(ls_stortynav).
      LOOP AT ls_stortynav-%target INTO DATA(ls_stytarget).
        ls_r_storty-sign   = ls_stytarget-sign.
        ls_r_storty-option = ls_stytarget-optio.
        ls_r_storty-low    = ls_stytarget-low.
        ls_r_storty-high   = ls_stytarget-high.

        APPEND ls_r_storty TO lcl_buffer=>gt_r_storty.
        CLEAR ls_r_storty.
      ENDLOOP.
    ENDLOOP.

**********************************************************************
    DATA ls_r_storbi LIKE LINE OF lcl_buffer=>gt_r_storbi.

    LOOP AT storbinav INTO DATA(ls_storbinav).
      LOOP AT ls_storbinav-%target INTO DATA(ls_sbitarget).
        ls_r_storbi-sign   = ls_sbitarget-sign.
        ls_r_storbi-option = ls_sbitarget-optio.
        ls_r_storbi-low    = ls_sbitarget-low.
        ls_r_storbi-high   = ls_sbitarget-high.

        APPEND ls_r_storbi TO lcl_buffer=>gt_r_storbi.
        CLEAR ls_r_storbi.
      ENDLOOP.
    ENDLOOP.

**********************************************************************
    DATA ls_r_assepr LIKE LINE OF lcl_buffer=>gt_r_assepr.

    LOOP AT asseprnav INTO DATA(ls_asseprnav).
      LOOP AT ls_asseprnav-%target INTO DATA(ls_asetarget).

        TRANSLATE ls_asetarget-low USING '* '.
        CONDENSE ls_asetarget-low NO-GAPS.

        TRANSLATE ls_asetarget-high USING '* '.
        CONDENSE ls_asetarget-high NO-GAPS.

        CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
          EXPORTING
            input  = ls_asetarget-low
          IMPORTING
            output = ls_asetarget-low.

        CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
          EXPORTING
            input  = ls_asetarget-high
          IMPORTING
            output = ls_asetarget-high.

        ls_r_assepr-sign   = ls_asetarget-sign.
        ls_r_assepr-option = ls_asetarget-optio.
        ls_r_assepr-low    = ls_asetarget-low.
        ls_r_assepr-high   = ls_asetarget-high.

        APPEND ls_r_assepr TO lcl_buffer=>gt_r_assepr.
        APPEND ls_r_assepr TO lcl_buffer=>gt_r_matnr.
        CLEAR ls_r_assepr.

      ENDLOOP.
    ENDLOOP.

**********************************************************************
    DATA ls_r_compo LIKE LINE OF lcl_buffer=>gt_r_compo.

    LOOP AT componav INTO DATA(ls_componav).
      LOOP AT ls_componav-%target INTO DATA(ls_comtarget).

        TRANSLATE ls_comtarget-low USING '* '.
        CONDENSE ls_comtarget-low NO-GAPS.

        TRANSLATE ls_comtarget-high USING '* '.
        CONDENSE ls_comtarget-high NO-GAPS.

        CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
          EXPORTING
            input  = ls_comtarget-low
          IMPORTING
            output = ls_comtarget-low.

        CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
          EXPORTING
            input  = ls_comtarget-high
          IMPORTING
            output = ls_comtarget-high.

        ls_r_compo-sign   = ls_comtarget-sign.
        ls_r_compo-option = ls_comtarget-optio.
        ls_r_compo-low    = ls_comtarget-low.
        ls_r_compo-high   = ls_comtarget-high.

        APPEND ls_r_compo TO lcl_buffer=>gt_r_compo.
        APPEND ls_r_compo TO lcl_buffer=>gt_r_matnr.
        CLEAR ls_r_compo.
      ENDLOOP.
    ENDLOOP.

  ENDMETHOD.

