  METHOD rba_itemsnav.
    DATA lv_headidx  TYPE sy-tabix.
    DATA lv_rootid   TYPE char30.
    DATA lv_availqty TYPE int4.
    DATA lv_delvqty  TYPE int4.
    DATA lv_stockven TYPE int4.
    DATA lv_delvqty_char TYPE char50.
    DATA lv_demand   TYPE int4. "char30.
    DATA lv_hucount  TYPE int4. "char10.
    DATA lv_traffic  TYPE char10.
    DATA lv_matnr    TYPE matnr.

    DATA lt_limtv TYPE TABLE OF limtv.
    DATA lt_lips  TYPE TABLE OF lips.
    DATA ls_licom TYPE licom.
    DATA(ls_dyntab) = lcl_buffer=>gs_dyntab.

    CASE ls_dyntab-runmode.
      WHEN 'R'.
        SELECT purchaseordernumber,
               material,
               materialname,
               baseunit,
               plant,
               storloc,
               vendornumber,
               vendorname,
               vendorcity,
               vendorcountry,
               requirementdate,
               ben,
               bomhead,
               bomitm,
               compdesc,
               shipto,
               SUM( deliveryquantity ) AS deliveryquantity
          FROM /rb1m/sd_availstock( p_werks = @ls_dyntab-plant,
                                    p_vstel = @ls_dyntab-shippoint,
                                    p_lgnum = @ls_dyntab-warehouno+0(3) )
         WHERE vendornumber IN @lcl_buffer=>gt_r_vendor
           AND purchaseordernumber IN @lcl_buffer=>gt_r_purord
           AND requirementdate IN @lcl_buffer=>gt_r_reqdat
           AND material IN @lcl_buffer=>gt_r_assepr
           AND bomitm IN @lcl_buffer=>gt_r_compo
         GROUP BY
               purchaseordernumber,
               material,
               materialname,
               baseunit,
               plant,
               storloc,
               vendornumber,
               vendorname,
               vendorcity,
               vendorcountry,
               requirementdate,
               ben,
               bomhead,
               bomitm,
               compdesc,
               shipto
          INTO TABLE @DATA(lt_assembly)
            UP TO @ls_dyntab-top ROWS.
        IF sy-subrc = 0.
          SORT lt_assembly BY vendornumber
                              purchaseordernumber
                              material
                              bomhead
                              bomitm
                              baseunit
                              storloc
                              shipto.
          DELETE ADJACENT DUPLICATES FROM lt_assembly COMPARING vendornumber
                                                                purchaseordernumber
                                                                material
                                                                bomhead
                                                                bomitm
                                                                baseunit
                                                                storloc
                                                                shipto.

          lcl_buffer=>gt_assembly = lt_assembly.

          DATA(lt_assetmp) = lt_assembly.
          SORT lt_assetmp BY bomitm ASCENDING.
          DELETE ADJACENT DUPLICATES FROM lt_assetmp COMPARING bomitm.

          lcl_buffer=>gt_r_compo = VALUE #( FOR <ls_assetmp> IN lt_assetmp ( sign = 'I'
                                                                             option = 'EQ'
                                                                             low = <ls_assetmp>-bomitm ) ).

*         Get Demand data
          SELECT material,
                 SUM( requiredquantity ) AS requiredquantity,
                 SUM( withdrawnquantity ) AS withdrawnquantity
            FROM i_subcontractingcomponent WITH PRIVILEGED ACCESS
           WHERE material IN @lcl_buffer=>gt_r_compo
             AND plant = @ls_dyntab-plant
             AND requirementdate IN @lcl_buffer=>gt_r_reqdat
           GROUP BY
                 material
            INTO TABLE @DATA(lt_demand).
          IF sy-subrc = 0.
            SORT lt_demand BY material.
          ENDIF.

*         Get List of Component
          SELECT matid,
                 batch,
                 warehousenumber,
                 storagetype,
                 storagebin,
                 material,
                 materialname,
                 SUM( availablequantity ) AS availablequantity,
                 baseunit,
                 bomhead,
                 SUM( hucount ) AS hucount
            FROM /rb1m/sd_availstock_compo( p_werks = @ls_dyntab-plant,
                                            p_lgnum = @ls_dyntab-warehouno )
           WHERE storagetype IN @lcl_buffer=>gt_r_storty
             AND storagebin IN @lcl_buffer=>gt_r_storbi
             AND material IN @lcl_buffer=>gt_r_compo
           GROUP BY
                 matid,
                 batch,
                 warehousenumber,
                 storagetype,
                 storagebin,
                 material,
                 materialname,
                 baseunit,
                 bomhead
            INTO TABLE @DATA(lt_componen).
          IF sy-subrc = 0.
            SORT lt_componen BY storagetype
                                storagebin
                                material
                                batch.

            lcl_buffer=>gt_componen = lt_componen.
          ENDIF.

*         Get Stock Vendor
          CLEAR lt_assetmp.
          lt_assetmp = lt_assembly.
          SORT lt_assetmp BY bomitm
                             plant
                             vendornumber.
          DELETE ADJACENT DUPLICATES FROM lt_assetmp COMPARING bomitm
                                                               plant
                                                               vendornumber.
          SELECT matnr,
                 werks,
                 charg,
                 lifnr,
                 lblab
            FROM mslb
            INTO TABLE @DATA(lt_mslb)
             FOR ALL ENTRIES IN @lt_assetmp
           WHERE matnr = @lt_assetmp-bomitm
             AND werks = @lt_assetmp-plant
             AND sobkz = 'O'
             AND lifnr = @lt_assetmp-vendornumber.
          IF sy-subrc = 0.
            SORT lt_mslb BY matnr
                            werks
                            lifnr.
          ENDIF.
        ELSE.
          APPEND VALUE #( mainindex = 1
                          msgindex = 1
                          msgtype = 'S'
                          msgno = 1
                          msgcontent = 'Data not valid.'
                          msgv1 = ''
                          msgv2 = ''
                          msgv3 = ''
                          msgv4 = ''
                         ) TO lcl_buffer=>gt_msgres.
        ENDIF.

*       Fill data to result
        LOOP AT lt_assembly INTO DATA(ls_assembly).

          lv_headidx = sy-tabix.

          lv_stockven = REDUCE int4( INIT total = 0
                                      FOR ls_mslb IN lt_mslb WHERE ( matnr = ls_assembly-bomitm
                                                                 AND werks = ls_assembly-plant
                                                                 AND lifnr = ls_assembly-vendornumber )
                                     NEXT total = total + ls_mslb-lblab ).

          lv_demand = REDUCE int4( INIT total = 0
                                    FOR ls_demand IN lt_demand WHERE ( material = ls_assembly-bomitm )
                                   NEXT total = total + ( ls_demand-requiredquantity - ls_demand-withdrawnquantity ) ).

          lv_traffic = COND #( WHEN lv_stockven < lv_demand "ls_assembly-DemandQuantity
                               THEN 'Error'
                               ELSE 'Success' ).

          lv_rootid = sy-tabix.
          CONDENSE lv_rootid NO-GAPS.

          DATA(lt_tempcom) = lt_componen.

          DELETE lt_tempcom WHERE material NE ls_assembly-bomitm.
          DELETE lt_tempcom WHERE bomhead NE ls_assembly-bomhead.

*         Main data filling
          CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
            EXPORTING
              input  = ls_assembly-material
            IMPORTING
              output = ls_assembly-material.

          CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
            EXPORTING
              input  = ls_assembly-bomitm
            IMPORTING
              output = ls_assembly-bomitm.

          CALL FUNCTION 'CONVERSION_EXIT_CUNIT_OUTPUT'
            EXPORTING
              input  = ls_assembly-baseunit
            IMPORTING
              output = ls_assembly-baseunit.

          lv_delvqty  = ls_assembly-deliveryquantity.

          lv_hucount = REDUCE int4( INIT total = 0
                                     FOR tempcom IN lt_tempcom
                                    NEXT total = total + tempcom-hucount ).

          lv_availqty = REDUCE int4( INIT total = 0
                                      FOR tempcom IN lt_tempcom
                                     NEXT total = total + tempcom-availablequantity ).

          APPEND VALUE #( mainindex = 1
                          headerindex = lv_headidx
                          itemsindex = 1
                          ismain = abap_true
                          title = ''
                          col1  = lv_traffic
                          col2  = |{ ls_assembly-vendornumber ALPHA = OUT }|
                          col3  = ls_assembly-vendorname
                          col4  = ls_assembly-vendorcity
                          col5  = ls_assembly-vendorcountry
                          col6  = |{ ls_assembly-purchaseordernumber ALPHA = OUT }|
                          col7  = ls_assembly-material
                          col8  = ls_assembly-materialname
                          col9  = ls_assembly-bomitm
                          col10 = ls_assembly-compdesc
                          col11 = lv_availqty
                          col12 = ls_assembly-baseunit
                          col13 = lv_hucount
                          col14 = lv_stockven
                          col15 = ''
                          col16 = lv_demand
                          col17 = |{ ls_assembly-shipto ALPHA = OUT }|
                          action = ''
                          rootid = lv_rootid
                          parentid = '' ) TO result.
          CLEAR:
            lv_availqty,
            lv_hucount,
            lv_traffic.

*         Sub data filling
          LOOP AT lt_tempcom INTO DATA(ls_temcom).
            DATA(lv_itemidx) = sy-tabix.
            DATA(lv_itmdelv) = lv_delvqty.

            lv_demand = lv_demand - lv_availqty.
            IF lv_demand < 0.
              lv_demand = 0.
            ENDIF.

            CLEAR lv_availqty.

            lv_availqty = ls_temcom-availablequantity.
            lv_hucount = ls_temcom-hucount.

            IF lv_itmdelv > lv_availqty.
              lv_itmdelv = lv_availqty.
            ENDIF.

            IF lv_demand < lv_availqty.
              lv_itmdelv = lv_demand.
            ENDIF.

            IF lv_delvqty > lv_availqty.
              lv_delvqty = lv_delvqty - lv_availqty.
            ELSE.
              lv_delvqty = 0.
            ENDIF.

            lv_delvqty_char = lv_itmdelv.
            CONDENSE lv_delvqty_char NO-GAPS.

            lv_traffic = COND #( WHEN ( lv_stockven + lv_itmdelv ) < lv_demand
                               THEN 'Error'
                               ELSE 'Success' ).

            CALL FUNCTION 'CONVERSION_EXIT_MATN1_OUTPUT'
              EXPORTING
                input  = ls_temcom-material
              IMPORTING
                output = ls_temcom-material.

            CALL FUNCTION 'CONVERSION_EXIT_CUNIT_OUTPUT'
              EXPORTING
                input  = ls_temcom-baseunit
              IMPORTING
                output = ls_temcom-baseunit.

            APPEND VALUE #( mainindex = 1
                            headerindex = lv_headidx
                            itemsindex = lv_itemidx
                            ismain = abap_false
                            title = ''
                            col1  = lv_traffic
                            col7  = |{ ls_temcom-storagetype ALPHA = OUT }|
                            col8  = |{ ls_temcom-storagebin ALPHA = OUT }|
                            col9  = ls_temcom-material
                            col10 = ls_temcom-materialname
                            col11 = lv_availqty
                            col12 = ls_temcom-baseunit
                            col13 = lv_hucount
                            col14 = ls_temcom-batch
                            col15 = '' "ls_temcom-ben
                            col16 = lv_demand
                            col17 = lv_delvqty_char
                            action = ''
                            rootid = ''
                            parentid = lv_rootid
                            editdelqty = abap_true ) TO result.
            CLEAR:
              lv_traffic,
              lv_delvqty_char.
          ENDLOOP.

*         Created Deliveries filling
          CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
            EXPORTING
              input        = ls_assembly-bomitm
            IMPORTING
              output       = ls_licom-matnr
            EXCEPTIONS
              length_error = 1
              OTHERS       = 2.

          ls_licom-lfart = 'YOLB'.
          ls_licom-vstel = ls_dyntab-shippoint.
          ls_licom-kunnr = ls_assembly-shipto.
          ls_licom-zuart = 'A'.
          ls_licom-vboff = 'X'.

          CALL FUNCTION 'RV_DELIVERY_VIEW_2'
            EXPORTING
              licom   = ls_licom
            TABLES
              llimtv  = lt_limtv
              lt_lips = lt_lips
            EXCEPTIONS
              OTHERS  = 1.
          IF sy-subrc = 0.
            DELETE lt_lips WHERE werks NE ls_dyntab-plant.

            LOOP AT lt_lips INTO DATA(ls_lips).
              LOOP AT lt_limtv INTO DATA(ls_limtv) WHERE vbeln = ls_lips-vbeln
                                                     AND posnr = ls_lips-posnr.
                CALL FUNCTION 'UNIT_CONVERSION'
                  EXPORTING
                    matnr   = ls_assembly-material
                    meinh   = ls_limtv-vrkme
                    meins   = ls_assembly-baseunit
                    mgame   = ls_limtv-lfimg
                  IMPORTING
                    o_mglme = ls_limtv-lfimg
                  EXCEPTIONS
                    OTHERS  = 1.

                CALL FUNCTION 'CONVERSION_EXIT_CUNIT_OUTPUT'
                  EXPORTING
                    input  = ls_limtv-vrkme
                  IMPORTING
                    output = ls_limtv-vrkme.

                WRITE ls_limtv-lfimg TO lv_delvqty_char DECIMALS 0.
                CONDENSE lv_delvqty_char NO-GAPS.

                APPEND VALUE #( mainindex = 1
                                headerindex = lv_headidx
                                itemsindex = lv_itemidx
                                ismain = abap_false
                                title = ''
                                col1  = 'Success'
                                col6  = |{ ls_lips-vbeln ALPHA = OUT }|
                                col7  = |{ ls_lips-lgtyp ALPHA = OUT }|
                                col8  = |{ ls_lips-lgpla ALPHA = OUT }|
                                col9  = ls_assembly-bomitm
                                col10 = ls_assembly-compdesc
                                col11 = ''
                                col12 = ls_limtv-vrkme
                                col13 = ''
                                col14 = ls_lips-charg "|{ ls_lips-charg ALPHA = OUT }|
                                col15 = ''
                                col16 = ''
                                col17 = lv_delvqty_char
                                action = ''
                                rootid = ''
                                parentid = lv_rootid
                                editdelqty = abap_false ) TO result.

                CLEAR:
                  lv_delvqty_char.
              ENDLOOP.
            ENDLOOP.
          ENDIF.

          CLEAR:
            lv_rootid,
            lv_delvqty,
            lv_stockven.

          CLEAR:
            lv_demand.
        ENDLOOP.

      WHEN 'C'.
        result = CORRESPONDING #( lcl_buffer=>gt_items ).

      WHEN OTHERS.

    ENDCASE.

  ENDMETHOD.

  METHOD rba_vendornav.

    result = VALUE #(
          ( mainindex = 1
            soindex = 1
            sign = 'I'
            optio = 'EQ'
            low = 'Test1'
            high = 'Test2' )
        ).

