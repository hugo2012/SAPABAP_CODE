METHOD /rb1m/if_sd_printout_util~create_excel_xml.
  DATA: lo_excel     TYPE REF TO /rb4c/cl_ca_a2xl,
        lo_worksheet TYPE REF TO /rb4c/cl_ca_a2xl_worksheet,
        lo_style     TYPE REF TO /rb4c/cl_ca_a2xl_style,
        lo_column    TYPE REF TO /rb4c/cl_ca_a2xl_column,
        lo_row       TYPE REF TO /rb4c/cl_ca_a2xl_row,
        lv_date_str  TYPE char10.
  DATA: lv_c_vemng(7)  TYPE c,
        lv_c_brgew(10) TYPE c,
        lv_c_ntgew(10) TYPE c,
        lv_c_laeng(7)  TYPE c,
        lv_c_breit(7)  TYPE c,
        lv_c_hoehe(7)  TYPE c.
  DATA: lv_letter2(2)  TYPE c.


  CREATE OBJECT lo_excel.
  lo_worksheet = lo_excel->get_active_worksheet( ).

  lo_style               = lo_excel->add_new_style( ).
  lo_style->alignment->vertical = /rb4c/cl_ca_a2xl_style_alignme=>c_vertical_bottom.
  lo_style->font->bold   = abap_true.
  lo_style->font->name   = /rb4c/cl_ca_a2xl_style_font=>c_name_arial.
  lo_style->font->family = /rb4c/cl_ca_a2xl_style_font=>c_family_swiss.
  lo_style->font->color-rgb  = /rb4c/cl_ca_a2xl_style_color=>c_red.
  lo_style->number_format->format_code = /rb4c/cl_ca_a2xl_style_number_=>c_format_text.
  DATA(lv_default_style) = lo_style->get_guid( ).

  lo_style               = lo_excel->add_new_style( ).
  lo_style->number_format->format_code = /rb4c/cl_ca_a2xl_style_number_=>c_format_text.
  DATA(lv_style_s62) = lo_style->get_guid( ).
  lo_style               = lo_excel->add_new_style( ).
  lo_style->font->bold  = abap_true.
  lo_style->number_format->format_code = /rb4c/cl_ca_a2xl_style_number_=>c_format_text.
  lo_style->font->name   = /rb4c/cl_ca_a2xl_style_font=>c_name_arial.
  lo_style->font->family = /rb4c/cl_ca_a2xl_style_font=>c_family_swiss.
  lo_style->font->color-rgb  = /rb4c/cl_ca_a2xl_style_color=>c_red.
  DATA(lv_style_s63) = lo_style->get_guid( ).
  lo_style               = lo_excel->add_new_style( ).
  lo_style->alignment->vertical = /rb4c/cl_ca_a2xl_style_alignme=>c_vertical_bottom.
  lo_style->alignment->wraptext     = abap_true.
  DATA(lv_style_s64) = lo_style->get_guid( ).
  lo_style               = lo_excel->add_new_style( ).
  lo_style->number_format->format_code = /rb4c/cl_ca_a2xl_style_number_=>c_format_number_00.
  DATA(lv_style_s65) = lo_style->get_guid( ).
  lo_style               = lo_excel->add_new_style( ).
  lo_style->number_format->format_code = /rb4c/cl_ca_a2xl_style_number_=>c_format_number.
  DATA(lv_style_s66) = lo_style->get_guid( ).
*   style for each cell of content
  lo_style               = lo_excel->add_new_style( ).
  lo_style->number_format->format_code = /rb4c/cl_ca_a2xl_style_number_=>c_format_text.
  DATA(lv_cell_style) = lo_style->get_guid( ).
  TRY.
      lo_worksheet->/rb4c/if_ca_a2xl_sheet_protect~protected  = /rb4c/if_ca_a2xl_sheet_protect=>c_protected.

      lo_row = lo_worksheet->get_row( 1 ).
      lo_row->set_row_height( 15 ).

      lo_worksheet->set_cell( ip_column = 'A' ip_row = 1 ip_value = 'Supplier no.'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'B' ip_row = 1 ip_value = 'Delivery note'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'C' ip_row = 1 ip_value = 'Consignment Order'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'D' ip_row = 1 ip_value = 'Freight order'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'E' ip_row = 1 ip_value = 'Shipping date'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'F' ip_row = 1 ip_value = 'Customer order no.'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'G' ip_row = 1 ip_value = 'Bosch order no.'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'H' ip_row = 1 ip_value = 'No. of parcels'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'I' ip_row = 1 ip_value = 'Means of transport'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'J' ip_row = 1 ip_value = 'Pick up place'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'K' ip_row = 1 ip_value = 'Recipient'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'L' ip_row = 1 ip_value = 'Unloading point'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'M' ip_row = 1 ip_value = 'Receiving point'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'N' ip_row = 1 ip_value = 'Carrier'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'O' ip_row = 1 ip_value = 'Carrier Country Code'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'P' ip_row = 1 ip_value = 'Carrier VAT number'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'Q' ip_row = 1 ip_value = 'Executing Carrier'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'R' ip_row = 1 ip_value = 'Executing Carrier Country Code'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'S' ip_row = 1 ip_value = 'Executing Carrier VAT number'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'T' ip_row = 1 ip_value = 'Container ID'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'U' ip_row = 1 ip_value = 'Commodity code/tariff code'  ip_style = lv_style_s63 ).
*       For future requirement
*        lo_worksheet->set_cell( ip_column = 'S' ip_row = 1 ip_value = 'Truck License plate number'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'V' ip_row = 1 ip_value = 'Driver Name'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'W' ip_row = 1 ip_value = 'Customer material'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'X' ip_row = 1 ip_value = 'Material description'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'Y' ip_row = 1 ip_value = 'Quantity'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'Z' ip_row = 1 ip_value = 'Bosch material no.'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'AA' ip_row = 1 ip_value = 'Handling Unit'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'AB' ip_row = 1 ip_value = 'Sub HU'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'AC' ip_row = 1 ip_value = 'Gross weight'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'AD' ip_row = 1 ip_value = 'Net weight'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'AE' ip_row = 1 ip_value = 'Length'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'AF' ip_row = 1 ip_value = 'Width'  ip_style = lv_style_s63 ).
      lo_worksheet->set_cell( ip_column = 'AG' ip_row = 1 ip_value = 'Height'  ip_style = lv_style_s63 ).

      DATA(lv_count) = 0.
      DATA(lv_ext)  = 0.

      DO 33 TIMES.
        IF lv_count < 26.
          lv_letter2 = sy-abcde+lv_count(1).
        ELSE.
          DATA(lv_a) = 0.
          DATA(lv_letter_x) = sy-abcde+lv_a(1).
          DATA(lv_letter_y) = sy-abcde+lv_ext(1).
          lv_letter2 = |{ lv_letter_x }| && |{ lv_letter_y }| .
          lv_ext += 1.
        ENDIF.
        CASE lv_letter2.
          WHEN 'C' OR 'E' OR 'M' OR 'D' OR 'G' OR 'H' OR 'Y' OR 'Z' OR 'O'.
            DATA(lv_width) = 20.
          WHEN 'N' OR 'K' OR 'J' OR 'X'  OR 'P' OR 'Q' OR 'R' OR 'S'.
            lv_width = 30.
          WHEN 'AA' OR 'AB'.
            lv_width = 40.
          WHEN OTHERS.
            lv_width = 15.
        ENDCASE.
        lo_column = lo_worksheet->get_column( lv_letter2 ).
        lo_column->set_auto_size( ip_auto_size = abap_false ).

        lo_column->set_width( lv_width ).
        lv_count += 1.
      ENDDO.

* Data
      LOOP AT it_item_data INTO DATA(ls_item_data).
        WRITE ls_item_data-vemng TO lv_c_vemng DECIMALS 0 NO-GROUPING LEFT-JUSTIFIED.
        IF ls_item_data-vemng IS INITIAL. lv_c_vemng = space. ENDIF.
        WRITE ls_item_data-brgew TO lv_c_brgew DECIMALS 3 NO-GROUPING LEFT-JUSTIFIED.
        TRANSLATE lv_c_brgew USING ',.'.
        IF ls_item_data-brgew IS INITIAL. lv_c_brgew = space. ENDIF.
        WRITE ls_item_data-ntgew TO lv_c_ntgew DECIMALS 3 NO-GROUPING LEFT-JUSTIFIED.
        TRANSLATE lv_c_ntgew USING ',.'.
        IF ls_item_data-ntgew IS INITIAL. lv_c_ntgew = space. ENDIF.
        WRITE ls_item_data-laeng TO lv_c_laeng DECIMALS 0 NO-GROUPING LEFT-JUSTIFIED.
        IF ls_item_data-laeng IS INITIAL. lv_c_laeng = space. ENDIF.
        WRITE ls_item_data-breit TO lv_c_breit DECIMALS 0 NO-GROUPING LEFT-JUSTIFIED.
        IF ls_item_data-breit IS INITIAL. lv_c_breit = space. ENDIF.
        WRITE ls_item_data-hoehe TO lv_c_hoehe DECIMALS 0 NO-GROUPING LEFT-JUSTIFIED.
        IF ls_item_data-hoehe IS INITIAL. lv_c_hoehe = space. ENDIF.
        IF ls_item_data-anzpk = 0. ls_item_data-anzpk = space. ENDIF.
        IF ls_item_data-wadat = 0. ls_item_data-wadat = space. ENDIF.
        IF ls_item_data-carriername IS INITIAL. ls_item_data-carriername = space. ENDIF.
        IF ls_item_data-execarriername IS INITIAL. ls_item_data-execarriername = space. ENDIF.
        IF ls_item_data-land1_sp IS INITIAL. ls_item_data-land1_sp = space. ENDIF.
        IF ls_item_data-stceg IS INITIAL. ls_item_data-stceg = space. ENDIF.
        IF ls_item_data-land1_sp_execarrier IS INITIAL. ls_item_data-land1_sp_execarrier = space. ENDIF.
        IF ls_item_data-stceg_execarrier IS INITIAL. ls_item_data-stceg_execarrier = space. ENDIF.
        IF ls_item_data-signi IS INITIAL. ls_item_data-signi = space. ENDIF.
        IF ls_item_data-itm_comco IS INITIAL. ls_item_data-itm_comco = space. ENDIF.


        DATA(lv_index) = sy-tabix + 1.
        lo_row = lo_worksheet->get_row( lv_index ).
        lo_row->set_row_height( 13 ).
        lo_worksheet->set_cell( ip_column = 'A' ip_row = lv_index ip_value = ls_item_data-eikto ip_style = lv_cell_style ).

        lo_worksheet->set_cell( ip_column = 'B' ip_row = lv_index ip_value = ls_item_data-vbeln ip_style = lv_cell_style ).

        lo_worksheet->set_cell( ip_column = 'C' ip_row = lv_index ip_value = ls_item_data-codoc ip_style = lv_cell_style ).

        lo_worksheet->set_cell( ip_column = 'D' ip_row = lv_index ip_value = ls_item_data-fodoc ip_style = lv_cell_style ).
        lv_date_str = |{ ls_item_data-wadat+0(4) }| && |{ ls_item_data-wadat+4(2) }| && |{ ls_item_data-wadat+6(2) }|.
        lo_worksheet->set_cell( ip_column = 'E' ip_row = lv_index ip_value = lv_date_str ip_style = lv_style_s62 ).
        lo_worksheet->set_cell( ip_column = 'F' ip_row = lv_index ip_value = ls_item_data-bstnk ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'G' ip_row = lv_index ip_value = ls_item_data-vgbel ip_style = lv_cell_style ).
        DATA(lv_anzpk) = |{ ls_item_data-anzpk ALPHA = IN }|.
        IF lv_anzpk = space.
          lo_worksheet->set_cell( ip_column = 'H' ip_row = lv_index ip_value = lv_anzpk ip_style = lv_style_s62 ).
        ELSE.
          lo_worksheet->set_cell( ip_column = 'H' ip_row = lv_index ip_value = lv_anzpk ip_style = lv_style_s66 ).

        ENDIF.
        lo_worksheet->set_cell( ip_column = 'I' ip_row = lv_index ip_value = ls_item_data-vsartbez ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'J' ip_row = lv_index ip_value = ls_item_data-adrvst ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'K' ip_row = lv_index ip_value = ls_item_data-adrkun ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'L' ip_row = lv_index ip_value = ls_item_data-ablad  ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'M' ip_row = lv_index ip_value = ls_item_data-empst ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'N' ip_row = lv_index ip_value = ls_item_data-carriername ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'O' ip_row = lv_index ip_value = ls_item_data-land1_sp ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'P' ip_row = lv_index ip_value = ls_item_data-stceg ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'Q' ip_row = lv_index ip_value = ls_item_data-execarriername ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'R' ip_row = lv_index ip_value = ls_item_data-land1_sp_execarrier ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'S' ip_row = lv_index ip_value = ls_item_data-stceg_execarrier ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'T' ip_row = lv_index ip_value = ls_item_data-signi ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'U' ip_row = lv_index ip_value = ls_item_data-itm_comco ip_style = lv_cell_style ).
*          lo_worksheet->set_cell( ip_column = 'S' ip_row = lv_index ip_value = ls_item_data-missingfield ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'V' ip_row = lv_index ip_value = ls_item_data-exti1 ip_style = lv_cell_style ).

        lo_worksheet->set_cell( ip_column = 'W' ip_row = lv_index ip_value = ls_item_data-kdmat ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'X' ip_row = lv_index ip_value = ls_item_data-arktx ip_style = lv_cell_style ).
        IF lv_c_vemng = space.
          lo_worksheet->set_cell( ip_column = 'Y' ip_row = lv_index ip_value = lv_c_vemng ip_style = lv_style_s62 ).
        ELSE.
          lo_worksheet->set_cell( ip_column = 'Y' ip_row = lv_index ip_value = lv_c_vemng ip_style = lv_style_s66 ).

        ENDIF.
        lo_worksheet->set_cell( ip_column = 'Z' ip_row = lv_index ip_value = ls_item_data-matnr ip_style = lv_style_s62 ).
        lo_worksheet->set_cell( ip_column = 'AA' ip_row = lv_index ip_value = ls_item_data-exidv ip_style = lv_cell_style ).
        lo_worksheet->set_cell( ip_column = 'AB' ip_row = lv_index ip_value = ls_item_data-subhu ip_style = lv_style_s64 ).
        IF lv_c_brgew = space.
          lo_worksheet->set_cell( ip_column = 'AC' ip_row = lv_index ip_value = lv_c_brgew ip_style = lv_style_s62 ).
        ELSE.
          lo_worksheet->set_cell( ip_column = 'AC' ip_row = lv_index ip_value = lv_c_brgew ip_style = lv_style_s66 ).
        ENDIF.
        IF lv_c_ntgew = space.
          lo_worksheet->set_cell( ip_column = 'AD' ip_row = lv_index ip_value = lv_c_ntgew ip_style = lv_style_s66 ).
        ELSE.
          lo_worksheet->set_cell( ip_column = 'AD' ip_row = lv_index ip_value = lv_c_ntgew ip_style = lv_style_s65 ).
        ENDIF.
        IF lv_c_laeng = space.
          lo_worksheet->set_cell( ip_column = 'AE' ip_row = lv_index ip_value = lv_c_laeng ip_style = lv_style_s62 ).
        ELSE.
          lo_worksheet->set_cell( ip_column = 'AE' ip_row = lv_index ip_value = lv_c_laeng ip_style = lv_style_s66 ).


        ENDIF.
        IF lv_c_breit = space.
          lo_worksheet->set_cell( ip_column = 'AF' ip_row = lv_index ip_value = lv_c_breit ip_style = lv_style_s62 ).
        ELSE.
          lo_worksheet->set_cell( ip_column = 'AF' ip_row = lv_index ip_value = lv_c_breit ip_style = lv_style_s66 ).
        ENDIF.
        IF lv_c_hoehe = space.
          lo_worksheet->set_cell( ip_column = 'AG' ip_row = lv_index ip_value = lv_c_hoehe ip_style = lv_style_s62 ).
        ELSE.
          lo_worksheet->set_cell( ip_column = 'AG' ip_row = lv_index ip_value = lv_c_hoehe ip_style = lv_style_s66 ).
        ENDIF.
      ENDLOOP.
    CATCH /rb4c/cx_ca_a2xl.

  ENDTRY.
  IF lo_excel IS BOUND .
    eo_excel ?= lo_excel.
  ENDIF.
ENDMETHOD.


  METHOD /rb1m/if_sd_printout_util~merge_pdf_per_co.
    DATA: lv_pdf_size_wbs TYPE so_obj_len,
          lv_datasize     TYPE so_obj_len,
          lv_pdf_size_lfg TYPE so_obj_len,
          lv_subject      TYPE so_obj_des,
          lv_subject2     TYPE string,
          lt_text         TYPE soli_tab,
          lt_text_html    TYPE string,
          lv_text         TYPE soli,
          lo_recipient    TYPE REF TO if_recipient_bcs,
          lv_sent_to_all  TYPE os_boolean,
          lo_send_request TYPE REF TO cl_bcs.

    DATA:
      lv_error_text      TYPE string,
      lv_rc              TYPE i,
      lv_merged_document TYPE xstring,
      lo_document        TYPE REF TO cl_document_bcs,
      lo_pdf_merger      TYPE REF TO cl_rspo_pdf_merge,
      ls_formoutput      TYPE fpformoutput,
      lv_pdf_content_wbs TYPE solix_tab,
      lv_pdf_content_lfg TYPE solix_tab,
      lv_email           TYPE adr6-smtp_addr.
    DATA: lw_document  TYPE xstring,
          lt_data2mail TYPE /rb1m/sd_t_pdf_data2mail.
    DATA: lt_freightorder TYPE /rb1m/cl_sd_printout_d_mpc_ext=>tt_freightorder.
    DATA: lo_writer TYPE REF TO /rb4c/if_ca_a2xl_writer.
    DATA: lt_attachment_header  TYPE soli_tab,
          ls_attachment_header  LIKE LINE OF lt_attachment_header,
          lv_attachment_subject TYPE sood-objdes,
          lv_bytecount          TYPE sood-objlen.
    DATA:lv_xml_data TYPE xstring,
         lt_xml      TYPE solix_tab.
    DATA: lv_title(20)            TYPE c,
          lv_title_translated(20) TYPE c.
    CONSTANTS:
      lc_beginhtmltag TYPE char30 VALUE ' <html> <body> ',
      lc_endhtmltag   TYPE char30 VALUE ' </body> </html> '.

    IF it_body_text IS NOT INITIAL.
      lt_text = it_body_text.
    ELSE.
      lt_text_html = iv_body_html.
      lt_text_html = lc_beginhtmltag && lt_text_html.
    ENDIF.
*   Check if the language from Front End of PDF2Mail App is different than sy-langu
*   Background processing is setting always to system language.....
    IF is_deepdata_data2mail-email_language NE sy-langu.
      SET LANGUAGE is_deepdata_data2mail-email_language.
      lv_title_translated = TEXT-002.
      SET LANGUAGE sy-langu.
    ELSE.
      lv_title_translated = TEXT-002.

    ENDIF.

    IF iv_export_excel EQ abap_true .
      lt_freightorder = CORRESPONDING #( it_pdf_data MAPPING codocument = codocument
                                                            freightorderdocument = freightorderdocument
                                                            deliverydocument = vbeln
                                                            freightorderunit = fudocument
                                                            carrier = carrier ).
      DELETE lt_freightorder WHERE deliverydocument+0(2) = '00'.
      DELETE lt_freightorder WHERE deliverydocument+0(1) = '7'.
      DELETE lt_freightorder WHERE deliverydocument+0(1) = 'A'.
      SORT lt_freightorder.
      DELETE ADJACENT DUPLICATES FROM lt_freightorder.
    ENDIF.
    DATA(lv_co) = VALUE #( it_pdf_data[ 1 ]-codocument OPTIONAL ).
    lt_data2mail = CORRESPONDING #( it_pdf_data ).
    LOOP AT it_pdf_data INTO DATA(ls_tmp1).
      CLEAR: lt_text_html.
      CHECK lt_data2mail IS NOT INITIAL.
      TRY.
          CREATE OBJECT lo_pdf_merger.
          CREATE OBJECT lo_document.

        CATCH cx_rspo_pdf_merge cx_document_bcs.
          MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
          APPEND VALUE #( type = 'E'
                               message = TEXT-007   " Document creation failed !
                      )
                TO et_return.
          EXIT.
      ENDTRY.
      IF ls_tmp1-codocument EQ lv_co.
*          Subject
        lv_title = lv_title_translated . " Bosch shipment
        lv_subject = lv_title  && | | &&  ls_tmp1-codocument .
        TRY.
            CREATE OBJECT lo_document.
            CREATE OBJECT lo_pdf_merger.

          CATCH cx_rspo_pdf_merge cx_document_bcs.
            MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
            APPEND VALUE #( type = 'E'
                                 message = TEXT-007   " Document creation failed !
                        )
                  TO et_return.
            EXIT.
        ENDTRY.
        lt_text_html = iv_body_html.
        lt_text_html = lc_beginhtmltag && lt_text_html.

        DATA(lv_string) = TEXT-004 && | | && is_shippingpoint_adrs-name1 && | | && TEXT-003.
        lt_text_html = lt_text_html && lv_string.
        CLEAR lv_string.
        lv_string = is_shippingpoint_adrs-name2 && | | && TEXT-003.
        lt_text_html = lt_text_html && lv_string.
        CLEAR lv_string.
        lv_string = is_shippingpoint_adrs-stras && | | && TEXT-003.
        lt_text_html = lt_text_html && lv_string.
        CLEAR lv_string.
        lv_string = is_shippingpoint_adrs-pstlz && | | && is_shippingpoint_adrs-ort01 && | | && TEXT-005.
        lt_text_html = lt_text_html && lv_string.
        lt_text_html = lt_text_html && lc_endhtmltag.
        lt_text = cl_bcs_convert=>string_to_soli( lt_text_html ).
        TRY.
            IF it_body_text IS NOT INITIAL.
              lo_document = cl_document_bcs=>create_document(
                  i_type    = 'RAW'
                  i_text    = lt_text
                  i_length  = lv_pdf_size_lfg
                  i_subject = lv_subject ).
            ELSE.
              lo_document = cl_document_bcs=>create_document(
                  i_type    = 'HTM'
                  i_text    = lt_text
                  i_length  = lv_pdf_size_lfg
                  i_subject = lv_subject ).
            ENDIF.
          CATCH cx_document_bcs.
            MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
            APPEND VALUE #( type = 'E'
                                 message = TEXT-007   " Document creation failed !
                        )
                  TO et_return.
            EXIT.
        ENDTRY.
*           Export Excel
        IF iv_export_excel EQ abap_true .
          CLEAR : lt_xml,lt_attachment_header, lv_subject, lv_xml_data ,
                  lv_bytecount, lv_attachment_subject, ls_attachment_header.

          DATA(lt_co_excel) = lt_freightorder.
          DELETE lt_co_excel WHERE codocument NE ls_tmp1-codocument.
          DATA(ls_do_exist) = VALUE #( lt_co_excel[ deliverydocument = ls_tmp1-vbeln ]-deliverydocument OPTIONAL ).
          IF lt_co_excel IS NOT INITIAL.

            CALL METHOD /rb1m/cl_sd_printout_dataprovd=>/rb1m/if_sd_printout_dataprovd~get_excel_data
              EXPORTING
                it_freightorder       = lt_co_excel
                is_deepdata_data2mail = is_deepdata_data2mail
              IMPORTING
                eo_excel              = DATA(lo_excel).

            DELETE ADJACENT DUPLICATES FROM lt_co_excel COMPARING codocument.
            DATA(lv_line) = lines( lt_co_excel ).
            CREATE OBJECT lo_writer TYPE /rb4c/cl_ca_a2xl_writer_2007.
            IF lo_excel IS BOUND.
              TRY.
                  lv_xml_data = lo_writer->write_file( lo_excel ).

                CATCH /rb4c/cx_ca_a2xl.
                  MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
                  APPEND VALUE #( type = 'E'
                                       message = TEXT-007   " Document creation failed !
                              )
                        TO et_return.
              ENDTRY.
              lv_bytecount = xstrlen( lv_xml_data ).
              IF lv_xml_data IS NOT INITIAL.
                TRY.
                    lt_xml = COND #( WHEN lv_xml_data IS NOT INITIAL
                                               THEN  cl_bcs_convert=>xstring_to_solix( iv_xstring  = lv_xml_data  ) ).
                  CATCH cx_bcs.
                    MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
                    APPEND VALUE #( type = 'E'
                                         message = TEXT-007   " Document creation failed !
                                )
                          TO et_return.
                    EXIT.
                ENDTRY.
              ENDIF.
            ENDIF.
            IF lt_xml IS NOT INITIAL.
              lv_subject = COND #( WHEN lv_line > 1 THEN lv_title_translated
                                   ELSE 'CO_' && ls_tmp1-codocument ).

              TRY.
                  lv_attachment_subject  = lv_subject && '.xlsx'.
                  CONCATENATE '&SO_FILENAME=' lv_attachment_subject INTO ls_attachment_header.
                  APPEND ls_attachment_header TO lt_attachment_header.
                  lo_document->add_attachment(
                                          i_attachment_type    = 'XLS'
                                          i_att_content_hex    = lt_xml
                                          i_attachment_size    = lv_bytecount
                                          i_attachment_header  = lt_attachment_header
                                          i_attachment_subject = lv_subject ).

                CATCH cx_document_bcs.
                  MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
                  APPEND VALUE #( type = 'E'
                                       message = TEXT-007   " Document creation failed !
                              )
                        TO et_return.
                  EXIT.
              ENDTRY.
            ENDIF.
          ELSE.
            APPEND VALUE #( type = 'W'
                       message = TEXT-008 && | | && ls_tmp1-codocument ) TO et_return.
            " No data attached to Delivery Note Application V2 for CO number
          ENDIF.
        ENDIF.
*           Export Excel
        LOOP AT lt_data2mail  INTO DATA(ls_pdf_data) WHERE codocument = ls_tmp1-codocument
                                                       AND tbpdf-pdf IS NOT INITIAL
                                                          GROUP BY  ( codocument = ls_pdf_data-codocument
                                                                      size  = GROUP SIZE
                                                                   index = GROUP INDEX )
                                                        ASCENDING
                                                        REFERENCE INTO DATA(co_group).
          TRY.
              CREATE OBJECT lo_pdf_merger.

            CATCH cx_rspo_pdf_merge .
              MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
              APPEND VALUE #( type = 'E'
                                   message = TEXT-007   " Document creation failed !
                          )
                    TO et_return.
              EXIT.
          ENDTRY.

          LOOP AT GROUP co_group ASSIGNING FIELD-SYMBOL(<fl_codocument>).

            IF co_group->size > 1.
              DATA(lv_merge_doc) = <fl_codocument>-codocument.
              DATA(lv_merge_carr) = <fl_codocument>-carrier.
              DATA(lv_doc_type) = <fl_codocument>-pdf_doc_type.

              MOVE <fl_codocument>-tbpdf-pdf TO lw_document.
              lo_pdf_merger->check_document( EXPORTING document    = lw_document
                                             IMPORTING error_text  = lv_error_text
                                                       rc          = lv_rc ).
              IF lv_rc = 0.
                lo_pdf_merger->add_document( lw_document ).
              ENDIF.
            ELSEIF co_group->size = 1.
              lv_merge_doc = <fl_codocument>-codocument.
              lv_merge_carr = <fl_codocument>-carrier.
              CLEAR: lv_datasize,lv_subject,lv_pdf_size_wbs, lv_pdf_content_wbs.
              lv_pdf_size_wbs = xstrlen( <fl_codocument>-tbpdf-pdf ).
              lv_pdf_content_wbs = cl_document_bcs=>xstring_to_solix(
                                                  ip_xstring = <fl_codocument>-tbpdf-pdf ).
*             limitation size of PDF file
              lv_datasize = lv_datasize + lv_pdf_size_wbs.
              IF lv_datasize > 20971520.
                MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
                APPEND VALUE #( type = 'E'
                                     message = TEXT-007   " Document creation failed !
                            )
                      TO et_return.
                EXIT.
              ENDIF.
              IF lv_pdf_content_wbs IS NOT INITIAL.
                lv_subject = 'CO' && '_' && lv_merge_doc .
                TRY.
                    lo_document->add_attachment(
                          i_attachment_type    = 'PDF'
                          i_att_content_hex    = lv_pdf_content_wbs
                          i_attachment_size    = lv_datasize
                          i_attachment_subject = lv_subject ).

                  CATCH cx_document_bcs.
                    MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
                    APPEND VALUE #( type = 'E'
                                         message = TEXT-007   " Document creation failed !
                                )
                          TO et_return.
                    EXIT.
                ENDTRY.
              ENDIF.
            ENDIF.

          ENDLOOP.
        ENDLOOP.
        IF lo_pdf_merger IS BOUND.
          lo_pdf_merger->get_document(
            EXPORTING index  = 1
              IMPORTING document = DATA(lv_strream) ).
        ENDIF.
        IF lv_strream IS NOT INITIAL.
          TRY.
              lo_pdf_merger->merge_documents( IMPORTING merged_document = lv_merged_document rc = lv_rc ).
            CATCH  cx_rspo_pdf_merge.
              lv_rc = 1.
              MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
              APPEND VALUE #( type = 'E'
                           message = TEXT-007   " Document creation failed !
                          )
                    TO et_return.
              EXIT.
          ENDTRY.

          IF lv_rc = 0.

            ls_formoutput-pdf = lv_merged_document.
            lv_pdf_size_lfg = xstrlen( ls_formoutput-pdf ).
            IF lv_pdf_size_lfg > 20971520.
              MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
              APPEND VALUE #( type = 'E'
                           message = TEXT-007   " Document creation failed !
                          )
                    TO et_return.
              EXIT.
            ENDIF.
            lv_pdf_content_lfg = cl_document_bcs=>xstring_to_solix(
                ip_xstring  = ls_formoutput-pdf ).
            IF lv_pdf_content_lfg IS NOT INITIAL.
              lv_subject = 'CO' && '_' && lv_merge_doc .
              TRY.
                  lo_document->add_attachment(
                        i_attachment_type    = 'PDF'
                        i_att_content_hex    = lv_pdf_content_lfg
                        i_attachment_size    = lv_pdf_size_lfg
                        i_attachment_subject = lv_subject ).

                CATCH cx_document_bcs.
                  MESSAGE TEXT-006 TYPE 'E'.  " Document is failed to generate !
                  APPEND VALUE #( type = 'E'
                                       message = TEXT-007   " Document creation failed !
                              )
                        TO et_return.
                  EXIT.
              ENDTRY.
            ENDIF.
          ENDIF.
        ENDIF.

        TRY.
*          Subject
            lv_subject2 = lv_title_translated .
            lo_send_request = cl_bcs=>create_persistent( ).
            lo_send_request->set_message_subject( ip_subject = lv_subject2 ).
*              Email address....
            TRY.

                LOOP AT it_recipients INTO DATA(ls_recipient).
                  MOVE ls_recipient-line TO lv_email .
                  lo_recipient = cl_cam_address_bcs=>create_internet_address(
                     i_address_string = lv_email ).
                  lo_send_request->add_recipient( i_recipient = lo_recipient i_blind_copy = 'X' ).
                ENDLOOP.
              CATCH cx_address_bcs.

            ENDTRY.

            lo_send_request->set_document( lo_document ).
            IF lv_pdf_content_lfg IS NOT INITIAL OR lt_xml IS NOT INITIAL.
              lv_sent_to_all = lo_send_request->send( i_with_error_screen = 'X' ).
            ELSE.
              lv_sent_to_all = abap_false.
            ENDIF.

            IF lv_sent_to_all EQ abap_true.
              MESSAGE TEXT-009 TYPE 'S'.
              APPEND VALUE #( type = 'S'
                     message = TEXT-009         " Document attached to email successfully !
            )
              TO et_return.

            ENDIF.

            FREE :lo_send_request, lo_pdf_merger, lo_document, lv_strream.
            CLEAR: lv_pdf_content_lfg,lv_pdf_content_wbs,ls_do_exist, lt_xml.
            DELETE lt_data2mail WHERE codocument = ls_tmp1-codocument.
            lv_co = VALUE #( lt_data2mail[ 1 ]-codocument OPTIONAL ).
            CONTINUE.

          CATCH cx_send_req_bcs.
            MESSAGE TEXT-010 TYPE 'E'.            "Send mail failed !
            APPEND VALUE #( type = 'E'
                         message = TEXT-010    "Send mail failed !
                        )
                  TO et_return.
            EXIT.
        ENDTRY.
      ENDIF.
    ENDLOOP.
  ENDMETHOD.


