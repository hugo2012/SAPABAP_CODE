    ENDIF.

*           Help Variable...
    lt_data2mail = CORRESPONDING #( it_pdf_data ).
    DATA(lv_car) = VALUE #( it_pdf_data[ 1 ]-carrier OPTIONAL ).
    LOOP AT it_pdf_data INTO DATA(ls_tmp1) .
      CLEAR: lt_text_html.
      CHECK lt_data2mail IS NOT INITIAL.
      IF ls_tmp1-carrier EQ lv_car.
        CLEAR :  lt_fo, lt_text_html.
        TRY.
            CREATE OBJECT lo_document.
            CREATE OBJECT lo_pdf_merger.

          CATCH cx_rspo_pdf_merge cx_document_bcs.
            MESSAGE 'Send mail failed !' TYPE 'E'.
            APPEND VALUE #( type = 'E'
                                 message = 'Send mail failed !'
                        )
                  TO et_return.
            EXIT.
        ENDTRY.
        DATA(lt_subject_temp) = lt_subject.
        DATA(lt_excel) = lt_freightorder.
        DELETE lt_subject_temp  WHERE carrier NE ls_tmp1-carrier.
        DELETE lt_excel  WHERE carrier NE ls_tmp1-carrier.
        DATA(ls_do_exist) = VALUE #( lt_excel[ deliverydocument = ls_tmp1-vbeln ]-deliverydocument OPTIONAL ).
        lt_fo = VALUE #( BASE lt_fo FOR ls_sub IN lt_subject_temp ( ls_sub-freightorderdocument )  ).
*          Subject
        lv_subject = lv_title_translated  && | | &&  ls_tmp1-freightorderdocument && | | &&  '/' && | | && ls_tmp1-carriername  .
        lt_text_html = lc_beginhtmltag && lt_text_html.
        DATA(lv_string) = '<p>The list of FO number belong to' && | | && ls_tmp1-carriername && | | && ':</p> '.
        lt_text_html = lc_beginhtmltag  && lv_string.

        CLEAR lv_string.
