  method /RB1M/IF_SD_PRINTOUT_UTIL~GET_RFC_DESTINATION.
      DATA:  lv_logsys TYPE logsys.
*-Fetch System ID
    CALL FUNCTION 'OWN_LOGICAL_SYSTEM_GET'
      IMPORTING
        own_logical_system             = lv_logsys
      EXCEPTIONS
        own_logical_system_not_defined = 1
        OTHERS                         = 2.
    IF sy-subrc <> 0.
      CLEAR rv_rfc_dest.
      RETURN.
    ENDIF.

*-Fetching RFC Destination based on System ID
    SELECT SINGLE * FROM /rb1m/sd_i_rfcmap_basic INTO @DATA(ls_rfcmap)
                       WHERE logsys EQ @lv_logsys.

    IF sy-subrc IS INITIAL.
      CALL FUNCTION 'RFC_CALLBACK_REJECTED'.
      CALL FUNCTION 'RFC_PING' DESTINATION ls_rfcmap-rfcdest
        EXCEPTIONS
          system_failure        = 1
          communication_failure = 2
          OTHERS                = 99.
      IF sy-subrc IS INITIAL.
        rv_rfc_dest = ls_rfcmap-rfcdest.
      ENDIF.
    ENDIF.
  endmethod.


  METHOD /rb1m/if_sd_printout_util~submit_pdf2mail_prog.

    DATA:
      lr_unprocess   TYPE /rb1m/if_sd_printout_dataprovd=>tr_proc,
      lo_message     TYPE REF TO /bobf/if_frw_message,
      lt_messagetype TYPE /rb1m/cl_sd_printout_d_mpc=>tt_output,
      lt_output      TYPE /rb1m/cl_sd_printout_d_mpc=>tt_output.

    DATA : lr_codoc      TYPE /rb1m/cl_sd_printout_util=>/rb1m/if_sd_printout_util~ty_r_codoc,
           lr_fodoc      TYPE /rb1m/cl_sd_printout_util=>/rb1m/if_sd_printout_util~ty_r_codoc,
           lr_output     TYPE /rb1m/cl_sd_printout_util=>/rb1m/if_sd_printout_util~ty_r_output,
           lr_actiontype TYPE /rb1m/cl_sd_printout_util=>/rb1m/if_sd_printout_util~ty_r_actiontype.


    CLEAR: lt_messagetype,lt_output,lr_unprocess,ev_subrc.

    IF it_freightorder IS INITIAL.
      ev_subrc  = 4.
      RETURN.
    ENDIF.
*    get message type
    lr_unprocess = VALUE #(
                       ( sign = 'I'
                         option = 'EQ'
                         low = '1'" green status
                       )
                       ( sign = 'I'
                         option = 'EQ'
                         low = '0'" yellow status
                       )
                        ).

    CALL METHOD /rb1m/cl_sd_printout_dataprovd=>/rb1m/if_sd_printout_dataprovd~get_message_type_batch
      EXPORTING
        it_freightorder   = it_freightorder
        ir_process        = lr_unprocess
      IMPORTING
        et_output_type    = lt_output
        et_messagetype    = lt_messagetype              " get message type
        ev_export_excel   = DATA(lv_export_excel)       " get export excel option
        es_data2mail      = DATA(ls_data2mail).

    IF lt_messagetype IS INITIAL.
      ev_subrc  = 4.
      RETURN.
    ENDIF.
*  Write logic for submit program
    lr_fodoc =  VALUE #(   FOR ls_fo2fonav IN lt_output
                           ( sign = 'I'
                             option = 'EQ'
                             low = ls_fo2fonav-freightorderdocument
                            )
                         ).
    SORT lr_fodoc BY low.
    DELETE ADJACENT DUPLICATES FROM lr_fodoc COMPARING low.

    lr_codoc =  VALUE #( FOR ls_fo2conav IN it_freightorder
                         ( sign = 'I'
                           option = 'EQ'
                           low = ls_fo2conav-codocument
                          )
                       ).
    SORT lr_codoc BY low.
    DELETE ADJACENT DUPLICATES FROM lr_codoc COMPARING low.

    lr_output =   VALUE #( FOR ls_fo2output IN lt_messagetype
                           WHERE ( messagetype IS NOT INITIAL )
                            ( sign = 'I'
                              option = 'EQ'
                              low = ls_fo2output-messagetype
                             )
                       ).

    lr_actiontype =   VALUE #( FOR ls_fo2actiontype IN lt_messagetype
                                WHERE ( actiontype IS NOT INITIAL )
                                ( sign = 'I'
                                  option = 'EQ'
                                  low = ls_fo2actiontype-actiontype
                                 )
                   ).

*   Get body text of email
    CALL METHOD /rb1m/cl_sd_printout_dataprovd=>/rb1m/if_sd_printout_dataprovd~get_email_text_batch(
      IMPORTING
        et_text      = DATA(lt_text)
        ev_mail_text = DATA(lv_mailtext)
    ).

    IF lv_mailtext  IS INITIAL.
      ev_subrc  = 4.
      RETURN.
    ENDIF.
*   Get Email Recipients.
    DATA(lv_shipping_point) = VALUE #( it_freightorder[ 1 ]-shippingpoint OPTIONAL ).
    DATA(lv_ship_to_party) =  VALUE #( it_freightorder[ 1 ]-shiptoparty OPTIONAL ).

    CALL METHOD /rb1m/cl_sd_printout_dataprovd=>/rb1m/if_sd_printout_dataprovd~get_recipients_batch
      EXPORTING
        iv_shiptoparty      = lv_ship_to_party
        iv_shippingpoint    = lv_shipping_point
      IMPORTING
        er_emailid          = DATA(lr_mailid).

    IF lr_mailid[] IS INITIAL.
      ev_subrc  = 4.
      RETURN.
    ENDIF.

*   get not processed status
    DATA(lv_processstatus_yellow) = abap_true.
*   get processed status
    DATA(lv_processstatus_green) = abap_true.

* " run forceground  - Direct submit
    SUBMIT /rb1m/sd_sh_printout_data2mail
        WITH s_fo     IN lr_fodoc
        WITH s_co     IN lr_codoc
        WITH s_out_p  IN lr_output
        WITH s_act_p  IN lr_actiontype
        WITH p_excel  EQ lv_export_excel
        WITH p_batch  EQ 'X'
        WITH p_langu  EQ sy-langu
        WITH p_inv    EQ ls_data2mail-directinvoice
        WITH p_mlbinv EQ ls_data2mail-mlbinvoice
        WITH p_proinv EQ ls_data2mail-proformadirectinvoice
        WITH p_pminv  EQ ls_data2mail-proformamlbinvoice
        WITH p_prcsg  EQ lv_processstatus_green
        WITH p_prcsy  EQ lv_processstatus_yellow
        WITH p_merge  EQ '01'
        WITH p_text   EQ lv_mailtext
        WITH s_mail   IN lr_mailid
        AND RETURN.
    IF sy-subrc IS NOT INITIAL.
      ev_subrc = 2.
    ELSE.
      ev_subrc = 0.
    ENDIF.

  ENDMETHOD.


  METHOD /rb1m/if_sd_printout_util~send_email_failure_case.
    DATA: lv_title(20) TYPE c,
          lv_text      TYPE soli_tab,
          lv_text_html TYPE string.
    DATA:
      lo_document        TYPE REF TO cl_document_bcs,
      lo_cx_document_bcs TYPE REF TO cx_document_bcs,
      lo_send_request    TYPE REF TO cl_bcs,
      lv_pdf_content_lfg TYPE solix_tab,
      lv_email           TYPE adr6-smtp_addr,
      lv_sent_to_all     TYPE os_boolean,
      lo_recipient       TYPE REF TO if_recipient_bcs,
      lo_exception       TYPE REF TO cx_send_req_bcs.
    DATA: lv_subject  TYPE so_obj_des,
          lv_subject2 TYPE string.

    CONSTANTS:
      lc_beginhtmltag TYPE char30 VALUE '<html> <body>',
      lc_endhtmltag   TYPE char30 VALUE '</body> </html>'.

    lv_title = TEXT-002 . " Bosch shipment
*       Subject of Email
    lv_subject = lv_title && | | && iv_codocument .
*       Content of Email
    lv_text_html = TEXT-016 && | | && iv_codocument && | | && TEXT-017 .
    lv_text_html = lc_beginhtmltag && lv_text_html.
    lv_text_html = lv_text_html && lc_endhtmltag.
    lv_text = cl_bcs_convert=>string_to_soli( lv_text_html ).
    TRY.

        lo_document = cl_document_bcs=>create_document(
            i_type      = 'HTM'
            i_text      = lv_text
            i_subject   = lv_subject ).
      CATCH cx_document_bcs INTO lo_cx_document_bcs.
    ENDTRY.
    lo_send_request = cl_bcs=>create_persistent( ).
    lv_subject2 = lv_subject.
    lo_send_request->set_message_subject( ip_subject = lv_subject2 ).
*    Email address....
    TRY.

        LOOP AT it_recipients INTO DATA(ls_recipient).
          MOVE ls_recipient-line TO lv_email .
          lo_recipient = cl_cam_address_bcs=>create_internet_address(
             i_address_string = lv_email ).
          lo_send_request->add_recipient( i_recipient = lo_recipient i_blind_copy = 'X' ).
        ENDLOOP.
      CATCH cx_address_bcs.

    ENDTRY.
    lo_send_request->set_document( lo_document ).
    lv_sent_to_all = lo_send_request->send( i_with_error_screen = 'X' ).
    COMMIT WORK.

  ENDMETHOD.
