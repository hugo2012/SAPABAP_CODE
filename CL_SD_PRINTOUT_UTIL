    CHECK iv_delivery_number IS NOT INITIAL.
    "get SO Number
    SELECT SINGLE
       FROM  i_sddocumentprocessflow
      WITH PRIVILEGED ACCESS  FIELDS precedingdocument, precedingdocumentitem
    WHERE subsequentdocument EQ @iv_delivery_number
