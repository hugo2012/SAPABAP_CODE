/* ABAP:/RB1M/CL_LE_CP_VE_FILTER */
CLASS /rb1m/cl_le_cp_ve_filter DEFINITION
  PUBLIC
  FINAL
  CREATE PUBLIC .

  PUBLIC SECTION.
    INTERFACES if_sadl_exit .
    INTERFACES if_sadl_exit_filter_transform .
  PROTECTED SECTION.
  PRIVATE SECTION.
ENDCLASS.



CLASS /RB1M/CL_LE_CP_VE_FILTER IMPLEMENTATION.


  METHOD if_sadl_exit_filter_transform~map_atom.
    "Map element to the associated field and apply operator
    CASE iv_element.
      WHEN 'AREAOFUSAGE'.
        DATA(lo_element) = cl_sadl_cond_prov_factory_pub=>create_simple_cond_factory( )->element( '_PARAMVALUE.AREAOFUSAGE' ).
        ro_condition = lo_element->equals( iv_value ).
      WHEN 'QUALIFIERID'.
        lo_element = cl_sadl_cond_prov_factory_pub=>create_simple_cond_factory( )->element( '_PARAMVALUE.QUALIFIERID' ).
        ro_condition = lo_element->equals( iv_value ).
      WHEN 'QUALVALUE'.
        lo_element = cl_sadl_cond_prov_factory_pub=>create_simple_cond_factory( )->element( '_PARAMVALUE.QUALVALUE' ).
        ro_condition = lo_element->covers_pattern( iv_value ).
    ENDCASE.
  ENDMETHOD.
ENDCLASS.

