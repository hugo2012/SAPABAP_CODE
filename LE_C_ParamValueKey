{
          @Consumption.valueHelpDefinition: [{entity:{name:'/RB4R/SD_I_CSP', element: 'CustomerShippingProfile'} } ]
  key     CustShippingProfile,
          @Consumption.valueHelpDefinition: [{entity:{name:'I_SHIPPINGPOINTVH', element: 'ShippingPoint'} } ]
  key     ShippingPoint,
          @Consumption.valueHelpDefinition: [{entity:{name:'I_CUSTOMER_VH', element: 'Customer'} }]
  key     ShipToParty,
          @Consumption.valueHelpDefinition: [{entity:{name:'/RB1M/LE_A_GROUPDEF', element: 'GroupID'} }]
