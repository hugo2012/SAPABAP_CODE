    WHERE PartnerType IN @ir_asn_partner_type
      AND Description IN @ir_description
      AND langu = @sy-langu
     INTO TABLE @lt_data.
    IF sy-subrc IS INITIAL.
      SORT lt_data BY partnertype.
      et_asnpartner_type_data = CORRESPONDING #( lt_data ).
    ENDIF.
  ENDMETHOD.


  METHOD get_countries_data.
*    DATA(lv_language) = COND #( WHEN iv_language IS INITIAL
*                                THEN sy-langu
*                                ELSE iv_language ).
*    SELECT DISTINCT a~land1 AS Country,
*                    b~Spras AS Language,
