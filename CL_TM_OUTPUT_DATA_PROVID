  METHOD validate_received_data.
    DATA: lv_fieldname TYPE fnam_____4,
          lv_kunnr     TYPE kunnr,
          lt_failure   TYPE STANDARD TABLE OF ddfkeyrc.
* Validate received data in case of Update or create.
    IF iv_mode EQ 'U' OR iv_mode EQ 'I'.
      "Fetch check tables details for all the fields of the custom table
      SELECT fieldname, keyflag, rollname, checktable FROM dd03L
                                                      WHERE Tabname   EQ @iv_tabname AND
                                                            checktable IS NOT INITIAL
                                                      INTO TABLE @DATA(lt_check_tables).
      IF sy-subrc EQ 0.
        DELETE lt_check_tables WHERE fieldname EQ 'MANDT'. "MANDT data need not be checked
        IF iv_mode EQ 'U'."In case of update no need to check key fields data
          DELETE lt_check_tables WHERE keyflag EQ abap_true.
        ENDIF.
      ENDIF.

      LOOP AT it_items ASSIGNING FIELD-SYMBOL(<lfs_items>).
        LOOP AT lt_check_tables ASSIGNING FIELD-SYMBOL(<lfs_check_tables>).
          ASSIGN COMPONENT <lfs_check_tables>-fieldname OF STRUCTURE <lfs_items> TO FIELD-SYMBOL(<lfs_field_value>).
          IF <lfs_field_value> IS ASSIGNED.
            IF <lfs_check_tables>-fieldname = 'SHIP_TO_PARTY'.
              lv_kunnr = <lfs_field_value>.
              lv_kunnr = |{ lv_kunnr ALPHA = IN }|.
              ASSIGN lv_kunnr to <lfs_field_value>.
            ENDIF.
            CLEAR: lv_fieldname.
            lv_fieldname = <lfs_check_tables>-fieldname.
            "Validate field value against check table using below FM
            CALL FUNCTION 'DDUT_INPUT_CHECK'
              EXPORTING
                tabname       = iv_tabname
                fieldname     = lv_fieldname
                value         = <lfs_field_value>
              IMPORTING
                msgid         = sy-msgid
                msgty         = sy-msgty
                msgno         = sy-msgno
                msgv1         = sy-msgv1
                msgv2         = sy-msgv2
                msgv3         = sy-msgv3
                msgv4         = sy-msgv4
              TABLES
                failure_tab   = lt_failure
              EXCEPTIONS
                no_ddic_field = 1
                illegal_move  = 2
                OTHERS        = 3.
            IF lt_failure IS NOT INITIAL.
              EXIT.
            ENDIF.
          ENDIF.
          UNASSIGN: <lfs_field_value>.
        ENDLOOP.
        IF lt_failure IS NOT INITIAL.
          EXIT.
        ENDIF.
      ENDLOOP.
      IF lt_failure IS NOT INITIAL.
        ev_failure = abap_true.
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD get_domain_value.
    DATA lt_dd07v TYPE STANDARD TABLE OF dd07v.

    CALL FUNCTION 'DD_DOMVALUES_GET'
      EXPORTING
        domname        = iv_domain
        text           = 'X'
        langu          = 'E'
      TABLES
        dd07v_tab      = lt_dd07v
      EXCEPTIONS
        wrong_textflag = 1
        OTHERS         = 2.
    IF sy-subrc IS INITIAL.
      et_return = CORRESPONDING #( lt_dd07v ).
    ENDIF.

  ENDMETHOD.
ENDCLASS.
