  METHOD get_access_sequences.
    "Fetch data from Access sequence mapping table
    SELECT OutputType       AS output_type,
           TableName        AS table_name,
           TableDescription AS table_description,
           AccessSequence   AS access_sequence
           FROM /RB1M/tm_I_acc_map
           WHERE outputType EQ @iv_output_type
           INTO TABLE @DATA(lt_acc_seq).
    IF sy-subrc EQ 0.
      SORT lt_acc_seq BY access_sequence.
      IF sy-langu EQ 'D'."German Translations
        LOOP AT lt_acc_seq ASSIGNING FIELD-SYMBOL(<lfs_acc_seq>).
          IF <lfs_acc_seq>-Table_name EQ '/RB1M/TM_ACCESS1'.
            <lfs_acc_seq>-table_description = 'Zugriffsfolge : Versandstelle / Warenempfänger'(001).
          ELSEIF <lfs_acc_seq>-Table_name EQ '/RB1M/TM_ACCESS2'.
            <lfs_acc_seq>-table_description = 'Zugriffsfolge : Versandstelle / CSP'(002).
          ELSEIF <lfs_acc_seq>-Table_name EQ '/RB1M/TM_ACCESS3'.
            <lfs_acc_seq>-table_description = 'Zugriffsfolge : Versandstelle'(003).
          ELSEIF <lfs_acc_seq>-Table_name EQ '/RB1M/TM_ACCESS4'.
            <lfs_acc_seq>-table_description = 'Zugriffsfolge : Versandstelle / Land'(004).
          ENDIF.
        ENDLOOP.
      ENDIF.
      et_access_seq = CORRESPONDING #( lt_acc_seq ).
    ENDIF.
  ENDMETHOD.


  method GET_ASN_PARTNER.
    DATA lv_partnernumber TYPE char10.
    Select Parnum as PARTNERNUMBER, Partyp as PARTNERTYPE
      FROM /RB1M/TM_I_ASNPartner
    WHERE Parnum in @ir_asn_partner
      AND partyp in @ir_asn_partner_type
     into TABLE @DATA(lt_data).
    IF sy-subrc is INITIAL.
      SORT lt_data by PARTNERNUMBER.
      LOOP AT lt_data ASSIGNING FIELD-SYMBOL(<lfs_data>).
        CLEAR lv_partnernumber.
*          lv_partnernumber = | { <lfs_data>-partnernumber ALPHA = OUT } |.
          CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
            EXPORTING
              input        = <lfs_data>-partnernumber
           IMPORTING
             OUTPUT        = lv_partnernumber
                  .
          CONDENSE lv_partnernumber NO-GAPS.
          <lfs_data>-partnernumber = lv_partnernumber.
      ENDLOOP.
      et_asnpartner_data = CORRESPONDING #( lt_data ).
    ENDIF.
  endmethod.


  METHOD get_asn_partner_type.
    DATA: lt_data TYPE STANDARD TABLE OF /RB1M/TM_ASN_PARTNER_TYPE.
    SELECT PartnerType AS partnertype, Description AS Description
