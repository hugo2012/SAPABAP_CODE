  METHOD get_csp_data.
    SELECT  CustomerShippingProfile AS csp,
                    CspDescription AS csp_description
                       FROM /rb4r/sd_i_csp
                       WHERE upper( CustomerShippingProfile ) IN @Ir_csp AND
                             upper( cspDescription ) IN @ir_description
                       INTO CORRESPONDING FIELDS OF TABLE @et_csp_data.
    IF sy-subrc EQ 0.
      SORT et_csp_data BY csp.
      LOOP AT et_csp_data ASSIGNING FIELD-SYMBOL(<lfs_csp>).
        TRANSLATE <lfs_csp>-csp TO UPPER CASE.
      ENDLOOP.
    ENDIF.
  ENDMETHOD.


  METHOD get_filters_from_service.
    IF is_service IS NOT INITIAL.
      "Get Filters from service
      er_ship_point = CORRESPONDING #( is_service-shippointsonav[] ).
      er_ship_to    = CORRESPONDING #( is_service-Shiptosonav[] ).
      er_csp        = CORRESPONDING #( is_service-cspsonav[] ).
      er_country    = CORRESPONDING #( is_service-countrysonav[] ).

      IF er_csp IS NOT INITIAL.
        LOOP AT er_csp ASSIGNING FIELD-SYMBOL(<lfs_csp>).
          IF <lfs_csp>-low IS NOT INITIAL.
            TRANSLATE <lfs_csp>-low TO UPPER CASE.
          ENDIF.
          IF <lfs_csp>-high IS NOT INITIAL.
            TRANSLATE <lfs_csp>-high TO UPPER CASE.
          ENDIF.
        ENDLOOP.
      ENDIF.

      IF er_ship_point IS NOT INITIAL.
        LOOP AT er_ship_point ASSIGNING FIELD-SYMBOL(<lfs_ship_point>).
          IF <lfs_ship_point>-low IS NOT INITIAL.
            TRANSLATE <lfs_ship_point>-low TO UPPER CASE.
          ENDIF.
          IF <lfs_ship_point>-high IS NOT INITIAL.
            TRANSLATE <lfs_ship_point>-high TO UPPER CASE.
          ENDIF.
        ENDLOOP.
      ENDIF.

      IF er_country IS NOT INITIAL.
        LOOP AT er_country ASSIGNING FIELD-SYMBOL(<lfs_country>).
          IF <lfs_country>-low IS NOT INITIAL.
            TRANSLATE <lfs_country>-low TO UPPER CASE.
          ENDIF.
          IF <lfs_country>-high IS NOT INITIAL.
            TRANSLATE <lfs_country>-high TO UPPER CASE.
          ENDIF.
        ENDLOOP.
      ENDIF.

      IF is_service-output_type IS NOT INITIAL.
        er_output = VALUE tr_output( BASE er_output ( sign   = 'I'
                                                      option = 'EQ'
                                                      low    = is_service-output_type ) ).
      ENDIF.
    ENDIF.
  ENDMETHOD.


  METHOD get_filter_for_where_clause.
    DATA: ls_filter TYPE /rb4r/plm_tabflt.

    IF ir_output IS NOT INITIAL.
      LOOP AT ir_output INTO DATA(ls_output).
        ls_filter-tablename = iv_table_name.
        ls_filter-FIeldname = 'OUTPUT_TYPE'.
        ls_filter-sign      = ls_output-sign.
        ls_filter-opt       = ls_output-option.
        ls_filter-value     = ls_output-low.
        APPEND ls_filter TO et_filter.
      ENDLOOP.
    ENDIF.

    IF ir_ship_point IS NOT INITIAL.
      LOOP AT ir_ship_point INTO DATA(ls_ship_point).
        ls_filter-tablename = iv_table_name.
        ls_filter-FIeldname = 'SHIPPING_POINT'.
        ls_filter-sign      = ls_ship_point-sign.
        ls_filter-opt       = ls_ship_point-option.
        ls_filter-value     = ls_ship_point-low.
        APPEND ls_filter TO et_filter.
      ENDLOOP.
    ENDIF.

    CASE iv_table_name.
      WHEN '/RB1M/TM_ACCESS1'.
        IF ir_ship_to IS NOT INITIAL.
          LOOP AT ir_ship_TO INTO DATA(ls_ship_TO).
            ls_filter-tablename = iv_table_name.
            ls_filter-FIeldname = 'SHIP_TO_PARTY'.
            ls_filter-sign      = ls_ship_to-sign.
            ls_filter-opt       = ls_ship_to-option.
            ls_filter-value     = ls_ship_to-low.
            APPEND ls_filter TO et_filter.
          ENDLOOP.
        ENDIF.
      WHEN '/RB1M/TM_ACCESS2'.
        IF ir_csp IS NOT INITIAL.
          LOOP AT ir_csp INTO DATA(ls_csp).
            ls_filter-tablename = iv_table_name.
            ls_filter-fieldname = 'CSP'.
            ls_filter-sign      = ls_csp-sign.
            ls_filter-opt       = ls_csp-option.
            ls_filter-value     = ls_csp-low.
            APPEND ls_filter TO et_filter.
          ENDLOOP.
        ENDIF.
      WHEN '/RB1M/TM_ACCESS4'.
        IF ir_country IS NOT INITIAL.
          LOOP AT ir_country INTO DATA(ls_country).
            ls_filter-tablename = iv_table_name.
            ls_filter-fieldname = 'DEST_COUNTRY'.
            ls_filter-sign      = ls_country-sign.
            ls_filter-opt       = ls_country-option.
            ls_filter-value     = ls_country-low.
            APPEND ls_filter TO et_filter.
          ENDLOOP.
        ENDIF.
      WHEN OTHERS.
    ENDCASE.
  ENDMETHOD.


  METHOD get_header_data.
    DATA: lr_data     TYPE REF TO data,
          lt_comp_tab TYPE cl_abap_structdescr=>component_table,
          ls_comp_fld TYPE cl_abap_structdescr=>component,
          ls_header   TYPE /rb1m/tm_dynamic_header.
* Local field symbols declarations
    FIELD-SYMBOLS: <lfs_table>      TYPE STANDARD TABLE,
                   <lfs_table_line> TYPE any,
                   <lfs_struct>     TYPE any.
    " Get Dynamic table structure
    DATA(lo_structdescr) = CAST cl_abap_structdescr( cl_abap_structdescr=>describe_by_name( is_dynamic_entity-Table_name ) ).
    DATA(lt_fieldlist)   = lo_structdescr->get_ddic_field_list(  ).
    IF lt_fieldlist IS NOT INITIAL.
      DELETE lt_fieldlist WHERE Fieldname EQ 'MANDT'.
    ENDIF.
    lt_comp_tab          = lo_structdescr->get_components( ).

    IF lt_fieldlist IS NOT INITIAL.
      et_fields_list = lt_fieldlist.
    ENDIF.

    "Define Dynamic Table and Work Area based on table name received
    CREATE DATA lr_data TYPE STANDARD TABLE OF (is_dynamic_entity-Table_name).
    ASSIGN lr_data->* TO <lfs_table>.

    CREATE DATA lr_data LIKE LINE OF <lfs_table>.
    ASSIGN lr_data->* TO <lfs_table_line>.

    DATA(lv_index) = 1.
    "Fill Dynamic header
    LOOP AT lt_comp_tab ASSIGNING FIELD-SYMBOL(<lfs_comp_tab>) WHERE name <> 'MANDT'.
      DATA(ls_fieldlist) = VALUE #( lt_fieldlist[ FIeldname = <lfs_comp_tab>-name ] OPTIONAL ).
      IF sy-subrc EQ 0 AND ls_fieldlist IS NOT INITIAL.
        ls_header-output_type  = is_dynamic_entity-output_type.
        ls_header-Table_name   = is_dynamic_entity-Table_name.
        ls_header-title        = is_dynamic_entity-title.
        ls_header-header_index = lv_index.
        ls_header-header_key   = ls_fieldlist-keyflag.
        ls_header-header_name  = ls_fieldlist-FIeldname.
        ls_header-header_type  = 'String'.
        ls_header-header_value = ls_fieldlist-scrtext_m.
        APPEND ls_header TO et_header_data.
      ENDIF.
      lv_index = lv_index + 1.
      CLEAR: ls_header, ls_fieldlist.
    ENDLOOP.
  ENDMETHOD.


